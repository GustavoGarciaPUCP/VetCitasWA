@* ====== Tarjeta de usuario (roles reales del usuario logueado) ====== *@
<div class="user-card">
    <div class="user-avatar">@Inicial</div>
    <div class="user-meta">
        <div class="user-name">@NombreUsuario</div>
        <div class="role-chips role-chips-static">
            @if (EsVet)
            {
                <span class="role-chip role-chip-vet">Vet</span>
            }
            @if (EsRecep)
            {
                <span class="role-chip role-chip-recep">Recep</span>
            }
            @if (EsAdmin)
            {
                <span class="role-chip role-chip-admin">Admin</span>
            }
        </div>
    </div>
</div>

