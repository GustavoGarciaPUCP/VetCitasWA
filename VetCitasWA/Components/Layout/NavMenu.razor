@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool EsVet, EsRecep, EsAdmin;
    private string NombreUsuario = "";
    private string Inicial = "?";

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null) return;
        var user = (await AuthState).User;
        if (user.Identity?.IsAuthenticated == true)
        {
            NombreUsuario = user.Identity.Name ?? user.FindFirst("Username")?.Value ?? "";
            Inicial = string.IsNullOrWhiteSpace(NombreUsuario) ? "?" : char.ToUpperInvariant(NombreUsuario[0]).ToString();
            EsVet = user.IsInRole("VETERINARIO");
            EsRecep = user.IsInRole("RECEPCIONISTA");
            EsAdmin = user.IsInRole("ADMINISTRADOR");
        }
    }
}
