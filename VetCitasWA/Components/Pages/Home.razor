@page "/"
@using System.Globalization
@using System.Security.Claims
@using VetCitasWA.Servicios.Modelo.Cita
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject AuthenticationStateProvider AuthStateProvider
@inject VetCitasWA.Servicios.REST.CitaRS.CitaRestService CitaService
@inject VetCitasWA.Servicios.REST.CitaRS.AtencionRestService AtencionService
@inject VetCitasWA.Servicios.REST.CitaRS.RecordatorioRestService RecordatorioService
@inject VetCitasWA.Servicios.REST.UsuarioRS.VeterinarioRestService VeterinarioService
@inject VetCitasWA.Servicios.REST.ClienteRS.ClienteRestService ClienteService
@inject VetCitasWA.Servicios.REST.ClienteRS.MascotaRestService MascotaService
@inject VetCitasWA.Servicios.REST.ServicioRS.ServicioRestService ServicioService

<PageTitle>Inicio - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Inicio</span>
</SectionContent>

@*
    Dashboard role-aware:
    - Cada bloque marcado con .vet-only / .recep-only / .admin-only se
      muestra solo si el rol correspondiente esta activo (clases
      :root.role-X-active definidas en App.razor).
    - Los KPI y widgets reflejan campos del modelo Java
      (Cita, Atencion, Cliente, Mascota, Servicio, Veterinario,
       Recordatorio, EstadoCita) — ver comentarios al lado.
*@

<div class="dashboard">

    @* ================================================================ *@
    @* ============ DASHBOARD: VETERINARIO ============================ *@
    @* ================================================================ *@
    <article class="dash-block vet-only">

        <header class="dash-block-head">
            <h2 class="dash-block-title">
                <span class="dash-role-pill dash-role-vet">Veterinario</span>
                Hola, @NombreUsuarioCorto. Esta es tu jornada de hoy
            </h2>
            <span class="dash-block-sub">@FechaHoyTexto</span>
        </header>

        @* ----- KPIs del Veterinario ----- *@
        @* Datos: Cita.estado, Cita.fechaHoraInicio, Cita.veterinario,
                 Atencion.fechaHora, Atencion.montoReferencial,
                 Atencion.descuentoAplicado, Atencion.recomendacionControl *@
        <div class="kpi-grid">

            <article class="kpi-card kpi-blue-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Mis citas hoy</div>
                    <div class="kpi-value">@CitasVetHoyActivas.Count</div>
                    <div class="kpi-sub">@ResumenCitasHoy</div>
                </div>
            </article>

            <article class="kpi-card kpi-violet-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" />
                        <path d="m9 12 2 2 4-4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Atenciones del mes</div>
                    <div class="kpi-value">@AtencionesVetMes</div>
                    <div class="kpi-sub">@NombreMesActual @Hoy.Year</div>
                </div>
            </article>

            <article class="kpi-card kpi-green-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 2v6m0 14v-6M2 12h6m14 0h-6" stroke-linecap="round" />
                        <circle cx="12" cy="12" r="3" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Citas esta semana</div>
                    <div class="kpi-value">@CitasVetSemanaActivas.Count</div>
                    <div class="kpi-sub">@RangoSemanaTexto</div>
                </div>
            </article>

            <article class="kpi-card kpi-amber-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke-linecap="round" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Pendientes hoy</div>
                    <div class="kpi-value">@PendientesVetHoy</div>
                    <div class="kpi-sub">Pendientes y confirmadas</div>
                </div>
            </article>

        </div>

        @* ----- Fila 2: Mi Agenda + Servicios que más realizo ----- *@
        <div class="dash-two-col">

            @* === Agenda del día === *@
            <section class="panel">
                <header class="panel-head">
                    <h3 class="panel-title">Mi agenda del día</h3>
                    <a href="/mis-horarios" class="panel-link">Ver la semana completa →</a>
                </header>
                <div class="panel-body">
                    @if (cargandoDashboard)
                    {
                        <p class="estado-mensaje">Cargando datos del tablero...</p>
                    }
                    else if (!CitasVetHoyActivas.Any())
                    {
                        <p class="estado-mensaje">No tienes citas activas asignadas para hoy.</p>
                    }
                    else
                    {
                        @foreach (var cita in CitasVetHoyActivas.OrderBy(c => c.FechaHoraInicio).Take(6))
                        {
                            <div class="ag-item">
                                <div class="ag-time">@cita.FechaHoraInicio.ToString("HH:mm")</div>
                                <div class="ag-info">
                                    <div class="ag-info-head">
                                        <span class="ag-pet">@NombreMascota(cita)</span>
                                        <span class="badge @BadgeEstado(cita.Estado)">
                                            @if (cita.Estado == EstadoCita.EN_CONSULTA)
                                            {
                                                <span class="dash-pulse-dot" aria-hidden="true"></span>
                                            }
                                            @EstadoLabel(cita.Estado)
                                        </span>
                                    </div>
                                    <span class="ag-info-sub">@NombreCliente(cita) · @(cita.Servicio?.Nombre ?? "Servicio sin nombre") · @DuracionCita(cita) min</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </section>

            @* Datos: count by Cita.servicio.nombre WHERE veterinario = me AND estado = ATENDIDA *@
            <section class="panel">
                <header class="panel-head">
                    <h3 class="panel-title">Servicios que más realizo</h3>
                    <span class="panel-sub">Este mes</span>
                </header>
                <div class="panel-body">
                    <div class="bar-list">
                        @if (!TopServiciosVet.Any())
                        {
                            <p class="estado-mensaje">Aun no hay atenciones registradas este mes.</p>
                        }
                        else
                        {
                            @foreach (var item in TopServiciosVet)
                            {
                                <div class="bar-row">
                                    <span class="bar-label">@(item.Servicio?.Nombre ?? "Servicio")</span>
                                    <div class="bar-track">
                                        <div class="bar-fill bar-blue" style="width: @PorcentajeServicio(item.TotalAtenciones)%"></div>
                                    </div>
                                    <span class="bar-value">@item.TotalAtenciones</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </section>

        </div>

    </article>


    @* ================================================================ *@
    @* ============ DASHBOARD: RECEPCIONISTA ========================== *@
    @* ================================================================ *@
    <article class="dash-block recep-only">

        <header class="dash-block-head">
            <h2 class="dash-block-title">
                <span class="dash-role-pill dash-role-recep">Recepción</span>
                Centro de operaciones del día
            </h2>
            <span class="dash-block-sub">@FechaHoyTexto</span>
        </header>

        @* ----- KPIs del Recepcionista ----- *@
        @* Datos: Cita.estado (todas las del día), Cita.veterinario,
                 Recordatorio (estado pendiente), Cliente.activo *@
        <div class="kpi-grid">

            <article class="kpi-card kpi-blue-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Citas hoy</div>
                    <div class="kpi-value">@CitasRecepHoyActivas.Count</div>
                    <div class="kpi-sub">@ResumenRecepcionHoy</div>
                </div>
            </article>

            <article class="kpi-card kpi-amber-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 9v4m0 4h.01" stroke-linecap="round" />
                        <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" stroke-linejoin="round" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Sin confirmar</div>
                    <div class="kpi-value">@SinConfirmarRecepHoy</div>
                    <div class="kpi-sub">En estado pendiente</div>
                </div>
            </article>

            <article class="kpi-card kpi-violet-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" stroke-linecap="round" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Recordatorios</div>
                    <div class="kpi-value">@RecordatoriosPendientes</div>
                    <div class="kpi-sub">Pendientes de envío</div>
                </div>
            </article>

            <article class="kpi-card kpi-rose-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <line x1="18" y1="6" x2="6" y2="18" stroke-linecap="round" />
                        <line x1="6" y1="6" x2="18" y2="18" stroke-linecap="round" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Cancelaciones</div>
                    <div class="kpi-value">@CancelacionesRecepHoy</div>
                    <div class="kpi-sub">Hoy</div>
                </div>
            </article>

        </div>

        @* ----- Fila 2: Cola sin confirmar + Carga por veterinario ----- *@
        <div class="dash-two-col">

            @* Datos: SELECT Cita WHERE estado = PENDIENTE ORDER BY fechaHoraInicio *@
            <section class="panel">
                <header class="panel-head">
                    <h3 class="panel-title">Pendientes de confirmación</h3>
                    <a href="/agenda-citas" class="panel-link">Ver agenda →</a>
                </header>
                <div class="panel-body">
                    @if (cargandoRecepcionDashboard)
                    {
                        <p class="estado-mensaje">Cargando datos de recepcion...</p>
                    }
                    else if (!CitasRecepPendientes.Any())
                    {
                        <p class="estado-mensaje">No hay citas pendientes de confirmacion para hoy.</p>
                    }
                    else
                    {
                        @foreach (var cita in CitasRecepPendientes.Take(6))
                        {
                            <div class="cola-item">
                                <div class="cola-when">
                                    <span class="cola-date">@FechaCortaRecepcion(cita.FechaHoraInicio)</span>
                                    <span class="cola-time">@cita.FechaHoraInicio.ToString("HH:mm")</span>
                                </div>
                                <div class="cola-info">
                                    <span class="cola-pet">@NombreMascota(cita) · @EspecieMascota(cita)</span>
                                    <span class="cola-meta">@NombreCliente(cita) · @ServicioNombre(cita) · @NombreVeterinario(cita)</span>
                                </div>
                                <span class="badge badge-pending">Pendiente</span>
                            </div>
                        }
                    }

                </div>
            </section>

            @* Datos: count(Cita) GROUP BY veterinario WHERE fecha = hoy *@
            <section class="panel">
                <header class="panel-head">
                    <h3 class="panel-title">Carga por veterinario</h3>
                    <span class="panel-sub">Citas activas asignadas hoy</span>
                </header>
                <div class="panel-body">
                    <div class="bar-list">
                        @if (cargandoRecepcionDashboard)
                        {
                            <p class="estado-mensaje">Calculando carga por veterinario...</p>
                        }
                        else if (!CargaVeterinariosRecep.Any())
                        {
                            <p class="estado-mensaje">No hay citas asignadas a veterinarios hoy.</p>
                        }
                        else
                        {
                            @foreach (var item in CargaVeterinariosRecep)
                            {
                                <div class="bar-row">
                                    <span class="bar-label">@CargaVeterinarioLabel(item)</span>
                                    <div class="bar-track">
                                        <div class="bar-fill bar-purple" style="width: @PorcentajeCargaRecepcion(item.Total)%"></div>
                                    </div>
                                    <span class="bar-value">@item.Total</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </section>

        </div>

    </article>


    @* ================================================================ *@
    @* ============ DASHBOARD: ADMINISTRADOR ========================== *@
    @* ================================================================ *@
    <article class="dash-block admin-only">

        <header class="dash-block-head">
            <h2 class="dash-block-title">
                <span class="dash-role-pill dash-role-admin">Administración</span>
                Visión integral de la clínica
            </h2>
            <span class="dash-block-sub">@NombreMesActual @Hoy.Year · datos consolidados</span>
        </header>

        @* ----- KPIs del Admin ----- *@
        @* Datos: count(Cita) mes, sum(Atencion.montoReferencial - descuentoAplicado),
                 count(Veterinario activo), count(Cliente activo), count(Mascota activa) *@
        <div class="kpi-grid">

            <article class="kpi-card kpi-blue-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Citas del mes</div>
                    <div class="kpi-value">@CitasAdminMes.Count</div>
                    <div class="kpi-sub">@ResumenCitasAdminMes</div>
                </div>
            </article>

            <article class="kpi-card kpi-green-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <line x1="12" y1="1" x2="12" y2="23" stroke-linecap="round" />
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke-linecap="round" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Ingresos del mes</div>
                    <div class="kpi-value">@FormatoMoneda(IngresosAdminMes)</div>
                    <div class="kpi-sub">Neto de descuentos aplicados</div>
                </div>
            </article>

            <article class="kpi-card kpi-violet-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke-linecap="round" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Veterinarios</div>
                    <div class="kpi-value">@VeterinariosActivosAdmin</div>
                    <div class="kpi-sub">Activos en plantilla</div>
                </div>
            </article>

            <article class="kpi-card kpi-amber-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M3 7v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-6l-2-3H5a2 2 0 0 0-2 2z" stroke-linejoin="round" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Clientes activos</div>
                    <div class="kpi-value">@ClientesActivosAdmin</div>
                    <div class="kpi-sub">@MascotasActivasAdmin mascotas activas</div>
                </div>
            </article>

        </div>

        @* ----- Fila 2: Top servicios + Top veterinarios ----- *@
        <div class="dash-two-col">

            @* Datos: count(Cita) GROUP BY Servicio ORDER BY count DESC LIMIT 5 *@
            <section class="panel">
                <header class="panel-head">
                    <h3 class="panel-title">Top servicios</h3>
                    <span class="panel-sub">Más demandados este mes</span>
                </header>
                <div class="panel-body">
                    <div class="bar-list">
                        @if (cargandoAdminDashboard)
                        {
                            <p class="estado-mensaje">Calculando servicios demandados...</p>
                        }
                        else if (!TopServiciosAdmin.Any())
                        {
                            <p class="estado-mensaje">Aun no hay servicios con atenciones este mes.</p>
                        }
                        else
                        {
                            @foreach (var item in TopServiciosAdmin)
                            {
                                <div class="bar-row">
                                    <span class="bar-label">@ServicioAdminLabel(item)</span>
                                    <div class="bar-track">
                                        <div class="bar-fill bar-green" style="width: @PorcentajeServicioAdmin(item.TotalAtenciones)%"></div>
                                    </div>
                                    <span class="bar-value">@item.TotalAtenciones</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </section>

            @* Datos: count(Atencion) GROUP BY veterinario ORDER BY count DESC *@
            <section class="panel">
                <header class="panel-head">
                    <h3 class="panel-title">Top veterinarios</h3>
                    <span class="panel-sub">Por atenciones realizadas</span>
                </header>
                <div class="panel-body">
                    <div class="top-list">
                        @if (cargandoAdminDashboard)
                        {
                            <p class="estado-mensaje">Calculando ranking de veterinarios...</p>
                        }
                        else if (!TopVeterinariosAdmin.Any())
                        {
                            <p class="estado-mensaje">Aun no hay atenciones registradas este mes.</p>
                        }
                        else
                        {
                            @foreach (var item in TopVeterinariosAdmin.Select((value, index) => new { value, index }))
                            {
                                <div class="top-item">
                                    <span class="top-rank">@(item.index + 1)</span>
                                    <div class="top-info">
                                        <span class="top-name">@NombreVeterinario(item.value.Veterinario)</span>
                                        <span class="top-meta">@MetaVeterinario(item.value.Veterinario)</span>
                                    </div>
                                    <div class="top-stat">
                                        <span class="top-value">@item.value.TotalAtenciones</span>
                                        <span class="top-label">atenciones</span>
                                    </div>
                                </div>
                            }
                        }

                    </div>
                </div>
            </section>

        </div>

    </article>


    @* ================================================================ *@
    @* === Fallback: si NO hay ningún rol activo ====================== *@
    @* ================================================================ *@
    @if (!tieneRolActivo)
    {
        <div class="dash-empty">
            <div class="dash-empty-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" stroke-linecap="round" />
                    <line x1="12" y1="16" x2="12.01" y2="16" stroke-linecap="round" />
                </svg>
            </div>
            <h2 class="dash-empty-title">No tienes roles activos para este tablero</h2>
            <p class="dash-empty-text">El tablero y el menu se construyen con los roles asignados a tu usuario. Solicita a un administrador que revise tus permisos si necesitas acceso.</p>
        </div>
    }

</div>

@code {
    private readonly CultureInfo culturaEs = new("es-PE");
    private DateTime Hoy = DateTime.Today;
    private int usuarioActualId;
    private string NombreUsuarioCorto = "usuario";
    private bool cargandoDashboard;
    private List<Cita> CitasVetHoy = new();
    private List<Cita> CitasVetSemana = new();
    private List<ServicioAtencionResumen> TopServiciosVet = new();
    private int AtencionesVetMes;
    private bool cargandoRecepcionDashboard;
    private List<Cita> CitasRecepHoy = new();
    private List<Cita> CitasRecepPendientes = new();
    private List<CargaVeterinarioResumen> CargaVeterinariosRecep = new();
    private int RecordatoriosPendientes;
    private bool cargandoAdminDashboard;
    private List<Cita> CitasAdminMes = new();
    private List<ServicioAtencionResumen> TopServiciosAdmin = new();
    private List<VeterinarioAtencionResumen> TopVeterinariosAdmin = new();
    private double IngresosAdminMes;
    private int VeterinariosActivosAdmin;
    private int ClientesActivosAdmin;
    private int MascotasActivasAdmin;
    private bool tieneRolActivo;

    private DateTime SemanaInicio => InicioSemana(Hoy);
    private DateTime SemanaFin => SemanaInicio.AddDays(6);
    private DateTime MesInicio => new(Hoy.Year, Hoy.Month, 1);
    private DateTime MesFin => MesInicio.AddMonths(1).AddDays(-1);
    private List<Cita> CitasVetHoyActivas => CitasVetHoy.Where(EsCitaActiva).ToList();
    private List<Cita> CitasVetSemanaActivas => CitasVetSemana.Where(EsCitaActiva).ToList();
    private List<Cita> CitasRecepHoyActivas => CitasRecepHoy.Where(EsCitaActiva).ToList();
    private int PendientesVetHoy => CitasVetHoyActivas.Count(c => c.Estado == EstadoCita.PENDIENTE || c.Estado == EstadoCita.CONFIRMADA);
    private int SinConfirmarRecepHoy => CitasRecepHoy.Count(c => c.Estado == EstadoCita.PENDIENTE);
    private int CancelacionesRecepHoy => CitasRecepHoy.Count(c => c.Estado == EstadoCita.CANCELADA);
    private string NombreMesActual => culturaEs.TextInfo.ToTitleCase(Hoy.ToString("MMMM", culturaEs));
    private string FechaHoyTexto => culturaEs.TextInfo.ToTitleCase(Hoy.ToString("dddd d 'de' MMMM 'de' yyyy", culturaEs));
    private string RangoSemanaTexto => $"{SemanaInicio:dd/MM/yyyy} - {SemanaFin:dd/MM/yyyy}";
    private string ResumenCitasAdminMes
    {
        get
        {
            if (!CitasAdminMes.Any())
            {
                return "Sin citas registradas este mes";
            }

            var atendidas = CitasAdminMes.Count(c => c.Estado == EstadoCita.ATENDIDA);
            var noConcretadas = CitasAdminMes.Count(c => c.Estado == EstadoCita.CANCELADA || c.Estado == EstadoCita.NO_ASISTIO);
            return $"{atendidas} atendidas · {noConcretadas} no concretadas";
        }
    }

    private string ResumenRecepcionHoy
    {
        get
        {
            if (!CitasRecepHoyActivas.Any())
            {
                return "Sin citas activas hoy";
            }

            var vets = CitasRecepHoyActivas.Where(c => c.Veterinario?.Id > 0).Select(c => c.Veterinario.Id).Distinct().Count();
            var servicios = CitasRecepHoyActivas.Where(c => c.Servicio?.Id > 0).Select(c => c.Servicio.Id).Distinct().Count();
            return $"{vets} vets · {servicios} servicios";
        }
    }

    private string ResumenCitasHoy
    {
        get
        {
            if (!CitasVetHoyActivas.Any())
            {
                return "Sin citas activas hoy";
            }

            var enConsulta = CitasVetHoyActivas.Count(c => c.Estado == EstadoCita.EN_CONSULTA);
            var confirmadas = CitasVetHoyActivas.Count(c => c.Estado == EstadoCita.CONFIRMADA);
            var pendientes = CitasVetHoyActivas.Count(c => c.Estado == EstadoCita.PENDIENTE);
            return $"{enConsulta} en consulta - {confirmadas} confirmadas - {pendientes} pendientes";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        NombreUsuarioCorto = ObtenerNombreCorto(user);
        usuarioActualId = ObtenerUsuarioId(user);
        tieneRolActivo = user.IsInRole("VETERINARIO")
            || user.IsInRole("RECEPCIONISTA")
            || user.IsInRole("ADMINISTRADOR");

        if (user.IsInRole("VETERINARIO") && usuarioActualId > 0)
        {
            await CargarDashboardVeterinarioAsync();
        }

        if (user.IsInRole("RECEPCIONISTA"))
        {
            await CargarDashboardRecepcionAsync();
        }

        if (user.IsInRole("ADMINISTRADOR"))
        {
            await CargarDashboardAdminAsync();
        }
    }

    private async Task CargarDashboardVeterinarioAsync()
    {
        cargandoDashboard = true;

        try
        {
            await Task.Yield();
            CitasVetHoy = CitaService.ListarFiltradas(usuarioActualId, Hoy, Hoy, "", "")
                .Where(c => c.Veterinario?.Id == usuarioActualId)
                .ToList();

            CitasVetSemana = CitaService.ListarFiltradas(usuarioActualId, SemanaInicio, SemanaFin, "", "")
                .Where(c => c.Veterinario?.Id == usuarioActualId)
                .ToList();

            AtencionesVetMes = AtencionService.ContarPorVeterinarioEnMes(usuarioActualId, Hoy.Year, Hoy.Month);
            TopServiciosVet = AtencionService.TopServiciosPorVeterinario(usuarioActualId, Hoy.Year, Hoy.Month, 5);
        }
        catch
        {
            CitasVetHoy = new();
            CitasVetSemana = new();
            TopServiciosVet = new();
            AtencionesVetMes = 0;
        }
        finally
        {
            cargandoDashboard = false;
        }
    }

    private static int ObtenerUsuarioId(ClaimsPrincipal user)
    {
        var valor = user.FindFirst("IdUsuario")?.Value
            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        return int.TryParse(valor, out var id) ? id : 0;
    }

    private static string ObtenerNombreCorto(ClaimsPrincipal user)
    {
        var nombre = user.Identity?.Name ?? user.FindFirst("Username")?.Value ?? "usuario";
        var primerNombre = nombre.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
        return string.IsNullOrWhiteSpace(primerNombre) ? "usuario" : primerNombre;
    }

    private static DateTime InicioSemana(DateTime fecha)
    {
        int diff = (7 + (int)fecha.DayOfWeek - (int)DayOfWeek.Monday) % 7;
        return fecha.Date.AddDays(-diff);
    }

    private static string NombreMascota(Cita cita)
    {
        var mascota = cita.Mascota;
        if (mascota is null)
        {
            return "Mascota sin nombre";
        }

        return string.IsNullOrWhiteSpace(mascota.Nombre)
            ? "Mascota sin nombre"
            : mascota.Nombre;
    }

    private static string NombreCliente(Cita cita)
    {
        var cliente = cita.Mascota?.Cliente;
        if (cliente is null)
        {
            return "Cliente sin datos";
        }

        var nombre = $"{cliente.Nombres} {cliente.Apellidos}".Trim();
        return string.IsNullOrWhiteSpace(nombre) ? "Cliente sin datos" : nombre;
    }

    private static string NombreVeterinario(Cita cita)
    {
        if (cita.Veterinario is null)
        {
            return "Sin veterinario";
        }

        var nombre = $"{cita.Veterinario.Nombres} {cita.Veterinario.Apellidos}".Trim();
        return string.IsNullOrWhiteSpace(nombre) ? "Sin veterinario" : nombre;
    }

    private static string ServicioNombre(Cita cita)
        => string.IsNullOrWhiteSpace(cita.Servicio?.Nombre) ? "Servicio sin nombre" : cita.Servicio.Nombre;

    private static string EspecieMascota(Cita cita)
    {
        var mascota = cita.Mascota;
        var especie = mascota?.Especie switch
        {
            TipoEspecie.PERRO => "Perro",
            TipoEspecie.GATO => "Gato",
            _ => "Especie sin registrar"
        };

        var raza = mascota?.Raza?.Trim();
        return string.IsNullOrWhiteSpace(raza)
            ? especie
            : $"{especie} · {raza}";
    }

    private string FechaCortaRecepcion(DateTime fecha)
        => fecha.Date == Hoy.Date ? "Hoy" : culturaEs.TextInfo.ToTitleCase(fecha.ToString("ddd dd/MM", culturaEs));

    private static int DuracionCita(Cita cita)
        => Math.Max(0, (int)Math.Round((cita.FechaHoraFin - cita.FechaHoraInicio).TotalMinutes));

    private static bool EsCitaActiva(Cita cita)
        => cita.Estado == EstadoCita.PENDIENTE
        || cita.Estado == EstadoCita.CONFIRMADA
        || cita.Estado == EstadoCita.EN_CONSULTA;

    private static string BadgeEstado(EstadoCita estado) => estado switch
    {
        EstadoCita.PENDIENTE => "badge-pending",
        EstadoCita.CONFIRMADA => "badge-confirmada",
        EstadoCita.EN_CONSULTA => "badge-enconsulta",
        EstadoCita.ATENDIDA => "badge-atendida",
        _ => "badge-cancelled"
    };

    private static string EstadoLabel(EstadoCita estado) => estado switch
    {
        EstadoCita.PENDIENTE => "Pendiente",
        EstadoCita.CONFIRMADA => "Confirmada",
        EstadoCita.EN_CONSULTA => "En consulta",
        EstadoCita.ATENDIDA => "Atendida",
        EstadoCita.CANCELADA => "Cancelada",
        EstadoCita.NO_ASISTIO => "No asistio",
        _ => estado.ToString()
    };

    private int PorcentajeServicio(int total)
    {
        var maximo = TopServiciosVet.Count == 0 ? 0 : TopServiciosVet.Max(s => s.TotalAtenciones);
        if (maximo <= 0)
        {
            return 0;
        }

        return Math.Clamp((int)Math.Round(total * 100.0 / maximo), 8, 100);
    }

    private async Task CargarDashboardRecepcionAsync()
    {
        cargandoRecepcionDashboard = true;

        try
        {
            await Task.Yield();
            CitasRecepHoy = CitaService.ListarFiltradas(0, Hoy, Hoy, "", "")
                .Where(c => c.FechaHoraInicio.Date == Hoy.Date)
                .OrderBy(c => c.FechaHoraInicio)
                .ToList();

            CitasRecepPendientes = CitasRecepHoy
                .Where(c => c.Estado == EstadoCita.PENDIENTE)
                .OrderBy(c => c.FechaHoraInicio)
                .ToList();

            CargaVeterinariosRecep = CitasRecepHoyActivas
                .Where(c => c.Veterinario?.Id > 0)
                .GroupBy(c => c.Veterinario.Id)
                .Select(g =>
                {
                    var vet = g.First().Veterinario;
                    return new CargaVeterinarioResumen(
                        Nombre: $"{vet.Nombres} {vet.Apellidos}".Trim(),
                        Especialidad: vet.Especialidad ?? "",
                        Total: g.Count());
                })
                .OrderByDescending(v => v.Total)
                .ThenBy(v => v.Nombre)
                .ToList();

            RecordatoriosPendientes = RecordatorioService.ContarPendientes();
        }
        catch
        {
            CitasRecepHoy = new();
            CitasRecepPendientes = new();
            CargaVeterinariosRecep = new();
            RecordatoriosPendientes = 0;
        }
        finally
        {
            cargandoRecepcionDashboard = false;
        }
    }

    private int PorcentajeCargaRecepcion(int total)
    {
        var maximo = CargaVeterinariosRecep.Count == 0 ? 0 : CargaVeterinariosRecep.Max(v => v.Total);
        if (maximo <= 0)
        {
            return 0;
        }

        return Math.Clamp((int)Math.Round(total * 100.0 / maximo), 8, 100);
    }

    private static string CargaVeterinarioLabel(CargaVeterinarioResumen item)
        => string.IsNullOrWhiteSpace(item.Especialidad)
            ? item.Nombre
            : $"{item.Nombre} · {item.Especialidad}";

    private async Task CargarDashboardAdminAsync()
    {
        cargandoAdminDashboard = true;

        try
        {
            await Task.Yield();
            CitasAdminMes = CitaService.ListarFiltradas(0, MesInicio, MesFin, "", "")
                .Where(c => c.FechaHoraInicio.Date >= MesInicio.Date && c.FechaHoraInicio.Date <= MesFin.Date)
                .ToList();

            IngresosAdminMes = AtencionService.SumarMontosNetosPorMes(Hoy.Year, Hoy.Month);
            VeterinariosActivosAdmin = VeterinarioService.ListarTodos().Count(v => v.Activo);
            ClientesActivosAdmin = ClienteService.ContarActivos();
            MascotasActivasAdmin = MascotaService.ContarActivas();
            TopServiciosAdmin = ServicioService.TopNMasDemandados(MesInicio, MesFin, 5);
            TopVeterinariosAdmin = AtencionService.TopVeterinariosPorAtenciones(Hoy.Year, Hoy.Month, 5);
        }
        catch
        {
            CitasAdminMes = new();
            TopServiciosAdmin = new();
            TopVeterinariosAdmin = new();
            IngresosAdminMes = 0;
            VeterinariosActivosAdmin = 0;
            ClientesActivosAdmin = 0;
            MascotasActivasAdmin = 0;
        }
        finally
        {
            cargandoAdminDashboard = false;
        }
    }

    private string FormatoMoneda(double monto)
        => monto.ToString("C0", culturaEs);

    private string ServicioAdminLabel(ServicioAtencionResumen item)
    {
        var servicio = item.Servicio;
        if (servicio is null)
        {
            return "Servicio sin nombre";
        }

        var nombre = string.IsNullOrWhiteSpace(servicio.Nombre) ? "Servicio sin nombre" : servicio.Nombre;
        return $"{nombre} · {FormatoMoneda(servicio.Precio)}";
    }

    private int PorcentajeServicioAdmin(int total)
    {
        var maximo = TopServiciosAdmin.Count == 0 ? 0 : TopServiciosAdmin.Max(s => s.TotalAtenciones);
        if (maximo <= 0)
        {
            return 0;
        }

        return Math.Clamp((int)Math.Round(total * 100.0 / maximo), 8, 100);
    }

    private static string NombreVeterinario(VetCitasWA.Servicios.Modelo.Usuario.Veterinario? vet)
    {
        if (vet is null)
        {
            return "Veterinario sin datos";
        }

        var nombre = $"{vet.Nombres} {vet.Apellidos}".Trim();
        return string.IsNullOrWhiteSpace(nombre) ? "Veterinario sin datos" : nombre;
    }

    private static string MetaVeterinario(VetCitasWA.Servicios.Modelo.Usuario.Veterinario? vet)
    {
        if (vet is null)
        {
            return "Veterinario sin datos";
        }

        var cmp = string.IsNullOrWhiteSpace(vet.Cmp) ? "CMPV sin registrar" : vet.Cmp;
        return string.IsNullOrWhiteSpace(vet.Especialidad)
            ? cmp
            : $"{vet.Especialidad} · {cmp}";
    }

