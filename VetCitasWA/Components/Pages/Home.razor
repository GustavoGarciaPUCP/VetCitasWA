                        </div>
                    </div>

                    <div class="ag-item">
                        <div class="ag-time">10:30</div>
                        <div class="ag-info">
                            <div class="ag-info-head">
                                <span class="ag-pet">Max · Perro</span>
                                <span class="badge badge-confirmada">Confirmada</span>
                            </div>
                            <span class="ag-info-sub">Juan Pérez · Consulta General · 30 min</span>
                        </div>
                    </div>

                    <div class="ag-item ag-item-break">
                        <div class="ag-time">13:00</div>
                        <div class="ag-info">
                            <div class="ag-break-title">Refrigerio</div>
                            <span class="ag-info-sub">13:00 — 14:00</span>
                        </div>
                    </div>

                    <div class="ag-item">
                        <div class="ag-time">14:30</div>
                        <div class="ag-info">
                            <div class="ag-info-head">
                                <span class="ag-pet">Rocky · Perro</span>
                                <span class="badge badge-confirmada">Confirmada</span>
                            </div>
                            <span class="ag-info-sub">Carlos López · Cirugía Menor · 60 min</span>
                        </div>
                    </div>

                </div>
            </section>

            @* Datos: count by Cita.servicio.nombre WHERE veterinario = me AND estado = ATENDIDA *@
            <section class="panel">
                <header class="panel-head">
                    <h3 class="panel-title">Servicios que más realizo</h3>
                    <span class="panel-sub">Este mes</span>
                </header>
                <div class="panel-body">
                    <div class="bar-list">
                        <div class="bar-row">
                            <span class="bar-label">Consulta General</span>
                            <div class="bar-track"><div class="bar-fill bar-blue" style="width: 92%"></div></div>
                            <span class="bar-value">28</span>
                        </div>
                        <div class="bar-row">
                            <span class="bar-label">Vacunación</span>
                            <div class="bar-track"><div class="bar-fill bar-blue" style="width: 68%"></div></div>
                            <span class="bar-value">21</span>
                        </div>
                        <div class="bar-row">
                            <span class="bar-label">Control Post-Operatorio</span>
                            <div class="bar-track"><div class="bar-fill bar-blue" style="width: 44%"></div></div>
                            <span class="bar-value">14</span>
                        </div>
                        <div class="bar-row">
                            <span class="bar-label">Esterilización</span>
                            <div class="bar-track"><div class="bar-fill bar-blue" style="width: 23%"></div></div>
                            <span class="bar-value">7</span>
