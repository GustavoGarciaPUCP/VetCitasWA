@page "/"

<PageTitle>Inicio - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Inicio</span>
</SectionContent>

@*
    Dashboard role-aware:
    - Cada bloque marcado con .vet-only / .recep-only / .admin-only se
      muestra solo si el rol correspondiente esta activo (clases
      :root.role-X-active definidas en App.razor).
    - Los KPI y widgets reflejan campos del modelo Java
      (Cita, Atencion, Cliente, Mascota, Servicio, Veterinario,
       Recordatorio, EstadoCita) — ver comentarios al lado.
*@

<div class="dashboard">

    @* ================================================================ *@
    @* ============ DASHBOARD: VETERINARIO ============================ *@
    @* ================================================================ *@
    <article class="dash-block vet-only">

        <header class="dash-block-head">
            <h2 class="dash-block-title">
                <span class="dash-role-pill dash-role-vet">Veterinario</span>
                Hola, Dr. Carlos — esto es lo tuyo de hoy
            </h2>
            <span class="dash-block-sub">Lunes 12 de Mayo de 2026</span>
        </header>

        @* ----- KPIs del Veterinario ----- *@
        @* Datos: Cita.estado, Cita.fechaHoraInicio, Cita.veterinario,
                 Atencion.fechaHora, Atencion.montoReferencial,
                 Atencion.descuentoAplicado, Atencion.recomendacionControl *@
        <div class="kpi-grid">

            <article class="kpi-card kpi-blue-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Mis citas hoy</div>
                    <div class="kpi-value">6</div>
                    <div class="kpi-sub">2 atendidas · 1 en consulta · 3 confirmadas</div>
                </div>
            </article>

            <article class="kpi-card kpi-violet-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" />
                        <path d="m9 12 2 2 4-4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Atenciones del mes</div>
                    <div class="kpi-value">73</div>
                    <div class="kpi-sub">+12 vs. mes anterior</div>
                </div>
            </article>

            <article class="kpi-card kpi-green-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 2v6m0 14v-6M2 12h6m14 0h-6" stroke-linecap="round" />
                        <circle cx="12" cy="12" r="3" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Próximos controles</div>
                    <div class="kpi-value">9</div>
                    <div class="kpi-sub">Programados en los próximos 7 días</div>
                </div>
            </article>

            <article class="kpi-card kpi-amber-soft">
                <div class="kpi-icon-circle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke-linecap="round" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </div>
                <div class="kpi-text">
                    <div class="kpi-title">Mascotas únicas</div>
                    <div class="kpi-value">128</div>
                    <div class="kpi-sub">Atendidas este año</div>
                </div>
            </article>

        </div>

        @* ----- Fila 2: Mi Agenda + Servicios que más realizo ----- *@
        <div class="dash-two-col">

            @* === Agenda del día === *@
            <section class="panel">
                <header class="panel-head">
                    <h3 class="panel-title">Mi agenda del día</h3>
