@page "/servicios/crear"
@page "/servicios/editar"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "ADMINISTRADOR")]
@using System.Security.Claims
@using VetCitasWA.Servicios.Modelo.Servicio
@using VetCitasWA.Servicios.Modelo.Common.Enums
@using VetCitasWA.Servicios.Modelo.Usuario
@inject VetCitasWA.Servicios.REST.ServicioRS.ServicioRestService ServicioService
@inject VetCitasWA.Servicios.UI.ToastService Toasts
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Servicio - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <a class="crumb crumb-link" href="/servicios">Servicios</a>
    <span class="crumb-sep">›</span>
    <span class="crumb current">@(EsEdicion ? "Editar" : "Crear")</span>
</SectionContent>

<div class="page-section">

    @* Cabecera con back link *@
    <div class="form-head">
        <a href="/servicios" class="back-link">
            <span class="back-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                </svg>
            </span>
            Volver al catálogo
        </a>
        <h1 class="page-title">@(EsEdicion ? "Editar servicio" : "Nuevo servicio")</h1>
        <p class="page-subtitle">
            Solo administradores pueden gestionar el catálogo (permiso: USUARIO_GESTIONAR).
        </p>
    </div>

    @if (cargando)
    {
        <section class="form-card"><p class="estado-mensaje">Cargando...</p></section>
    }
    else
    {
        <EditForm Model="modelo" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <section class="form-card">

                @* === Datos básicos === *@
                <fieldset class="form-section">
                    <legend class="form-legend">Datos del servicio</legend>

                    <div class="form-row">
                        <div class="form-field form-field-wide">
                            <label class="form-label" for="sv-nombre">Nombre <span class="req">*</span></label>
                            <input id="sv-nombre" type="text" class="form-input" placeholder="Ej. Consulta general"
                                   @bind="modelo.Nombre" required maxlength="100" />
                            <span class="form-hint">Nombre visible en el catálogo. Máximo 100 caracteres.</span>
                        </div>
                        <div class="form-field">
                            <label class="form-label" for="sv-tipo">Tipo <span class="req">*</span></label>
                            <div class="form-select-wrap">
                                <VcSelect TValue="TipoServicio" @bind-Value="modelo.Tipo" Options="TipoOptions" />
                            </div>
                            <span class="form-hint">Clínica: requiere atención veterinaria.</span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-field">
                            <label class="form-label" for="sv-duracion">Duración (minutos) <span class="req">*</span></label>
                            <input id="sv-duracion" type="number" class="form-input" placeholder="30"
                                   @bind="modelo.DuracionMinutos" required min="1" max="600" />
                            <span class="form-hint">Tiempo estimado por sesión.</span>
                        </div>
                        <div class="form-field">
                            <label class="form-label" for="sv-precio">Precio referencial (S/) <span class="req">*</span></label>
                            <div class="form-input-prefix">
                                <span class="prefix-symbol">S/</span>
                                <input id="sv-precio" type="number" class="form-input form-input-with-prefix" placeholder="0.00"
                                       @bind="modelo.Precio" required min="0" step="0.01" />
                            </div>
                            <span class="form-hint">Puede ajustarse al cobrar la atención.</span>
                        </div>
                    </div>

                    <div class="form-field">
                        <label class="form-label" for="sv-descripcion">Descripción</label>
                        <textarea id="sv-descripcion" class="form-textarea" rows="3"
                                  placeholder="Describe en qué consiste el servicio (opcional)..."
                                  maxlength="255" @bind="modelo.Descripcion"></textarea>
                        <span class="form-hint">Máximo 255 caracteres. Aparece como detalle del servicio.</span>
                    </div>

                </fieldset>

                @if (errorMensaje is not null)
                {
                    <p class="estado-mensaje estado-error">@errorMensaje</p>
                }

                @* === Acciones === *@
                <footer class="form-actions">
                    <a href="/servicios" class="vc-btn vc-btn-secondary">Cancelar</a>
                    <button type="submit" class="vc-btn vc-btn-primary" disabled="@procesando">
                        @if (procesando)
                        {
                            <span class="vc-spinner" aria-hidden="true"></span>
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <span>@(EsEdicion ? "Guardar cambios" : "Crear servicio")</span>
                        }
                    </button>
                </footer>
            </section>
        </EditForm>
    }

</div>

@code {
    // El id llega por query string: /servicios/editar?id=5
    [SupplyParameterFromQuery(Name = "id")]
    public int Id { get; set; }

    private Servicio modelo = new() { Tipo = TipoServicio.CLINICA, DuracionMinutos = 30, Activo = true };

    // Opciones del tipo de servicio (VcSelect)
    private static readonly IEnumerable<VcSelectOption<TipoServicio>> TipoOptions = new[]
    {
        new VcSelectOption<TipoServicio>(TipoServicio.CLINICA, "Clínica"),
        new VcSelectOption<TipoServicio>(TipoServicio.NO_CLINICA, "No clínica"),
    };
    private bool EsEdicion => Id > 0;
    private bool cargando = true;
    private bool procesando = false;
    private int usuarioActualId;
    private string? errorMensaje;

    protected override async Task OnInitializedAsync()
    {
        usuarioActualId = await ObtenerUsuarioActualId();
        if (EsEdicion)
        {
            try
            {
                var existente = await Task.Run(() => ServicioService.BuscarPorId(Id));
                if (existente is not null)
                {
                    modelo = existente;
                }
                else
                {
                    errorMensaje = "No se encontró el servicio solicitado.";
                }
            }
            catch (Exception ex)
            {
                errorMensaje = "No se pudo cargar el servicio. Inténtalo nuevamente.";
            }
        }
        cargando = false;
    }

    private async Task<int> ObtenerUsuarioActualId()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var raw = authState.User.FindFirst("IdUsuario")?.Value
            ?? authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
            ?? authState.User.FindFirst("nameid")?.Value;
        return int.TryParse(raw, out var id) ? id : 0;
    }

    // Valida y normaliza el servicio. Devuelve el mensaje de error o null si todo es correcto.
    private string? ValidarServicio()
    {
        var nombre = (modelo.Nombre ?? "").Trim();
        var desc = (modelo.Descripcion ?? "").Trim();

        if (string.IsNullOrWhiteSpace(nombre)) return "Ingresa el nombre del servicio.";
        if (nombre.Length < 2 || nombre.Length > 100) return "El nombre debe tener entre 2 y 100 caracteres.";

        if (modelo.DuracionMinutos <= 0) return "La duración debe ser mayor que 0 minutos.";
        if (modelo.DuracionMinutos > 600) return "La duración no puede superar los 600 minutos.";

        if (modelo.Precio < 0) return "El precio referencial no puede ser negativo.";

        if (desc.Length > 255) return "La descripción no puede superar los 255 caracteres.";

        // Normaliza los valores ya validados
        modelo.Nombre = nombre;
        modelo.Descripcion = desc;
        return null;
    }

    private async Task Guardar()
    {
        // Guarda anti-reentrada: impide guardar dos veces seguidas
        if (procesando) return;

        var error = ValidarServicio();
        if (error is not null)
        {
            errorMensaje = error;
            return;
        }
        if (usuarioActualId <= 0)
        {
            errorMensaje = "No se pudo identificar al usuario autenticado. Vuelve a iniciar sesion.";
            return;
        }

        procesando = true;
        errorMensaje = null;
        try
        {
            modelo.ModifiedBy = new Usuario { Id = usuarioActualId };
            if (EsEdicion)
            {
                await Task.Run(() => ServicioService.Modificar(modelo));
                Toasts.Exito($"Servicio \"{modelo.Nombre}\" actualizado correctamente.");
            }
            else
            {
                await Task.Run(() => ServicioService.Insertar(modelo));
                Toasts.Exito($"Servicio \"{modelo.Nombre}\" guardado correctamente.");
            }
            Nav.NavigateTo("/servicios");
        }
        catch (Exception ex)
        {
            errorMensaje = "No se pudo guardar el servicio. Inténtalo nuevamente.";
            Toasts.Error("No se pudo guardar el servicio. Inténtalo nuevamente.");
            procesando = false;
        }
    }
}
