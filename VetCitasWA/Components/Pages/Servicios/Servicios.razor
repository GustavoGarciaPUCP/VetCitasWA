@page "/servicios"
@using VetCitasWA.Servicios.Modelo.Servicio
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.ServicioRS.ServicioRestService ServicioService

<PageTitle>Servicios - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Servicios</span>
</SectionContent>

<div class="page-section">

    @* Cabecera: título + botón "Nuevo Servicio" (admin-only) *@
    <div class="page-head">
        <h1 class="page-title">Catálogo de Servicios</h1>
        <a href="/servicios/crear" class="btn-new admin-only">
            <span class="btn-plus" aria-hidden="true">+</span>
            <span>Nuevo Servicio</span>
        </a>
    </div>

    <section class="panel">
        <div class="table-wrapper">
            <table class="vet-table">
                <thead>
                    <tr>
                        <th>Servicio</th>
                        <th>Tipo</th>
                        <th>Duración (min)</th>
                        <th>Precio (S/)</th>
                        <th>Estado</th>
                        <th class="admin-only">Acciones</th>
                    </tr>
                </thead>
                <tbody>

                    @if (listaServicios == null || !listaServicios.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center" style="padding: 2rem;">
                                <em>Cargando datos desde el servidor o no se encontraron resultados...</em>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var servicio in listaServicios)
                        {
                            <tr>
                                <td data-label="Servicio">@servicio.Nombre</td>
                                <td data-label="Tipo">
                                    @if (servicio.Tipo == TipoServicio.CLINICA)
                                    {
                                        <span class="type-badge type-clinica">Clínica</span>
                                    }
                                    else
                                    {
                                        <span class="type-badge type-noclinica">No Clínica</span>
                                    }
                                </td>
                                <td data-label="Duración (min)">@servicio.DuracionMinutos</td>
                                <td data-label="Precio (S/)">S/ @servicio.Precio.ToString("0.00")</td>
                                <td data-label="Estado">
                                    @if (servicio.Activo)
                                    {
                                        <span class="status-badge status-active">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-inactive">Inactivo</span>
                                    }
                                </td>
                                <td data-label="Acciones" class="admin-only">
                                    <div class="row-actions">
                                        <a href="@($"/servicios/editar?id={servicio.Id}")" class="btn-icon btn-icon-edit" title="Editar" aria-label="Editar">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" /></svg>
                                        </a>
                                        <button type="button" class="btn-icon btn-icon-delete" title="Eliminar" aria-label="Eliminar" @onclick="() => EliminarServicio(servicio.Id)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z" /><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" /></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }

                </tbody>
            </table>
        </div>
    </section>

</div>

@code {
    private List<Servicio> listaServicios = new List<Servicio>();

    protected override void OnInitialized()
    {
        listaServicios = ServicioService.ListarTodos();
    }

    private void EliminarServicio(int id)
    {
        ServicioService.Eliminar(id);
        listaServicios = ServicioService.ListarTodos();
    }
}
