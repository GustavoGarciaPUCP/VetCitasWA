@page "/recordatorios"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "RECEPCIONISTA")]
@using VetCitasWA.Servicios.Modelo.Cita
@using VetCitasWA.Servicios.Modelo.Cliente
@using VetCitasWA.Servicios.Modelo.Usuario
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.CitaRS.RecordatorioRestService RecordatorioService
@inject VetCitasWA.Servicios.REST.ClienteRS.ClienteRestService ClienteService
@inject VetCitasWA.Servicios.REST.UsuarioRS.VeterinarioRestService VeterinarioService
@inject VetCitasWA.Servicios.UI.ToastService Toasts
@implements IDisposable

<PageTitle>Recordatorios - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Recordatorios</span>
</SectionContent>

<div class="page-section">

    <div class="page-head">
        <h1 class="page-title">Recordatorios</h1>
        <p class="page-subtitle">Los recordatorios se generan automáticamente a partir de las citas. Aquí puedes editar el mensaje, enviarlos por WhatsApp o eliminarlos.</p>
    </div>

    @* Filtros *@
    <div class="filter-bar">
        <div class="vc-search">
            <span class="vc-search-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                </svg>
            </span>
            <input type="text" class="vc-search-input" placeholder="Buscar por mascota, cliente o mensaje"
                   value="@textoBusqueda" @oninput="OnBusquedaInput" />
        </div>
        <VcSelect TValue="string" CssClass="vc-cs-filtro" Value="filtroEstado" ValueChanged="OnFiltroEstadoSel" Options="EstadoOptions" />
    </div>

    <section class="panel">
        <div class="table-wrapper">
            @if (cargando)
            {
                <p class="estado-mensaje">Cargando recordatorios…</p>
            }
            else if (errorMensaje is not null)
            {
                <p class="estado-mensaje estado-error">@errorMensaje</p>
            }
            else
            {
                <table class="rem-table">
                    <thead>
                        <tr>
                            <th>Mascota</th>
                            <th>Cliente</th>
                            <th>Mensaje</th>
                            @*<th>Fecha<br />Programada</th>*@
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Filtrados.Any())
                        {
                            <tr><td colspan="6" class="estado-mensaje">No hay recordatorios que mostrar.</td></tr>
                        }
                        else
                        {
                            @foreach (var r in Pagina)
                            {
                                <tr>
                                    <td data-label="Mascota">@(r.Cita?.Mascota?.Nombre ?? "—")</td>
                                    <td data-label="Cliente">@NombreCliente(r)</td>
                                    <td data-label="Mensaje" class="msg-cell">@r.Mensaje</td>
                                    @*<td data-label="Fecha Programada">@r.FechaProgramada.ToString("yyyy-MM-dd HH:mm")</td>*@
                                    <td data-label="Estado">
                                        @if (r.EstadoSeguimiento == EstadoSeguimiento.ENVIADO)
                                        {
                                            <span class="status-badge status-sent">Enviado</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-pending">Pendiente</span>
                                        }
                                    </td>
                                    <td data-label="Acciones">
                                        <div class="actions">
                                            @if (r.EstadoSeguimiento == EstadoSeguimiento.PENDIENTE)
                                            {
                                                <a href="@WaLink(r)" target="_blank" rel="noopener" class="btn-icon btn-whatsapp" title="Enviar por WhatsApp" @onclick="() => MarcarEnviado(r)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232" /></svg>
                                                </a>
                                                <button type="button" class="btn-icon btn-edit" title="Editar mensaje" @onclick="() => AbrirEditar(r)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" /></svg>
                                                </button>
                                            }
                                            else
                                            {
                                                <a href="@WaLink(r)" target="_blank" rel="noopener" class="btn-icon btn-whatsapp" title="Reenviar por WhatsApp">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232" /></svg>
                                                </a>
                                            }
                                            <button type="button" class="btn-icon btn-delete" title="Eliminar" @onclick="() => recordatorioAEliminar = r">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z" /><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" /></svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>

                <Pager CurrentPage="paginaActual" TotalPages="TotalPaginas" CurrentPageChanged="IrAPagina" />
            }
        </div>
    </section>
</div>

@* ===================== MODAL EDITAR MENSAJE ===================== *@
@if (recordatorioEdit is not null)
{
    <div class="vc-modal-backdrop" role="presentation">
        <div class="vc-modal-card vc-modal-card-lg" role="dialog" aria-modal="true">
            <button type="button" class="vc-modal-close" aria-label="Cerrar" @onclick="() => recordatorioEdit = null" disabled="@procesando">×</button>
            <h2 class="vc-modal-title">Editar mensaje</h2>
            <p class="vc-modal-subtitle">@(recordatorioEdit.Cita?.Mascota?.Nombre) · @NombreCliente(recordatorioEdit)</p>
            <div class="vc-form-field">
                <label class="vc-form-label">Mensaje</label>
                <textarea class="vc-form-textarea" rows="4" @bind="mensajeEdit"></textarea>
            </div>
            @if (errorEdit is not null)
            {
                <p class="vc-form-error">@errorEdit</p>
            }
            <div class="vc-modal-actions" style="justify-content:flex-end;">
                <button class="vc-btn vc-btn-secondary" @onclick="() => recordatorioEdit = null" disabled="@procesando">Cancelar</button>
                <button class="vc-btn vc-btn-primary" @onclick="GuardarMensaje" disabled="@procesando">
                    @if (procesando) { <span class="vc-spinner" aria-hidden="true"></span><span>Guardando…</span> }
                    else { <span>Guardar</span> }
                </button>
            </div>
        </div>
    </div>
}

@* ===================== CONFIRMAR ELIMINAR ===================== *@
@if (recordatorioAEliminar is not null)
{
    <div class="vc-modal-backdrop" role="presentation">
        <div class="vc-modal-card" role="dialog" aria-modal="true">
            <button type="button" class="vc-modal-close" aria-label="Cerrar" @onclick="() => recordatorioAEliminar = null">×</button>
            <h3 class="vc-modal-title">¿Eliminar recordatorio?</h3>
            <p class="vc-modal-message">Esta acción no se puede deshacer.</p>
            <div class="vc-modal-actions">
                <button class="vc-btn vc-btn-secondary" @onclick="() => recordatorioAEliminar = null" disabled="@procesando">Cancelar</button>
                <button class="vc-btn vc-btn-danger" @onclick="ConfirmarEliminar" disabled="@procesando">
                    @if (procesando) { <span class="vc-spinner" aria-hidden="true"></span><span>Eliminando…</span> }
                    else { <span>Sí, eliminar</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<Recordatorio> recordatorios = new();
    private Dictionary<int, Cliente> clientesPorId = new();
    private int modBy = 0;
    private bool cargando = true;
    private bool procesando;
    private string? errorMensaje;

    private string textoBusqueda = "";
    private string textoAplicado = "";
    private string filtroEstado = "todos";

    // Paginación (cliente)
    private const int PageSize = 5;
    private int paginaActual = 1;

    private Recordatorio? recordatorioEdit;
    private string mensajeEdit = "";
    private string? errorEdit;
    private Recordatorio? recordatorioAEliminar;

    private CancellationTokenSource? debounceCts;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var clientes = await Task.Run(() => ClienteService.ListarTodos());
            clientesPorId = clientes.ToDictionary(c => c.Id, c => c);
            var vets = await Task.Run(() => VeterinarioService.ListarTodos());
            modBy = vets.FirstOrDefault()?.Id ?? 0;
        }
        catch { }
        await CargarRecordatorios();
    }

    private async Task CargarRecordatorios()
    {
        cargando = true;
        errorMensaje = null;
        try
        {
            recordatorios = await Task.Run(() => RecordatorioService.ListarPorMascotaOCliente(""));
        }
        catch (Exception ex)
        {
            errorMensaje = $"No se pudieron cargar los recordatorios. Inténtalo nuevamente. ({ex.Message})";
            recordatorios = new();
        }
        finally { cargando = false; }
    }

    private IEnumerable<Recordatorio> Filtrados
    {
        get
        {
            IEnumerable<Recordatorio> q = recordatorios;
            if (filtroEstado != "todos")
                q = q.Where(r => r.EstadoSeguimiento.ToString() == filtroEstado);
            if (!string.IsNullOrWhiteSpace(textoAplicado))
            {
                string t = textoAplicado.Trim().ToLowerInvariant();
                q = q.Where(r =>
                    (r.Cita?.Mascota?.Nombre ?? "").ToLowerInvariant().Contains(t) ||
                    NombreCliente(r).ToLowerInvariant().Contains(t) ||
                    (r.Mensaje ?? "").ToLowerInvariant().Contains(t));
            }
            return q;
        }
    }

    // Lista filtrada + ordenada (recientes primero)
    private List<Recordatorio> FiltradosOrdenados => Filtrados.OrderByDescending(x => x.FechaProgramada).ToList();

    private int TotalPaginas => Math.Max(1, (int)Math.Ceiling(FiltradosOrdenados.Count / (double)PageSize));

    // Página actual ya recortada (con clamp por si la página quedó fuera de rango)
    private IEnumerable<Recordatorio> Pagina
    {
        get
        {
            var orden = FiltradosOrdenados;
            if (paginaActual > TotalPaginas) paginaActual = TotalPaginas;
            if (paginaActual < 1) paginaActual = 1;
            return orden.Skip((paginaActual - 1) * PageSize).Take(PageSize);
        }
    }

    private void IrAPagina(int p) => paginaActual = p;
    private void ResetPagina() => paginaActual = 1;

    private static readonly IEnumerable<VcSelectOption<string>> EstadoOptions = new[]
    {
        new VcSelectOption<string>("todos", "Todos los estados"),
        new VcSelectOption<string>("PENDIENTE", "Pendiente"),
        new VcSelectOption<string>("ENVIADO", "Enviado"),
    };

    private void OnFiltroEstadoSel(string value)
    {
        filtroEstado = value;
        ResetPagina();
    }

    private string NombreCliente(Recordatorio r)
    {
        var cl = r.Cita?.Mascota?.Cliente;
        return cl is null ? "—" : $"{cl.Nombres} {cl.Apellidos}".Trim();
    }

    // Código de país por defecto (Perú). Solo se antepone si el número parece local
    // (9 dígitos); si ya trae su propio código se respeta tal cual.
    private const string CodigoPaisDefecto = "51";

    private string TelefonoWa(Recordatorio r)
    {
        int? cid = r.Cita?.Mascota?.Cliente?.Id;
        if (cid is null || !clientesPorId.TryGetValue(cid.Value, out var cl) || string.IsNullOrWhiteSpace(cl.Telefono))
            return "";

        var tel = cl.Telefono.Trim();
        // Si viene con "+" asumimos que ya incluye el código de país internacional
        bool tieneCodigoPais = tel.StartsWith("+");
        string d = new string(tel.Where(char.IsDigit).ToArray());

        // Número local de 9 dígitos sin "+" → anteponemos el código de país por defecto
        if (!tieneCodigoPais && d.Length == 9)
            d = CodigoPaisDefecto + d;

        return d;
    }

    private string WaLink(Recordatorio r)
    {
        var tel = TelefonoWa(r);
        var msg = Uri.EscapeDataString(r.Mensaje ?? "");
        return string.IsNullOrEmpty(tel) ? $"https://wa.me/?text={msg}" : $"https://wa.me/{tel}?text={msg}";
    }

    // ===== Debounce buscador (800 ms) =====
    private async Task OnBusquedaInput(ChangeEventArgs e)
    {
        textoBusqueda = e.Value?.ToString() ?? "";
        debounceCts?.Cancel();
        debounceCts = new CancellationTokenSource();
        var token = debounceCts.Token;
        try
        {
            await Task.Delay(800, token);
            textoAplicado = textoBusqueda;
            paginaActual = 1;
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException) { }
    }

    // ===== Acciones =====
    private async Task MarcarEnviado(Recordatorio r)
    {
        // El enlace de WhatsApp se abre por el href; aquí marcamos el recordatorio como enviado.
        try
        {
            await Task.Run(() => RecordatorioService.MarcarEnviado(r.Id, modBy));
            Toasts.Exito("Recordatorio marcado como enviado.");
            await CargarRecordatorios();
        }
        catch (Exception ex)
        {
            Toasts.Error($"No se pudo marcar como enviado. Inténtalo nuevamente. ({ex.Message})");
        }
    }

    private void AbrirEditar(Recordatorio r)
    {
        recordatorioEdit = r;
        mensajeEdit = r.Mensaje ?? "";
        errorEdit = null;
    }

    private async Task GuardarMensaje()
    {
        if (procesando || recordatorioEdit is null) return;
        if (string.IsNullOrWhiteSpace(mensajeEdit))
        {
            errorEdit = "El mensaje no puede estar vacío.";
            return;
        }
        procesando = true;
        errorEdit = null;
        try
        {
            recordatorioEdit.Mensaje = mensajeEdit.Trim();
            await Task.Run(() => RecordatorioService.Modificar(recordatorioEdit));
            Toasts.Exito("Mensaje actualizado.");
            recordatorioEdit = null;
            await CargarRecordatorios();
        }
        catch (Exception ex)
        {
            errorEdit = $"No se pudo guardar el mensaje. Inténtalo nuevamente. ({ex.Message})";
        }
        finally { procesando = false; }
    }

    private async Task ConfirmarEliminar()
    {
        if (procesando || recordatorioAEliminar is null) return;
        procesando = true;
        try
        {
            int id = recordatorioAEliminar.Id;
            await Task.Run(() => RecordatorioService.Eliminar(id));
            Toasts.Exito("Recordatorio eliminado.");
            recordatorioAEliminar = null;
            await CargarRecordatorios();
        }
        catch (Exception ex)
        {
            Toasts.Error($"No se pudo eliminar el recordatorio. Inténtalo nuevamente. ({ex.Message})");
        }
        finally { procesando = false; }
    }

    public void Dispose() => debounceCts?.Cancel();
}
