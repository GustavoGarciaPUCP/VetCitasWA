@page "/recordatorios"
@using VetCitasWA.Servicios.Modelo.Cita
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.CitaRS.RecordatorioRestService RecordatorioService

<PageTitle>Recordatorios - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Recordatorios</span>
</SectionContent>

<div class="page-section">

    @* ================= Cabecera ================= *@
    <div class="page-head">
        <h1 class="page-title">Recordatorios</h1>
        <p class="page-subtitle">Los recordatorios se generan automáticamente a partir de las citas. Aquí puedes editar el mensaje, enviarlos por WhatsApp o eliminarlos.</p>
    </div>

    @* ================= Tabla ================= *@
    <section class="panel">
        <div class="table-wrapper">
            <table class="rem-table">
                <thead>
                    <tr>
                        <th>Mascota</th>
                        <th>Cliente</th>
                        <th>Mensaje</th>
                        <th>Fecha<br />Programada</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>

                    @if (listaRecordatorios == null || !listaRecordatorios.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center" style="padding: 2rem;">
                                <em>Cargando datos desde el servidor o no se encontraron resultados...</em>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var recordatorio in listaRecordatorios)
                        {
                            var mascota = recordatorio.Cita?.Mascota;
                            var cliente = mascota?.Cliente;
                            var pendiente = recordatorio.EstadoSeguimiento == EstadoSeguimiento.PENDIENTE;

                            <tr>
                                <td data-label="Mascota">@(mascota?.Nombre)</td>
                                <td data-label="Cliente">@(cliente != null ? $"{cliente.Nombres} {cliente.Apellidos}" : "")</td>
                                <td data-label="Mensaje" class="msg-cell">
                                    @recordatorio.Mensaje
                                </td>
                                <td data-label="Fecha Programada">@recordatorio.FechaProgramada.ToString("yyyy-MM-dd")</td>
                                <td data-label="Estado">
                                    @if (pendiente)
                                    {
                                        <span class="status-badge status-pending">Pendiente</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-sent">Enviado</span>
                                    }
                                </td>
                                <td data-label="Acciones">
                                    <div class="actions">
                                        @if (pendiente)
                                        {
                                            <button type="button" class="btn-icon btn-whatsapp" aria-label="Enviar por WhatsApp" title="Enviar por WhatsApp" @onclick="() => EnviarWhatsApp(recordatorio.Id)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232" />
                                                </svg>
                                            </button>
                                            <label for="recordatorio-form-modal" class="btn-icon btn-edit" aria-label="Editar mensaje" title="Editar mensaje">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" />
                                                </svg>
                                            </label>
                                        }
                                        <button type="button" class="btn-icon btn-delete" aria-label="Eliminar recordatorio" title="Eliminar" @onclick="() => EliminarRecordatorio(recordatorio.Id)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z" />
                                                <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                                            </svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }

                </tbody>
            </table>
        </div>
    </section>

</div>

@code {
    private const int UsuarioActualId = 1; // TODO: usuario autenticado

    private List<Recordatorio> listaRecordatorios = new List<Recordatorio>();

    protected override void OnInitialized()
    {
        listaRecordatorios = RecordatorioService.ListarTodos();
    }

    private void EnviarWhatsApp(int id)
    {
        RecordatorioService.MarcarEnviado(id, UsuarioActualId);
        listaRecordatorios = RecordatorioService.ListarTodos();
    }

    private void EliminarRecordatorio(int id)
    {
        RecordatorioService.Eliminar(id);
        listaRecordatorios = RecordatorioService.ListarTodos();
    }
}
