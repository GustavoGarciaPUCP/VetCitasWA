@page "/citas-hoy"
@using VetCitasWA.Servicios.Modelo.Cita
@using VetCitasWA.Servicios.Modelo.Cliente
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.CitaRS.CitaRestService CitaService

<PageTitle>Citas de Hoy - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Citas de Hoy</span>
</SectionContent>

<div class="page-section">

    <div class="page-head">
        <div>
            <h1 class="page-title">Citas de Hoy</h1>
            <p class="page-subtitle">Inicia las atenciones según vayan llegando los pacientes. Al iniciar se cambia el estado de la cita.</p>
        </div>
    </div>

    <section class="panel">

        @* ================= Filtros ================= *@
        <div class="filters">
            <div class="filter-field">
                <label class="filter-label" for="filterEstado">Estado</label>
                <div class="filter-control">
                    <span class="filter-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5" />
                        </svg>
                    </span>
                    <select id="filterEstado" class="filter-select" @onchange="OnEstadoChanged">
                        <option value="">Todos los estados</option>
                        <option value="PENDIENTE">Pendiente</option>
                        <option value="CONFIRMADA">Confirmada</option>
                        <option value="EN_CONSULTA">En consulta</option>
                        <option value="ATENDIDA">Atendida</option>
                        <option value="CANCELADA">Cancelada</option>
                        <option value="NO_ASISTIO">No asistió</option>
                    </select>
                </div>
            </div>

            <div class="filter-field filter-field-fecha">
                <label class="filter-label" for="filterFecha">Fecha</label>
                <div class="filter-control">
                    <span class="filter-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z" />
                        </svg>
                    </span>
                    <select id="filterFecha" class="filter-select">
                        <option>Hoy</option>
                        <option>Ayer</option>
                        <option>Esta semana</option>
                        <option>Este mes</option>
                    </select>
                </div>
            </div>
        </div>

        @* ================= Tabla de citas ================= *@
        <div class="table-wrapper">
            <table class="vet-table">
                <thead>
                    <tr>
                        <th>Hora Cita</th>
                        <th>Paciente</th>
                        <th>Cliente</th>
                        <th>Servicio</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>

                    @if (listaCitas == null || !listaCitas.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center" style="padding: 2rem;">
                                <em>Cargando datos desde el servidor o no se encontraron resultados...</em>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var cita in listaCitas)
                        {
                            <tr class="@(cita.Estado == EstadoCita.CANCELADA ? "row-disabled" : "")">
                                <td data-label="Hora Cita" class="cell-hora">@cita.FechaHoraInicio.ToString("HH:mm")</td>
                                <td data-label="Paciente">
                                    <div class="patient-cell">
                                        <span class="pet-avatar" aria-hidden="true">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 24 24">
                                                <circle cx="11" cy="4" r="2"></circle>
                                                <circle cx="18" cy="8" r="2"></circle>
                                                <circle cx="4" cy="8" r="2"></circle>
                                                <circle cx="20" cy="16" r="2"></circle>
                                                <path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z" />
                                            </svg>
                                        </span>
                                        <div>
                                            <div class="pet-name">@(cita.Mascota?.Nombre)</div>
                                            <div class="pet-meta">@EspecieTexto(cita.Mascota) · @(cita.Servicio?.Nombre)</div>
                                        </div>
                                    </div>
                                </td>
                                <td data-label="Cliente">@(cita.Mascota?.Cliente?.Nombres) @(cita.Mascota?.Cliente?.Apellidos)</td>
                                <td data-label="Servicio">@(cita.Servicio?.Nombre)</td>
                                <td data-label="Estado">
                                    <span class="badge @BadgeEstado(cita.Estado)">@EstadoTexto(cita.Estado)</span>
                                </td>
                                <td data-label="Acciones">
                                    @switch (cita.Estado)
                                    {
                                        case EstadoCita.CONFIRMADA:
                                            <a href="/citas-hoy/atender" class="btn-action btn-start">Iniciar Atención</a>
                                            break;
                                        case EstadoCita.EN_CONSULTA:
                                            <a href="/citas-hoy/atender" class="btn-action btn-continue">Continuar</a>
                                            break;
                                        case EstadoCita.ATENDIDA:
                                            <a href="/citas-hoy/atender" class="btn-action btn-view">Ver Atención</a>
                                            break;
                                        case EstadoCita.PENDIENTE:
                                            <span class="action-hint">Esperando confirmación</span>
                                            break;
                                        default:
                                            <span class="action-hint">—</span>
                                            break;
                                    }
                                </td>
                            </tr>
                        }
                    }

                </tbody>
            </table>
        </div>

        @* ================= Paginación ================= *@
        <nav class="pager" aria-label="Paginación">
            <button type="button" class="pager-btn pager-arrow" aria-label="Anterior">‹</button>
            <button type="button" class="pager-btn pager-active">1</button>
            <button type="button" class="pager-btn">2</button>
            <span class="pager-dots">…</span>
            <button type="button" class="pager-btn pager-arrow" aria-label="Siguiente">›</button>
        </nav>

    </section>

</div>

@code {
    private List<Cita> listaCitas = new();
    private string estadoSeleccionado = "";

    // Filtra las citas del día de hoy. idVet = 0 => todos los veterinarios.
    protected override void OnInitialized()
    {
        Recargar();
    }

    private void Recargar()
    {
        listaCitas = CitaService.ListarFiltradas(0, DateTime.Today, DateTime.Today, estadoSeleccionado, "");
    }

    private void OnEstadoChanged(ChangeEventArgs e)
    {
        estadoSeleccionado = e.Value?.ToString() ?? "";
        Recargar();
    }

    private string EspecieTexto(Mascota? m)
        => m == null ? "" : (m.Especie == TipoEspecie.PERRO ? "Perro" : "Gato");

    private string EstadoTexto(EstadoCita estado) => estado switch
    {
        EstadoCita.PENDIENTE => "Pendiente",
        EstadoCita.CONFIRMADA => "Confirmada",
        EstadoCita.EN_CONSULTA => "En consulta",
        EstadoCita.ATENDIDA => "Atendida",
        EstadoCita.CANCELADA => "Cancelada",
        EstadoCita.NO_ASISTIO => "No asistió",
        _ => ""
    };

    private string BadgeEstado(EstadoCita estado) => estado switch
    {
        EstadoCita.PENDIENTE => "badge-pending",
        EstadoCita.CONFIRMADA => "badge-confirmada",
        EstadoCita.EN_CONSULTA => "badge-enconsulta",
        EstadoCita.ATENDIDA => "badge-atendida",
        EstadoCita.CANCELADA => "badge-cancelled",
        EstadoCita.NO_ASISTIO => "badge-cancelled",
        _ => ""
    };
}