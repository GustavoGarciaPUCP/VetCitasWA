@page "/citas-hoy"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "VETERINARIO")]
@using VetCitasWA.Servicios.Modelo.Cita
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.CitaRS.CitaRestService CitaService
@inject VetCitasWA.Servicios.UI.ToastService Toasts
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Citas de hoy - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Citas de hoy</span>
</SectionContent>

<div class="page-section">

    <div class="page-head">
        <div>
            <h1 class="page-title">Citas de hoy</h1>
            <p class="page-subtitle">Gestiona el avance de las citas: confirmar, iniciar atención, marcar como atendida o cancelar.</p>
        </div>
    </div>

    <section class="panel">

        @* ================= Filtros ================= *@
        <div class="filters">
            <div class="filter-field">
                <label class="filter-label" for="filterEstado">Estado</label>
                <div class="filter-control vc-ms">
                    <span class="filter-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5" />
                        </svg>
                    </span>
                    <button type="button" class="filter-select vc-ms-toggle" @onclick="() => estadoDropdownAbierto = !estadoDropdownAbierto">
                        @EstadosResumen
                    </button>
                    @if (estadoDropdownAbierto)
                    {
                        <div class="vc-ms-overlay" @onclick="() => estadoDropdownAbierto = false"></div>
                        <div class="vc-ms-panel">
                            <label class="vc-ms-item vc-ms-item-all">
                                <input type="checkbox" checked="@TodosEstadosSeleccionados" @onchange="ToggleTodosEstados" />
                                <span>Todos</span>
                            </label>
                            @foreach (var e in EstadosTodos)
                            {
                                <label class="vc-ms-item">
                                    <input type="checkbox" checked="@estadosSel.Contains(e)" @onchange="() => ToggleEstado(e)" />
                                    <span>@EstadoLabel(e)</span>
                                </label>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ================= Tabla de citas ================= *@
        <div class="table-wrapper">
            @if (cargando)
            {
                <p class="estado-mensaje">Cargando citas…</p>
            }
            else if (errorMensaje is not null)
            {
                <p class="estado-mensaje estado-error">@errorMensaje</p>
            }
            else
            {
                <table class="vet-table">
                    <thead>
                        <tr>
                            <th>Hora</th>
                            <th>Mascota</th>
                            <th>Cliente</th>
                            <th>Servicio</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!CitasFiltradas.Any())
                        {
                            <tr><td colspan="6" class="estado-mensaje">No hay citas para los filtros seleccionados.</td></tr>
                        }
                        else
                        {
                            @foreach (var c in Pagina)
                            {
                                <tr class="@(c.Estado == EstadoCita.CANCELADA || c.Estado == EstadoCita.NO_ASISTIO ? "row-disabled" : "")">
                                    <td data-label="Hora Cita" class="cell-hora">@c.FechaHoraInicio.ToString("HH:mm")</td>
                                    <td data-label="Paciente">
                                        <div class="patient-cell">
                                            <span class="pet-avatar" aria-hidden="true">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 24 24">
                                                    <circle cx="11" cy="4" r="2"></circle>
                                                    <circle cx="18" cy="8" r="2"></circle>
                                                    <circle cx="4" cy="8" r="2"></circle>
                                                    <circle cx="20" cy="16" r="2"></circle>
                                                    <path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z" />
                                                </svg>
                                            </span>
                                            <div>
                                                <div class="pet-name">@(c.Mascota?.Nombre ?? "—")</div>
                                                <div class="pet-meta">@(c.Servicio?.Nombre ?? "")</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td data-label="Cliente">@NombreCliente(c)</td>
                                    <td data-label="Servicio">@(c.Servicio?.Nombre ?? "—")</td>
                                    <td data-label="Estado">
                                        <span class="badge @EstadoBadge(c.Estado)">@EstadoLabel(c.Estado)</span>
                                    </td>
                                    <td data-label="Acciones">
                                        @if (c.Estado == EstadoCita.PENDIENTE || c.Estado == EstadoCita.CONFIRMADA || c.Estado == EstadoCita.EN_CONSULTA)
                                        {
                                            <div class="acc-wrap">
                                                <button type="button" class="acc-kebab" aria-label="Acciones" @onclick="() => ToggleMenu(c.Id)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                                        <path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0" />
                                                    </svg>
                                                </button>
                                                @if (menuCitaId == c.Id)
                                                {
                                                    <div class="acc-menu">
                                                        @switch (c.Estado)
                                                        {
                                                            case EstadoCita.PENDIENTE:
                                                                <button type="button" class="acc-item" @onclick="() => MenuConfirmar(c)">Confirmar</button>
                                                                @if (EsRecep)
                                                                {
                                                                    <button type="button" class="acc-item acc-item-danger" @onclick="() => MenuCancelar(c)">Cancelar</button>
                                                                }
                                                                break;
                                                            case EstadoCita.CONFIRMADA:
                                                                <button type="button" class="acc-item" @onclick="() => MenuIniciar(c)">Iniciar atención</button>
                                                                @if (EsRecep)
                                                                {
                                                                    <button type="button" class="acc-item" @onclick="() => MenuNoAsistio(c)">No asistió</button>
                                                                    <button type="button" class="acc-item acc-item-danger" @onclick="() => MenuCancelar(c)">Cancelar</button>
                                                                }
                                                                break;
                                                            case EstadoCita.EN_CONSULTA:
                                                                <a class="acc-item" href="@($"/citas-hoy/atender?id={c.Id}")" @onclick="() => menuCitaId = 0">Registrar atención</a>
                                                                break;
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="action-hint">@(c.Estado == EstadoCita.ATENDIDA ? "Atendida" : "—")</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>

                <Pager CurrentPage="paginaActual" TotalPages="TotalPaginas" CurrentPageChanged="IrAPagina" />
            }
        </div>

    </section>
</div>

@* Capa transparente para cerrar el menú de acciones al hacer clic fuera *@
@if (menuCitaId != 0)
{
    <div class="acc-overlay" @onclick="() => menuCitaId = 0"></div>
}

@* ===================== MODAL CANCELAR CITA ===================== *@
@if (citaACancelar is not null)
{
    <div class="vc-modal-backdrop" role="presentation">
        <div class="vc-modal-card" role="dialog" aria-modal="true">
            <button type="button" class="vc-modal-close" aria-label="Cerrar" @onclick="() => citaACancelar = null">×</button>
            <h3 class="vc-modal-title">Cancelar cita</h3>
            <p class="vc-modal-message">
                Se cancelará la cita de <strong>@(citaACancelar.Mascota?.Nombre)</strong> de las @citaACancelar.FechaHoraInicio.ToString("HH:mm").
                Indica el motivo:
            </p>
            <textarea class="vc-form-textarea" rows="3" placeholder="Motivo de la cancelación…" @bind="motivoCancelacion" style="width:100%;margin-bottom:1rem;"></textarea>
            <div class="vc-modal-actions">
                <button type="button" class="vc-btn vc-btn-secondary" @onclick="() => citaACancelar = null" disabled="@procesando">Volver</button>
                <button type="button" class="vc-btn vc-btn-danger" @onclick="ConfirmarCancelacion" disabled="@procesando">
                    @if (procesando) { <span class="vc-spinner" aria-hidden="true"></span><span>Cancelando…</span> }
                    else { <span>Cancelar cita</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<Cita> citas = new();
    private bool cargando = true;
    private bool procesando;
    private string? errorMensaje;
    private int usuarioActualId;
    private bool EsRecep; // true si el usuario también tiene rol recepcionista

    // Filtro de estado (multi-selección). Por defecto: Pendiente y En consulta.
    private static readonly EstadoCita[] EstadosTodos =
    {
        EstadoCita.PENDIENTE, EstadoCita.CONFIRMADA, EstadoCita.EN_CONSULTA,
        EstadoCita.ATENDIDA, EstadoCita.NO_ASISTIO, EstadoCita.CANCELADA
    };
    private HashSet<EstadoCita> estadosSel = new() { EstadoCita.CONFIRMADA, EstadoCita.EN_CONSULTA };
    private bool estadoDropdownAbierto;

    // Paginación (cliente)
    private const int PageSize = 4;
    private int paginaActual = 1;

    private Cita? citaACancelar;
    private string motivoCancelacion = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        EsRecep = authState.User.IsInRole("RECEPCIONISTA");
        await CargarCitas();
    }

    private async Task CargarCitas()
    {
        cargando = true;
        errorMensaje = null;
        try
        {
            usuarioActualId = await ObtenerUsuarioActualId();
            if (usuarioActualId <= 0)
            {
                citas = new();
                errorMensaje = "No se pudo identificar al veterinario autenticado. Vuelve a iniciar sesion.";
                return;
            }

            var (inicio, fin) = RangoFechas();
            citas = await Task.Run(() => CitaService.ListarFiltradas(usuarioActualId, inicio, fin, "", ""));
        }
        catch (Exception ex)
        {
            errorMensaje = "No se pudieron cargar las citas. Inténtalo nuevamente.";
            citas = new();
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task<int> ObtenerUsuarioActualId()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claim = authState.User.FindFirst("IdUsuario")?.Value
            ?? authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        return int.TryParse(claim, out var id) ? id : 0;
    }

    private (DateTime, DateTime) RangoFechas()
    {
        var hoy = DateTime.Today;
        return (hoy, hoy);
    }

    private IEnumerable<Cita> CitasFiltradas
        => citas.Where(c => EsCitaDelVeterinarioActual(c) && estadosSel.Contains(c.Estado));

    private bool EsCitaDelVeterinarioActual(Cita c)
        => usuarioActualId > 0 && c.Veterinario?.Id == usuarioActualId;

    private void ToggleEstado(EstadoCita e)
    {
        if (!estadosSel.Remove(e)) estadosSel.Add(e);
        paginaActual = 1;
    }

    private bool TodosEstadosSeleccionados => estadosSel.Count == EstadosTodos.Length;

    private void ToggleTodosEstados()
    {
        estadosSel = TodosEstadosSeleccionados
            ? new HashSet<EstadoCita>()
            : EstadosTodos.ToHashSet();
        paginaActual = 1;
    }

    private string EstadosResumen
    {
        get
        {
            if (estadosSel.Count == 0) return "Ninguno";
            if (estadosSel.Count == EstadosTodos.Length) return "Todos los estados";
            if (estadosSel.Count == 1) return EstadoLabel(estadosSel.First());
            return $"{estadosSel.Count} estados";
        }
    }

    // ===== Paginación (cliente) =====
    private List<Cita> FiltradasOrdenadas => CitasFiltradas.OrderBy(x => x.FechaHoraInicio).ToList();
    private int TotalPaginas => Math.Max(1, (int)Math.Ceiling(FiltradasOrdenadas.Count / (double)PageSize));

    private IEnumerable<Cita> Pagina
    {
        get
        {
            var orden = FiltradasOrdenadas;
            if (paginaActual > TotalPaginas) paginaActual = TotalPaginas;
            if (paginaActual < 1) paginaActual = 1;
            return orden.Skip((paginaActual - 1) * PageSize).Take(PageSize);
        }
    }

    private void IrAPagina(int p) => paginaActual = p;

    private string NombreCliente(Cita c)
    {
        var cl = c.Mascota?.Cliente;
        return cl is null ? "—" : $"{cl.Nombres} {cl.Apellidos}".Trim();
    }

    // Sin autenticación todavía: usamos el id del veterinario de la cita como modificador (FK válida)
    private int ModBy(Cita c) => usuarioActualId;

    // Veterinario (sin rol recepción): marca la cita en consulta y va directo al registro de atención.
    private async Task IrARegistrar(Cita c)
    {
        try { await Task.Run(() => CitaService.MarcarEnConsulta(c.Id, ModBy(c))); }
        catch { /* si falla el cambio de estado, igual abrimos el registro */ }
        Nav.NavigateTo($"/citas-hoy/atender?id={c.Id}");
    }

    private string EstadoBadge(EstadoCita e) => e switch
    {
        EstadoCita.PENDIENTE => "badge-pending",
        EstadoCita.CONFIRMADA => "badge-confirmada",
        EstadoCita.EN_CONSULTA => "badge-enconsulta",
        EstadoCita.ATENDIDA => "badge-atendida",
        EstadoCita.NO_ASISTIO => "badge-noshow",
        _ => "badge-cancelled"
    };

    private string EstadoLabel(EstadoCita e) => e switch
    {
        EstadoCita.PENDIENTE => "Pendiente",
        EstadoCita.CONFIRMADA => "Confirmada",
        EstadoCita.EN_CONSULTA => "En consulta",
        EstadoCita.ATENDIDA => "Atendida",
        EstadoCita.CANCELADA => "Cancelada",
        EstadoCita.NO_ASISTIO => "No asistió",
        _ => e.ToString()
    };

    // Envoltorios de acciones (sin literales de texto en el markup)
    private Task Confirmar(Cita c) => Accion(() => CitaService.ConfirmarCita(c.Id, ModBy(c)), "Cita confirmada correctamente.");
    private Task NoAsistio(Cita c) => Accion(() => CitaService.MarcarNoAsistio(c.Id, ModBy(c)), "Cita marcada como no asistió.");

    // ===== Menú de acciones (3 puntos) =====
    private int menuCitaId = 0;
    private void ToggleMenu(int id) => menuCitaId = (menuCitaId == id) ? 0 : id;
    private async Task MenuConfirmar(Cita c) { menuCitaId = 0; await Confirmar(c); }
    private async Task MenuIniciar(Cita c) { menuCitaId = 0; await IrARegistrar(c); }
    private async Task MenuNoAsistio(Cita c) { menuCitaId = 0; await NoAsistio(c); }
    private void MenuCancelar(Cita c) { menuCitaId = 0; PedirCancelar(c); }

    private async Task Accion(Func<int> accion, string okMsg)
    {
        if (procesando) return;
        if (usuarioActualId <= 0)
        {
            Toasts.Error("No se pudo identificar al usuario autenticado.");
            return;
        }

        procesando = true;
        try
        {
            int r = await Task.Run(accion);
            if (r == 1)
            {
                Toasts.Exito(okMsg);
                await CargarCitas();
            }
            else
            {
                Toasts.Error("No se pudo completar la operación. Inténtalo nuevamente.");
            }
        }
        catch (Exception ex)
        {
            Toasts.Error(string.IsNullOrWhiteSpace(ex.Message)
                ? "Ocurrio un error. Intentalo nuevamente."
                : ex.Message);
        }
        finally
        {
            procesando = false;
        }
    }

    private void PedirCancelar(Cita c)
    {
        citaACancelar = c;
        motivoCancelacion = "";
    }

    private async Task ConfirmarCancelacion()
    {
        if (procesando || citaACancelar is null) return;
        if (string.IsNullOrWhiteSpace(motivoCancelacion))
        {
            Toasts.Error("Indica el motivo de la cancelación.");
            return;
        }

        procesando = true;
        try
        {
            var c = citaACancelar;
            int r = await Task.Run(() => CitaService.CancelarCita(c.Id, motivoCancelacion.Trim(), ModBy(c)));
            if (r == 1)
            {
                Toasts.Exito("Cita cancelada correctamente.");
                citaACancelar = null;
                await CargarCitas();
            }
            else
            {
                Toasts.Error("No se pudo cancelar la cita. Inténtalo nuevamente.");
            }
        }
        catch (Exception ex)
        {
            Toasts.Error(string.IsNullOrWhiteSpace(ex.Message)
                ? "Ocurrio un error. Intentalo nuevamente."
                : ex.Message);
        }
        finally
        {
            procesando = false;
        }
    }
}
