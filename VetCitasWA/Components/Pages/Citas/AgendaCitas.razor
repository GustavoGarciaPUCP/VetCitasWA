@* ----- 3) EN CONSULTA: atención en curso (solo lectura para recep) ----- *@
<div class="ac-modal-backdrop ac-modal-detalle" data-state="enconsulta">
    <div class="ac-modal-card" role="dialog" aria-modal="true" aria-labelledby="det-enconsulta-title">
        <header class="ac-modal-head">
            <div class="ac-detalle-head">
                <h2 id="det-enconsulta-title" class="ac-modal-title">Cita #1002</h2>
                <span class="dt-badge dt-enconsulta">
                    <span class="dt-pulse-dot" aria-hidden="true"></span>
                    En Consulta
                </span>
            </div>
            <label for="agenda-det-enconsulta" class="ac-modal-close" aria-label="Cerrar">×</label>
