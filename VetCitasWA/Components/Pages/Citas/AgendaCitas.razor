        <footer class="ac-modal-foot ac-modal-foot-detail">
            <label for="cancelar-cita-modal" class="btn-modal btn-modal-danger recep-only">Cancelar Cita</label>
            <label for="reprogramar-cita-modal" class="btn-modal btn-modal-secondary recep-only">Reprogramar</label>
            <button type="button" class="btn-modal btn-modal-primary recep-only">Marcar Confirmada</button>
        </footer>
    </div>
</div>

