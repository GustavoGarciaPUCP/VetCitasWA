    private List<HorarioVeterinario> HorariosBaseAgenda()
        => horariosAgenda
            .Where(h => h.Activo && (vetFiltro == 0 || h.Veterinario?.Id == vetFiltro))
            .ToList();

    private List<int> CalcularHorasAgenda()
    {
        var horarios = HorariosBaseAgenda();
        var citasVisibles = citas.Where(PasaFiltros).ToList();

        if (!horarios.Any() && !citasVisibles.Any())
        {
            return Enumerable.Range(HoraAperturaFallback, HoraCierreMaxima - HoraAperturaFallback).ToList();
        }

        var inicio = horarios.Any()
            ? horarios.Min(h => Math.Clamp(h.HoraInicio.Hour, 0, HoraCierreMaxima - 1))
            : HoraAperturaFallback;

        var cierre = horarios.Any()
            ? horarios.Max(h => Math.Min(HoraCierreMaxima + 1, h.HoraFin.Hour + (h.HoraFin.Minute > 0 ? 1 : 0)))
            : HoraCierreMaxima;

        var ultimaHora = Math.Max(inicio, cierre - 1);

        if (citasVisibles.Any())
        {
            inicio = Math.Min(inicio, citasVisibles.Min(c => Math.Clamp(c.FechaHoraInicio.Hour, 0, HoraCierreMaxima - 1)));
            ultimaHora = Math.Max(ultimaHora, citasVisibles.Max(c => Math.Clamp(c.FechaHoraInicio.Hour, 0, HoraCierreMaxima - 1)));
        }

        ultimaHora = Math.Min(ultimaHora, HoraCierreMaxima);
        return Enumerable.Range(inicio, ultimaHora - inicio + 1).ToList();
    }

    private bool EsFueraHorario(DateTime dia, int hora)
