@code {
    private List<Cita> listaCitas = new();
    private List<Veterinario> listaVeterinarios = new();

    private int idVetSeleccionado = 0;
    private string estadoSeleccionado = "";
    private DateTime fechaDesde = DateTime.Today;
    private DateTime fechaHasta = DateTime.Today.AddDays(6);

    // Días Lunes..Viernes de la semana que contiene fechaDesde.
    private IEnumerable<DateTime> DiasSemana
    {
        get
        {
            int offset = ((int)fechaDesde.DayOfWeek + 6) % 7; // 0 = Lunes
            var lunes = fechaDesde.Date.AddDays(-offset);
            for (int i = 0; i < 5; i++)
            {
                yield return lunes.AddDays(i);
            }
        }
    }

    private static readonly int[] Horas = new[] { 8, 9, 10, 11, 12, 13, 14, 15, 16 };

    protected override void OnInitialized()
    {
        listaVeterinarios = VetService.ListarTodos();
        Recargar();
    }

    private void Recargar()
    {
        listaCitas = CitaService.ListarFiltradas(idVetSeleccionado, fechaDesde, fechaHasta, estadoSeleccionado, "");
    }

    private void OnVetChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            idVetSeleccionado = id;
            Recargar();
        }
    }

    private void OnEstadoChanged(ChangeEventArgs e)
    {
        estadoSeleccionado = e.Value?.ToString() ?? "";
        Recargar();
    }

    private void OnDesdeChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var f))
        {
            fechaDesde = f;
            Recargar();
        }
    }

    private void OnHastaChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var f))
        {
            fechaHasta = f;
            Recargar();
        }
    }

    private string NombreDia(DateTime d) => d.DayOfWeek switch
    {
        DayOfWeek.Monday => "Lunes",
        DayOfWeek.Tuesday => "Martes",
        DayOfWeek.Wednesday => "Miércoles",
        DayOfWeek.Thursday => "Jueves",
        DayOfWeek.Friday => "Viernes",
        DayOfWeek.Saturday => "Sábado",
        _ => "Domingo"
    };

    private string EspecieTexto(Mascota? m)
        => m == null ? "" : (m.Especie == TipoEspecie.PERRO ? "Perro" : "Gato");

    private string CssEstado(EstadoCita estado) => estado switch
    {
        EstadoCita.PENDIENTE => "cita-pendiente",
        EstadoCita.CONFIRMADA => "cita-confirmada",
        EstadoCita.EN_CONSULTA => "cita-enconsulta",
        EstadoCita.ATENDIDA => "cita-atendida",
        EstadoCita.CANCELADA => "cita-cancelada",
        EstadoCita.NO_ASISTIO => "cita-noasistio",
        _ => ""
    };

    private string EstadoTexto(EstadoCita estado) => estado switch
    {
        EstadoCita.PENDIENTE => "Pendiente",
        EstadoCita.CONFIRMADA => "Confirmada",
        EstadoCita.EN_CONSULTA => "En Consulta",
        EstadoCita.ATENDIDA => "Atendida",
        EstadoCita.CANCELADA => "Cancelada",
        EstadoCita.NO_ASISTIO => "No asistió",
        _ => ""
    };

    private string ModalDetalleId(EstadoCita estado) => estado switch
    {
        EstadoCita.PENDIENTE => "agenda-det-pendiente",
        EstadoCita.CONFIRMADA => "agenda-det-confirmada",
        EstadoCita.EN_CONSULTA => "agenda-det-enconsulta",
        EstadoCita.ATENDIDA => "agenda-det-atendida",
        EstadoCita.CANCELADA => "agenda-det-cancelada",
        EstadoCita.NO_ASISTIO => "agenda-det-noasistio",
        _ => "agenda-nueva-modal"
    };
}
