        var hor = horariosVet.FirstOrDefault(h => h.DiaSemana == DiaSemanaNum(dia) && h.Activo);
        if (hor?.HoraDescansoInicio is null || hor.HoraDescansoFin is null) return false;
        var t = new TimeOnly(hora, 0);
