    private Task OnMascotaNuevaSel(int value)
    {
        cruceClienteConfirmado = false;
        if (MascotaTieneCruceCrear(value))
        {
            mascotaSel = 0;
            errorCrear = "La mascota ya tiene una cita que se cruza con ese horario. Elige otra hora o revisa su agenda.";
        }
        else
        {
            mascotaSel = value;
            errorCrear = null;
        }

        return Task.CompletedTask;
    }

    private async Task OnServicioNuevaSel(int value)
    {
        servicioSel = value;
        await ActualizarVeterinariosDisponibles();
    }

    private async Task ActualizarVeterinariosDisponibles()
    {
        vetSel = 0;
        veterinariosDisponiblesCrear = new();
        errorCrear = null;

        if (!mostrarCrear || servicioSel <= 0 || fechaNueva.Date < DateTime.Today)
        {
            citasDiaCrear = new();
            fechaCitasDiaCrear = null;
            return;
        }

        cargandoVeterinariosCrear = true;
        try
        {
            var inicio = fechaNueva.Date.Add(horaNueva.ToTimeSpan());
            await RefrescarCitasDiaCrear(forzar: true);
            await RefrescarVeterinariosYHorarios();
            veterinariosDisponiblesCrear = await Task.Run(() => VeterinarioService.ListarDisponibles(inicio, servicioSel));
            cruceClienteConfirmado = false;
            if (mascotaSel > 0 && MascotaTieneCruceCrear(mascotaSel))
            {
                mascotaSel = 0;
                errorCrear = "La mascota seleccionada ya tiene una cita que se cruza con ese horario.";
            }
        }
        catch
        {
            veterinariosDisponiblesCrear = new();
            errorCrear = "No se pudo consultar la disponibilidad de veterinarios.";
        }
        finally
        {
            cargandoVeterinariosCrear = false;
        }
    }

    // Busca clientes en el servidor al escribir (mínimo 2 caracteres, con debounce).
    // Los resultados se muestran con scroll incremental (<Virtualize>), así no se precarga toda la lista.
    private async Task<bool> RefrescarCitasDiaCrear(bool forzar = false)
    {
        if (fechaNueva.Date < DateTime.Today)
        {
            citasDiaCrear = new();
            fechaCitasDiaCrear = null;
            return true;
        }

        if (!forzar && fechaCitasDiaCrear == fechaNueva.Date)
        {
            return true;
        }

        try
        {
            citasDiaCrear = await Task.Run(() => CitaService.ListarFiltradas(0, fechaNueva.Date, fechaNueva.Date, "", ""));
            fechaCitasDiaCrear = fechaNueva.Date;
            return true;
        }
        catch
        {
            citasDiaCrear = new();
            fechaCitasDiaCrear = null;
            return false;
        }
    }

    private async Task RefrescarVeterinariosYHorarios()
    {
        veterinarios = await Task.Run(() => VeterinarioService.ListarTodos());
        horariosAgenda = await Task.Run(() => HorarioService.ListarTodos());
    }

    private (DateTime Inicio, DateTime Fin) RangoNuevaCita()
    {
        var inicio = fechaNueva.Date.Add(horaNueva.ToTimeSpan());
        var servicio = servicios.FirstOrDefault(s => s.Id == servicioSel);
        var duracion = servicio?.DuracionMinutos ?? 30;
        return (inicio, inicio.AddMinutes(duracion));
    }

    private bool MascotaTieneCruceCrear(int idMascota)
    {
        if (idMascota <= 0 || !PuedeConsultarDisponibilidadCrear || !citasDiaCrear.Any())
        {
            return false;
        }

        var (inicio, fin) = RangoNuevaCita();
        return citasDiaCrear.Any(c =>
            c.Mascota?.Id == idMascota
            && EsEstadoBloqueante(c.Estado)
            && RangosSeCruzan(inicio, fin, c.FechaHoraInicio, c.FechaHoraFin));
    }

    private bool ClienteTieneCruceCrear(int idCliente)
    {
        if (idCliente <= 0 || !PuedeConsultarDisponibilidadCrear || !citasDiaCrear.Any())
        {
            return false;
        }

        var (inicio, fin) = RangoNuevaCita();
        return citasDiaCrear.Any(c =>
            c.Mascota?.Cliente?.Id == idCliente
            && EsEstadoBloqueante(c.Estado)
            && RangosSeCruzan(inicio, fin, c.FechaHoraInicio, c.FechaHoraFin));
    }

    // Cruce del cliente con OTRA mascota (no la seleccionada): se permite, pero se avisa.
    private bool ClienteTieneCruceConOtraMascota(int idCliente, int idMascota)
    {
        if (idCliente <= 0 || !PuedeConsultarDisponibilidadCrear || !citasDiaCrear.Any())
        {
            return false;
        }

        var (inicio, fin) = RangoNuevaCita();
        return citasDiaCrear.Any(c =>
            c.Mascota?.Cliente?.Id == idCliente
            && c.Mascota?.Id != idMascota
            && EsEstadoBloqueante(c.Estado)
            && RangosSeCruzan(inicio, fin, c.FechaHoraInicio, c.FechaHoraFin));
    }

    private async Task OnClienteBuscar()
    {
        clienteDropdownAbierto = true;
        // Al cambiar el texto se considera que aún no hay cliente confirmado
        clienteSel = 0;
        mascotaSel = 0;
        mascotasCliente = new();

        var texto = clienteBusqueda.Trim();
        clienteCts?.Cancel();

        if (texto.Length < 2)
        {
            resultadosCliente = new();
            buscandoCliente = false;
            return;
        }

        clienteCts = new CancellationTokenSource();
        var token = clienteCts.Token;
        try
        {
            await Task.Delay(400, token); // debounce
            buscandoCliente = true;
            await InvokeAsync(StateHasChanged);

            var lista = await Task.Run(() => ClienteService.ListarPorNombreApellidoODni(texto));
            if (token.IsCancellationRequested) return;
            resultadosCliente = lista;
        }
        catch (TaskCanceledException) { return; }
        catch
        {
            resultadosCliente = new();
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                buscandoCliente = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task SeleccionarCliente(Cliente c)
    {
        clienteCts?.Cancel();
        clienteSel = c.Id;
        clienteBusqueda = $"{c.Nombres} {c.Apellidos}";
        clienteDropdownAbierto = false;
        resultadosCliente = new();
        mascotaSel = 0;
        cruceClienteConfirmado = false;
        var mascotasDelCliente = await Task.Run(() => MascotaService.ListarPorCliente(clienteSel));
        mascotasCliente = mascotasDelCliente.Where(m => m.Activo).ToList(); // solo mascotas activas para agendar
        if (PuedeConsultarDisponibilidadCrear)
        {
            await RefrescarCitasDiaCrear();
        }
    }

    public void Dispose() => clienteCts?.Cancel();

    private void AbrirCrearEn(DateTime dia, int hora)
    {
        AbrirCrear();
        fechaNueva = dia.Date;
        horaNueva = new TimeOnly(hora, 0);
    }

    private async Task GuardarCita()
    {
        if (procesando) return;
        if (clienteSel == 0 || mascotaSel == 0 || servicioSel == 0 || vetSel == 0)
        {
            errorCrear = "Completa cliente, mascota, servicio y veterinario.";
            return;
        }
        if (usuarioActualId <= 0)
        {
            errorCrear = "No se pudo identificar al usuario autenticado. Vuelve a iniciar sesion.";
            return;
        }
        if (fechaNueva.Date < DateTime.Today)
        {
            errorCrear = "No se puede agendar una cita en una fecha anterior a hoy.";
            return;
        }

        var inicio = fechaNueva.Date.Add(horaNueva.ToTimeSpan());
        var servicio = servicios.FirstOrDefault(s => s.Id == servicioSel);
        int dur = servicio?.DuracionMinutos ?? 30;
        var fin = inicio.AddMinutes(dur);

        procesando = true;
        errorCrear = null;
        try
        {
            var citasDiaOk = await RefrescarCitasDiaCrear(forzar: true);
            if (!citasDiaOk)
            {
                errorCrear = "No se pudo validar si el cliente ya tiene una cita en ese horario. Intenta nuevamente.";
                procesando = false;
                return;
            }

            if (MascotaTieneCruceCrear(mascotaSel))
            {
                mascotaSel = 0;
                errorCrear = "La mascota ya tiene una cita que se cruza con ese horario. Elige otra hora o revisa su agenda.";
                procesando = false;
                return;
            }

            // Cliente con OTRA mascota a la misma hora: se permite, pero se pide confirmación.
            if (!cruceClienteConfirmado && ClienteTieneCruceConOtraMascota(clienteSel, mascotaSel))
            {
                procesando = false;
                mostrarAdvertenciaCliente = true;
                return;
            }

            // Pre-chequeo opcional; si falla (p. ej. el endpoint no responde JSON),
            // continuamos: el backend vuelve a validar horario y cruces al insertar.
            bool disponible = true;
            try { disponible = await Task.Run(() => CitaService.ValidarDisponibilidadSlot(vetSel, inicio, fin)); }
            catch
            {
                errorCrear = "No se pudo validar la disponibilidad del veterinario. Intenta nuevamente.";
                procesando = false;
                return;
            }
            if (!disponible)
            {
                errorCrear = "El veterinario no está disponible en ese horario. Elige otro horario o veterinario.";
                procesando = false;
                return;
            }

            var disponibles = await Task.Run(() => VeterinarioService.ListarDisponibles(inicio, servicioSel));
            if (!disponibles.Any(v => v.Id == vetSel))
            {
                veterinariosDisponiblesCrear = disponibles;
                vetSel = 0;
                errorCrear = "El veterinario seleccionado ya no esta disponible. Elige otro veterinario.";
                procesando = false;
                return;
            }

            var cita = new Cita
            {
                FechaHoraInicio = inicio,
                FechaHoraFin = fin,
                Estado = EstadoCita.PENDIENTE,
                Mascota = new Mascota { Id = mascotaSel },
                Veterinario = new Veterinario { Id = vetSel },
                Servicio = new Servicio { Id = servicioSel },
                ModifiedBy = new Usuario { Id = usuarioActualId }
            };

            var resultado = await Task.Run(() => CitaService.InsertarCitaSeguro(cita));
            if (resultado.Ok)
            {
                Toasts.Exito("Cita agendada correctamente.");
                mostrarCrear = false;
                await CargarCitas();
            }
            else
            {
                errorCrear = MensajeCrearAmigable(resultado.Mensaje);
            }
        }
        catch (Exception ex)
        {
            errorCrear = string.IsNullOrWhiteSpace(ex.Message)
                ? "No se pudo agendar la cita. Intentalo nuevamente."
                : MensajeCrearAmigable(ex.Message);
        }
        finally
        {
            procesando = false;
        }
    }

    private static string MensajeCrearAmigable(string mensaje)
    {
        if (string.IsNullOrWhiteSpace(mensaje))
        {
            return "No se pudo agendar la cita. Intentalo nuevamente.";
        }

        var limpio = mensaje.Replace("ERROR insertando cita:", "", StringComparison.OrdinalIgnoreCase).Trim();
        if (limpio.Contains("cliente", StringComparison.OrdinalIgnoreCase)
            && limpio.Contains("cita", StringComparison.OrdinalIgnoreCase))
        {
            return "Este cliente ya tiene una cita que se cruza con ese horario. Elige otra hora antes de agendar.";
        }

        if (limpio.Contains("mascota", StringComparison.OrdinalIgnoreCase)
            && limpio.Contains("cita", StringComparison.OrdinalIgnoreCase))
        {
            return "La mascota ya tiene una cita que se cruza con ese horario. Elige otra hora o revisa su agenda.";
        }

        if (limpio.Contains("veterinario", StringComparison.OrdinalIgnoreCase)
            && limpio.Contains("disponible", StringComparison.OrdinalIgnoreCase))
        {
            return "El veterinario ya no esta disponible para ese horario. Elige otro veterinario u otra hora.";
        }

        return limpio;
    }

