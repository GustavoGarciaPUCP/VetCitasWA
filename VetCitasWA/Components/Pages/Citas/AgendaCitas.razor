@* ============================================================ *@
@* =============== MODAL: Agendar Nueva Cita ================= *@
@* ============================================================ *@
<div class="ac-modal-backdrop ac-modal-nueva">
    <div class="ac-modal-card" role="dialog" aria-modal="true" aria-labelledby="nueva-title">
        <header class="ac-modal-head">
            <div>
                <h2 id="nueva-title" class="ac-modal-title">Agendar Nueva Cita</h2>
                <p class="ac-modal-subtitle">Completa los datos para reservar el slot</p>
            </div>
            <label for="agenda-nueva-modal" class="ac-modal-close" aria-label="Cerrar">×</label>
        </header>

        <div class="ac-modal-body">

            <div class="ff">
                <label class="ff-label" for="m-client">Cliente</label>
                <input id="m-client" type="text" class="ff-input" placeholder="Buscar por nombre o DNI..." />
                <span class="ff-hint">Busca por DNI (8 dígitos) o nombre</span>
            </div>

            <div class="ff">
                <label class="ff-label" for="m-pet">Mascota</label>
                <div class="ff-select-wrap">
                    <select id="m-pet" class="ff-select">
                        <option value="" selected disabled hidden>Primero selecciona un cliente...</option>
                        <option>Max (Perro - Golden Retriever)</option>
                        <option>Thor (Perro - Pastor Alemán)</option>
                    </select>
                </div>
                <span class="ff-hint">Solo las mascotas activas del cliente</span>
            </div>

            <div class="ff">
                <label class="ff-label" for="m-srv">Servicio</label>
                <div class="ff-select-wrap">
                    <select id="m-srv" class="ff-select">
                        <option value="" selected disabled hidden>Seleccionar servicio...</option>
                        <option>Consulta General — 30 min · S/ 50.00</option>
                        <option>Esterilización Canina — 120 min · S/ 250.00</option>
                        <option>Vacunación Múltiple — 15 min · S/ 35.00</option>
                        <option>Cirugía Menor — 60 min · S/ 300.00</option>
                        <option>Control Post-Operatorio — 20 min · S/ 30.00</option>
                    </select>
                </div>
                <span class="ff-hint">Muestra duración y precio referencial</span>
            </div>

            <div class="ff ff-row">
                <div class="ff-col">
                    <label class="ff-label" for="m-date">Fecha</label>
                    <input id="m-date" type="date" class="ff-input" value="2026-05-13" />
                </div>
                <div class="ff-col">
                    <label class="ff-label" for="m-time">Hora</label>
                    <input id="m-time" type="time" class="ff-input" value="10:00" step="900" />
                </div>
            </div>

            <div class="ff">
                <label class="ff-label" for="m-vet">Veterinario</label>
                <div class="ff-select-wrap">
                    <select id="m-vet" class="ff-select">
                        <option>Dr. Carlos — Medicina general</option>
                        <option>Dra. Sofía — Cirugía</option>
                        <option>Dr. Ricardo — Cardiología</option>
                    </select>
                </div>
                <span class="ff-hint">Se valida disponibilidad y horario</span>
            </div>

        </div>

        <footer class="ac-modal-foot">
            <button type="button" class="btn-modal btn-modal-primary">Confirmar Cita</button>
        </footer>
    </div>
</div>

@* ============================================================ *@
@* === MODALES DE DETALLE (uno por estado de cita) ============ *@
@* ============================================================ *@

@* ----- 1) PENDIENTE: cliente aún no ha confirmado ----- *@
<div class="ac-modal-backdrop ac-modal-detalle" data-state="pendiente">
    <div class="ac-modal-card" role="dialog" aria-modal="true" aria-labelledby="det-pendiente-title">
        <header class="ac-modal-head">
            <div class="ac-detalle-head">
                <h2 id="det-pendiente-title" class="ac-modal-title">Cita #1003</h2>
                <span class="dt-badge dt-pendiente">Pendiente</span>
            </div>
            <label for="agenda-det-pendiente" class="ac-modal-close" aria-label="Cerrar">×</label>
        </header>

        <div class="ac-modal-body">

            <div class="dt-banner dt-banner-warn">
                <strong>Cliente aún no confirma.</strong>
                Recomendamos enviarle un recordatorio antes del día de la cita.
            </div>

            <div class="dt-section">
                <h3 class="dt-section-title">Mascota</h3>
                <div class="dt-row"><span class="dt-label">Nombre</span><span class="dt-value">Luna</span></div>
                <div class="dt-row"><span class="dt-label">Especie / Raza</span><span class="dt-value">Gato · Siamés</span></div>
            </div>

            <div class="dt-section">
                <h3 class="dt-section-title">Cliente</h3>
                <div class="dt-row"><span class="dt-label">Nombre</span><span class="dt-value">María García</span></div>
                <div class="dt-row"><span class="dt-label">Teléfono</span><span class="dt-value">+51 987 612 543</span></div>
            </div>

            <div class="dt-section">
                <h3 class="dt-section-title">Servicio</h3>
                <div class="dt-row"><span class="dt-label">Servicio</span><span class="dt-value">Vacunación</span></div>
                <div class="dt-row"><span class="dt-label">Duración</span><span class="dt-value">15 min</span></div>
            </div>

            <div class="dt-section">
                <h3 class="dt-section-title">Programación</h3>
                <div class="dt-row"><span class="dt-label">Veterinario</span><span class="dt-value">Dr. Carlos</span></div>
                <div class="dt-row"><span class="dt-label">Fecha</span><span class="dt-value">Mar 13/05/2026</span></div>
                <div class="dt-row"><span class="dt-label">Hora</span><span class="dt-value">11:30 — 11:45</span></div>
            </div>

        </div>

        @* Cancelar/Reprogramar son acciones de gestión — solo rol Recepcionista. *@
        <footer class="ac-modal-foot ac-modal-foot-detail">
            <label for="cancelar-cita-modal" class="btn-modal btn-modal-danger recep-only">Cancelar Cita</label>
            <label for="reprogramar-cita-modal" class="btn-modal btn-modal-secondary recep-only">Reprogramar</label>
            <button type="button" class="btn-modal btn-modal-primary recep-only">Marcar Confirmada</button>
        </footer>
    </div>
</div>

