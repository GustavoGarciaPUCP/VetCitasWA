@page "/agenda-citas"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "RECEPCIONISTA")]
@implements IDisposable
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using VetCitasWA.Servicios.Modelo.Cita
@using VetCitasWA.Servicios.Modelo.Cliente
@using VetCitasWA.Servicios.Modelo.Usuario
@using VetCitasWA.Servicios.Modelo.Servicio
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.CitaRS.CitaRestService CitaService
@inject VetCitasWA.Servicios.REST.ServicioRS.ServicioRestService ServicioService
@inject VetCitasWA.Servicios.REST.UsuarioRS.VeterinarioRestService VeterinarioService
@inject VetCitasWA.Servicios.REST.UsuarioRS.HorarioVeterinarioRestService HorarioService
@inject VetCitasWA.Servicios.REST.ClienteRS.ClienteRestService ClienteService
@inject VetCitasWA.Servicios.REST.ClienteRS.MascotaRestService MascotaService
@inject VetCitasWA.Servicios.UI.ToastService Toasts

<PageTitle>Agenda de citas - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Agenda de citas</span>
</SectionContent>

<div class="page-section">

    <div class="page-head">
        <h1 class="page-title">Gestión de citas · vista semanal</h1>
        <button type="button" class="btn-new-cita" @onclick="() => AbrirCrear()">
            <span class="btn-plus" aria-hidden="true">+</span>
            <span>Nueva cita</span>
        </button>
    </div>

    @* ----- Toolbar: filtros + navegación ----- *@
    <div class="cal-toolbar">
        <div class="tb-field tb-field-vet">
            <label class="tb-label" for="vetFilter">Veterinario</label>
            <div class="tb-control">
                <VcSelect TValue="int" Value="vetFiltro" ValueChanged="OnVetFiltroSel" Options="VetFiltroOptions" />
            </div>
        </div>

        <div class="tb-field tb-field-state">
            <label class="tb-label">Estado</label>
            <div class="tb-control vc-ms">
                <button type="button" class="tb-select vc-ms-toggle" @onclick="() => estadoDropdownAbierto = !estadoDropdownAbierto">
                    @EstadosResumen
                </button>
                @if (estadoDropdownAbierto)
                {
                    <div class="vc-ms-overlay" @onclick="() => estadoDropdownAbierto = false"></div>
                    <div class="vc-ms-panel">
                        @foreach (var e in EstadosTodos)
                        {
                            <label class="vc-ms-item">
                                <input type="checkbox" checked="@estadosSel.Contains(e)" @onchange="() => ToggleEstado(e)" />
                                <span>@EstadoLabel(e)</span>
                            </label>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="tb-field tb-field-nav">
            <label class="tb-label">Navegación</label>
            <div class="tb-nav">
                <button type="button" class="tb-nav-btn" aria-label="Semana anterior" @onclick="SemanaAnterior">‹</button>
                <button type="button" class="tb-nav-btn tb-nav-today" @onclick="IrHoy">Hoy</button>
                <button type="button" class="tb-nav-btn" aria-label="Semana siguiente" @onclick="SemanaSiguiente">›</button>
            </div>
        </div>
    </div>

    @* Resumen del rango activo *@
    <div class="cal-range-summary">
        <span class="range-label">Mostrando:</span>
        <strong class="range-value">@FechaLarga(semanaInicio) — @FechaLarga(SemanaFin)</strong>
        <span class="range-sub">(7 días · @citas.Count(PasaFiltros) citas)</span>
    </div>

    @* ----- Grilla del calendario ----- *@
    <div class="cal-card">
        @if (cargando)
        {
            <p class="estado-mensaje">Cargando agenda…</p>
        }
        else if (errorMensaje is not null)
        {
            <p class="estado-mensaje estado-error">@errorMensaje</p>
        }
        else
        {
            <div class="cal-grid">
                <div class="cal-cell cal-head cal-corner"></div>
                @foreach (var d in DiasSemana)
                {
                    <div class="cal-cell cal-head">@DiasNombre[(int)(d - semanaInicio).TotalDays]<span class="cal-head-date">@FechaCorta(d)</span></div>
                }

                @foreach (var h in Horas)
                {
                    <div class="cal-cell cal-time">@($"{h:00}:00")</div>
                    @foreach (var d in DiasSemana)
                    {
                        var lista = CitasEn(d, h);
                        @if (EsRefrigerio(d, h) && !lista.Any())
                        {
                            <div class="cal-cell cal-break">Refrigerio</div>
                        }
                        else
                        {
                            <div class="cal-cell cal-slot">
                                @if (lista.Any())
                                {
                                    @foreach (var c in lista)
                                    {
                                        <div class="cita @CitaClase(c.Estado)" role="button" @onclick="() => AbrirDetalle(c)">
                                            <div class="cita-title">@c.Mascota?.Nombre</div>
                                            <div class="cita-sub">@NombreCliente(c) · @(c.Servicio?.Nombre)</div>
                                            <div class="cita-foot">@c.FechaHoraInicio.ToString("HH:mm") · @EstadoLabel(c.Estado)</div>
                                        </div>
                                    }
                                    @if (!EsPasado(d, h) && !EsRefrigerio(d, h))
                                    {
                                        <button type="button" class="slot-add-mini" @onclick="() => AbrirCrearEn(d, h)" title="Agendar otra cita en este horario"><span aria-hidden="true">+</span> Agregar</button>
                                    }
                                }
                                else if (!EsPasado(d, h))
                                {
                                    <button type="button" class="slot-trigger" aria-label="Nueva cita" @onclick="() => AbrirCrearEn(d, h)"></button>
                                }
                            </div>
                        }
                    }
                }
            </div>
        }
    </div>

    @* ----- Leyenda ----- *@
    <div class="cal-legend">
        <span class="legend-item"><span class="dot dot-pendiente"></span> Pendiente</span>
        <span class="legend-item"><span class="dot dot-confirmada"></span> Confirmada</span>
        <span class="legend-item"><span class="dot dot-enconsulta"></span> En consulta</span>
        <span class="legend-item"><span class="dot dot-atendida"></span> Atendida</span>
        <span class="legend-item"><span class="dot dot-cancelada"></span> Cancelada</span>
        <span class="legend-item"><span class="dot dot-noasistio"></span> No asistió</span>
    </div>

</div>

@* ===================== MODAL NUEVA CITA ===================== *@
@if (mostrarCrear)
{
    <div class="vc-modal-backdrop" role="presentation">
        <div class="vc-modal-card vc-modal-card-lg" role="dialog" aria-modal="true">
            <button type="button" class="vc-modal-close" aria-label="Cerrar" @onclick="() => mostrarCrear = false" disabled="@procesando">×</button>
            <h2 class="vc-modal-title">Agendar nueva cita</h2>
            <p class="vc-modal-subtitle">Completa los datos para reservar el horario</p>

            <div class="vc-form-field vc-ac">
                <label class="vc-form-label">Cliente *</label>
                <input type="text" class="vc-form-input" placeholder="Buscar por nombre o DNI…"
                       @bind="clienteBusqueda" @bind:event="oninput" @bind:after="OnClienteBuscar"
                       @onfocus="() => clienteDropdownAbierto = true"
                       @onfocusout="() => clienteDropdownAbierto = false" />
                @if (clienteDropdownAbierto)
                {
                    <div class="vc-ac-list" @onmousedown:preventDefault="true">
                        @if (clienteBusqueda.Trim().Length < 2)
                        {
                            <div class="vc-ac-empty">Escribe al menos 2 caracteres para buscar.</div>
                        }
                        else if (buscandoCliente)
                        {
                            <div class="vc-ac-empty">Buscando…</div>
                        }
                        else if (!resultadosCliente.Any())
                        {
                            <div class="vc-ac-empty">Sin resultados.</div>
                        }
                        else
                        {
                            <Virtualize Items="resultadosCliente" Context="c" ItemSize="46">
                                <div class="vc-ac-item" @onclick="() => SeleccionarCliente(c)">
                                    <span class="vc-ac-name">@c.Nombres @c.Apellidos</span>
                                    <span class="vc-ac-meta">DNI @c.Dni</span>
                                </div>
                            </Virtualize>
                        }
                    </div>
                }
            </div>

            <div class="vc-form-field">
                <label class="vc-form-label">Mascota *</label>
                <VcSelect TValue="int" @bind-Value="mascotaSel" Options="MascotaOptions"
                          Placeholder="@(clienteSel == 0 ? "Primero selecciona un cliente…" : "Selecciona una mascota…")" />
            </div>

            <div class="vc-form-field">
                <label class="vc-form-label">Servicio *</label>
                <VcSelect TValue="int" Value="servicioSel" ValueChanged="OnServicioNuevaSel" Options="ServicioOptions"
                          Placeholder="Selecciona un servicio…" />
            </div>

            <div class="vc-form-row">
                <div class="vc-form-field">
                    <label class="vc-form-label">Fecha *</label>
                    <input type="date" class="vc-form-input" min="@HoyIso" @bind="fechaNueva" @bind:after="ActualizarVeterinariosDisponibles" />
                </div>
                <div class="vc-form-field">
                    <label class="vc-form-label">Hora *</label>
                    <input type="time" step="900" class="vc-form-input" @bind="horaNueva" @bind:after="ActualizarVeterinariosDisponibles" />
                </div>
            </div>

            <div class="vc-form-field">
                <label class="vc-form-label">Veterinario *</label>
                <VcSelect TValue="int" @bind-Value="vetSel" Options="VeterinarioCrearOptions"
                          Placeholder="Selecciona un veterinario…" />
                <span class="vc-form-hint">Se valida la disponibilidad del horario.</span>
            </div>

            @if (errorCrear is not null)
            {
                <p class="vc-form-error">@errorCrear</p>
            }

            <div class="vc-modal-actions" style="justify-content:flex-end;margin-top:1rem;">
                <button type="button" class="vc-btn vc-btn-secondary" @onclick="() => mostrarCrear = false" disabled="@procesando">Cancelar</button>
                <button type="button" class="vc-btn vc-btn-primary" @onclick="GuardarCita" disabled="@procesando">
                    @if (procesando) { <span class="vc-spinner" aria-hidden="true"></span><span>Guardando…</span> }
                    else { <span>Confirmar cita</span> }
                </button>
            </div>
        </div>
    </div>
}

@* ===================== MODAL DETALLE DE CITA ===================== *@
@if (citaDetalle is not null)
{
    <div class="vc-modal-backdrop" role="presentation">
        <div class="vc-modal-card vc-modal-card-lg" role="dialog" aria-modal="true">
            <button type="button" class="vc-modal-close" aria-label="Cerrar" @onclick="() => citaDetalle = null">×</button>
            <h2 class="vc-modal-title">Detalle de la cita <span class="@CitaBadge(citaDetalle.Estado)">@EstadoLabel(citaDetalle.Estado)</span></h2>

            <div class="vc-form-row">
                <div class="vc-form-field">
                    <span class="vc-form-label">Mascota</span>
                    <div>@(citaDetalle.Mascota?.Nombre ?? "—")</div>
                </div>
                <div class="vc-form-field">
                    <span class="vc-form-label">Cliente</span>
                    <div>@NombreCliente(citaDetalle)</div>
                </div>
            </div>
            <div class="vc-form-row">
                <div class="vc-form-field">
                    <span class="vc-form-label">Servicio</span>
                    <div>@(citaDetalle.Servicio?.Nombre ?? "—")</div>
                </div>
                <div class="vc-form-field">
                    <span class="vc-form-label">Veterinario</span>
                    <div>@(citaDetalle.Veterinario is null ? "—" : $"{citaDetalle.Veterinario.Nombres} {citaDetalle.Veterinario.Apellidos}")</div>
                </div>
            </div>
            <div class="vc-form-row">
                <div class="vc-form-field">
                    <span class="vc-form-label">Fecha</span>
                    <div>@citaDetalle.FechaHoraInicio.ToString("dddd dd/MM/yyyy")</div>
                </div>
                <div class="vc-form-field">
                    <span class="vc-form-label">Hora</span>
                    <div>@citaDetalle.FechaHoraInicio.ToString("HH:mm") — @citaDetalle.FechaHoraFin.ToString("HH:mm")</div>
                </div>
            </div>

            @if (citaDetalle.Estado == EstadoCita.CANCELADA && !string.IsNullOrWhiteSpace(citaDetalle.MotivoCancelacion))
            {
                <p class="vc-form-error">Motivo de cancelación: @citaDetalle.MotivoCancelacion</p>
            }

            <div class="vc-modal-actions" style="justify-content:flex-end;margin-top:1rem;flex-wrap:wrap;">
                @switch (citaDetalle.Estado)
                {
                    case EstadoCita.PENDIENTE:
                        <button class="vc-btn vc-btn-sm vc-btn-danger" disabled="@procesando" @onclick="() => AbrirCancelar(citaDetalle)">Cancelar cita</button>
                        <button class="vc-btn vc-btn-sm vc-btn-secondary" disabled="@procesando" @onclick="() => AbrirReprogramar(citaDetalle)">Reprogramar</button>
                        <button class="vc-btn vc-btn-sm vc-btn-primary" disabled="@procesando" @onclick="() => ConfirmarDesdeDetalle(citaDetalle)">Confirmar cita</button>
                        break;
                    case EstadoCita.CONFIRMADA:
                        <button class="vc-btn vc-btn-sm vc-btn-danger" disabled="@procesando" @onclick="() => AbrirCancelar(citaDetalle)">Cancelar cita</button>
                        <button class="vc-btn vc-btn-sm vc-btn-secondary" disabled="@procesando" @onclick="() => AbrirCambiarVet(citaDetalle)">Cambiar veterinario</button>
                        <button class="vc-btn vc-btn-sm vc-btn-primary" disabled="@procesando" @onclick="() => AbrirReprogramar(citaDetalle)">Reprogramar</button>
                        break;
                    case EstadoCita.NO_ASISTIO:
                        <button class="vc-btn vc-btn-sm vc-btn-primary" disabled="@procesando" @onclick="() => AbrirReprogramar(citaDetalle)">Reprogramar</button>
                        break;
                    default:
                        <span class="action-hint">No hay acciones disponibles.</span>
                        break;
                }
            </div>
        </div>
    </div>
}

@* ===================== MODAL REPROGRAMAR ===================== *@
@if (mostrarReprogramar && citaAccion is not null)
{
    <div class="vc-modal-backdrop" role="presentation">
        <div class="vc-modal-card" role="dialog" aria-modal="true">
            <button type="button" class="vc-modal-close" aria-label="Cerrar" @onclick="() => mostrarReprogramar = false" disabled="@procesando">×</button>
            <h3 class="vc-modal-title">Reprogramar cita</h3>
            <div class="vc-form-row">
                <div class="vc-form-field">
                    <label class="vc-form-label">Nueva fecha</label>
                    <input type="date" class="vc-form-input" min="@HoyIso" @bind="reprogFecha" />
                </div>
                <div class="vc-form-field">
                    <label class="vc-form-label">Nueva hora</label>
                    <input type="time" step="900" class="vc-form-input" @bind="reprogHora" />
                </div>
            </div>
            <div class="vc-form-field">
                <label class="vc-form-label">Motivo</label>
                <textarea class="vc-form-textarea" rows="2" @bind="reprogMotivo"></textarea>
            </div>
            <div class="vc-modal-actions" style="justify-content:flex-end;">
                <button class="vc-btn vc-btn-secondary" @onclick="() => mostrarReprogramar = false" disabled="@procesando">Volver</button>
                <button class="vc-btn vc-btn-primary" @onclick="ConfirmarReprogramar" disabled="@procesando">
                    @if (procesando) { <span class="vc-spinner" aria-hidden="true"></span><span>Guardando…</span> }
                    else { <span>Reprogramar</span> }
                </button>
            </div>
        </div>
    </div>
}

@* ===================== MODAL CAMBIAR VETERINARIO ===================== *@
@if (mostrarCambiarVet && citaAccion is not null)
{
    <div class="vc-modal-backdrop" role="presentation">
        <div class="vc-modal-card" role="dialog" aria-modal="true">
            <button type="button" class="vc-modal-close" aria-label="Cerrar" @onclick="() => mostrarCambiarVet = false" disabled="@procesando">×</button>
            <h3 class="vc-modal-title">Cambiar veterinario</h3>
            <div class="vc-form-field">
                <label class="vc-form-label">Nuevo veterinario</label>
                <VcSelect TValue="int" @bind-Value="cambiarVetSel" Options="VeterinarioOptions"
                          Placeholder="Selecciona un veterinario…" />
            </div>
            <div class="vc-modal-actions" style="justify-content:flex-end;">
                <button class="vc-btn vc-btn-secondary" @onclick="() => mostrarCambiarVet = false" disabled="@procesando">Volver</button>
                <button class="vc-btn vc-btn-primary" @onclick="ConfirmarCambiarVet" disabled="@procesando">
                    @if (procesando) { <span class="vc-spinner" aria-hidden="true"></span><span>Guardando…</span> }
                    else { <span>Cambiar</span> }
                </button>
            </div>
        </div>
    </div>
}

@* ===================== MODAL CANCELAR ===================== *@
@if (mostrarCancelar && citaAccion is not null)
{
    <div class="vc-modal-backdrop" role="presentation">
        <div class="vc-modal-card" role="dialog" aria-modal="true">
            <button type="button" class="vc-modal-close" aria-label="Cerrar" @onclick="() => mostrarCancelar = false" disabled="@procesando">×</button>
            <h3 class="vc-modal-title">Cancelar cita</h3>
            <p class="vc-modal-message">Indica el motivo de la cancelación:</p>
            <textarea class="vc-form-textarea" rows="3" @bind="cancelarMotivo" style="width:100%;margin-bottom:1rem;"></textarea>
            <div class="vc-modal-actions">
                <button class="vc-btn vc-btn-secondary" @onclick="() => mostrarCancelar = false" disabled="@procesando">Volver</button>
                <button class="vc-btn vc-btn-danger" @onclick="ConfirmarCancelar" disabled="@procesando">
                    @if (procesando) { <span class="vc-spinner" aria-hidden="true"></span><span>Cancelando…</span> }
                    else { <span>Cancelar cita</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    // Semana mostrada (lunes)
    private DateTime semanaInicio = InicioSemana(DateTime.Today);
    private List<Cita> citas = new();
    private bool cargando = true;
    private bool procesando;
    private string? errorMensaje;

    // Filtros
    private int vetFiltro = 0;

    // ===== Opciones para VcSelect =====
    private IEnumerable<VcSelectOption<int>> VetFiltroOptions =>
        new[] { new VcSelectOption<int>(0, "Todos") }
            .Concat(veterinarios.Select(v => new VcSelectOption<int>(v.Id, NombreVet(v))));

    private IEnumerable<VcSelectOption<int>> VeterinarioOptions =>
        veterinarios.Select(v => new VcSelectOption<int>(v.Id, NombreVet(v)));

    private IEnumerable<VcSelectOption<int>> VeterinarioCrearOptions =>
        veterinariosDisponiblesCrear.Select(v => new VcSelectOption<int>(v.Id, NombreVet(v)));

    private IEnumerable<VcSelectOption<int>> ServicioOptions =>
        servicios.Select(s => new VcSelectOption<int>(s.Id, $"{s.Nombre} — {s.DuracionMinutos} min · S/ {s.Precio:0.00}"));

    private IEnumerable<VcSelectOption<int>> MascotaOptions =>
        mascotasCliente.Select(m => new VcSelectOption<int>(m.Id, m.Nombre + (string.IsNullOrWhiteSpace(m.Raza) ? "" : $" — {m.Raza}")));

    private async Task OnVetFiltroSel(int v) { vetFiltro = v; await OnVetFiltroChanged(); }

    // Filtro de estado (multi-selección). Por defecto se ocultan ATENDIDA y CANCELADA.
    private static readonly EstadoCita[] EstadosTodos =
    {
        EstadoCita.PENDIENTE, EstadoCita.CONFIRMADA, EstadoCita.EN_CONSULTA,
        EstadoCita.ATENDIDA, EstadoCita.NO_ASISTIO, EstadoCita.CANCELADA
    };
    private HashSet<EstadoCita> estadosSel = new()
    {
        EstadoCita.PENDIENTE, EstadoCita.CONFIRMADA, EstadoCita.EN_CONSULTA, EstadoCita.NO_ASISTIO
    };
    private bool estadoDropdownAbierto;

    // Catálogos
    private List<Veterinario> veterinarios = new();
    private List<Servicio> servicios = new();

    // Horario del veterinario filtrado (para pintar su refrigerio real)
    private List<HorarioVeterinario> horariosVet = new();

    // Crear
    private bool mostrarCrear;
    private int clienteSel, mascotaSel, servicioSel, vetSel;
    private List<Mascota> mascotasCliente = new();
    private List<Veterinario> veterinariosDisponiblesCrear = new();
    private bool cargandoVeterinariosCrear;

    // Buscador de cliente (autocompletado con búsqueda en servidor)
    private string clienteBusqueda = "";
    private bool clienteDropdownAbierto;
    private List<Cliente> resultadosCliente = new();
    private bool buscandoCliente;
    private CancellationTokenSource? clienteCts;
    private DateTime fechaNueva = DateTime.Today;
    private TimeOnly horaNueva = new(8, 0);
    private string? errorCrear;
    private string VeterinarioCrearPlaceholder =>
        servicioSel == 0 ? "Selecciona un servicio primero" :
        cargandoVeterinariosCrear ? "Buscando disponibles..." :
        !veterinariosDisponiblesCrear.Any() ? "Sin veterinarios disponibles" :
        "Selecciona un veterinario";

    private string VeterinarioCrearHint =>
        servicioSel == 0 ? "Elige servicio, fecha y hora para ver disponibilidad." :
        cargandoVeterinariosCrear ? "Consultando horarios y cruces..." :
        veterinariosDisponiblesCrear.Any()
            ? "Solo se muestran veterinarios activos y disponibles para ese horario."
            : "No hay veterinarios activos disponibles para ese servicio y horario.";

    // Detalle / acciones
    private Cita? citaDetalle;
    private Cita? citaAccion;
    private bool mostrarReprogramar, mostrarCambiarVet, mostrarCancelar;
    private DateTime reprogFecha = DateTime.Today;
    private TimeOnly reprogHora = new(8, 0);
    private string reprogMotivo = "";
    private int cambiarVetSel;
    private string cancelarMotivo = "";

    private static readonly string[] DiasNombre = { "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo" };
    private static readonly string[] MesCorto = { "Ene", "Feb", "Mar", "Abr", "May", "Jun", "Jul", "Ago", "Sep", "Oct", "Nov", "Dic" };
    private static readonly int[] Horas = { 8, 9, 10, 11, 12, 13, 14, 15, 16 };

    private DateTime[] DiasSemana => Enumerable.Range(0, 7).Select(i => semanaInicio.AddDays(i)).ToArray();
    private DateTime SemanaFin => semanaInicio.AddDays(6);

    // Fecha mínima para los selectores de fecha (no se permiten días anteriores a hoy)
    private string HoyIso => DateTime.Today.ToString("yyyy-MM-dd");

    // Un slot es pasado si el día ya pasó, o si es hoy y la hora ya transcurrió
    private bool EsPasado(DateTime dia, int hora)
        => dia.Date < DateTime.Today
        || (dia.Date == DateTime.Today && hora < DateTime.Now.Hour);

    // 1=Lunes .. 7=Domingo
    private static int DiaSemanaNum(DateTime d) => ((int)d.DayOfWeek + 6) % 7 + 1;

    // Carga (o limpia) el horario del veterinario seleccionado en el filtro
    private async Task OnVetFiltroChanged()
    {
        if (vetFiltro == 0)
        {
            horariosVet = new();
            return;
        }
        try { horariosVet = await Task.Run(() => HorarioService.ListarPorVeterinario(vetFiltro)); }
        catch { horariosVet = new(); }
    }

    // Refrigerio real: solo si hay un veterinario seleccionado y la hora cae en su descanso ese día.
    private bool EsRefrigerio(DateTime dia, int hora)
    {
        if (vetFiltro == 0) return false;
        var hor = horariosVet.FirstOrDefault(h => h.DiaSemana == DiaSemanaNum(dia) && h.Activo);
        if (hor?.HoraDescansoInicio is null || hor.HoraDescansoFin is null) return false;
        var t = new TimeOnly(hora, 0);
        return t >= hor.HoraDescansoInicio.Value && t < hor.HoraDescansoFin.Value;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            veterinarios = await Task.Run(() => VeterinarioService.ListarTodos());
            servicios = await Task.Run(() => ServicioService.ListarPorEstado(true));
        }
        catch (Exception ex)
        {
            errorMensaje = "No se pudieron cargar los datos. Inténtalo nuevamente.";
        }
        await CargarCitas();
    }

    private async Task CargarCitas()
    {
        cargando = true;
        errorMensaje = null;
        try
        {
            citas = await Task.Run(() => CitaService.ListarFiltradas(0, semanaInicio, SemanaFin, "", ""));
        }
        catch (Exception ex)
        {
            errorMensaje = "No se pudieron cargar las citas. Inténtalo nuevamente.";
            citas = new();
        }
        finally
        {
            cargando = false;
        }
    }

    // ===== Navegación =====
    private async Task SemanaAnterior() { semanaInicio = semanaInicio.AddDays(-7); await CargarCitas(); }
    private async Task SemanaSiguiente() { semanaInicio = semanaInicio.AddDays(7); await CargarCitas(); }
    private async Task IrHoy() { semanaInicio = InicioSemana(DateTime.Today); await CargarCitas(); }

    // ===== Helpers =====
    private static DateTime InicioSemana(DateTime d)
    {
        int diff = (7 + (int)d.DayOfWeek - (int)DayOfWeek.Monday) % 7;
        return d.Date.AddDays(-diff);
    }

    private string FechaCorta(DateTime d) => $"{d.Day} {MesCorto[d.Month - 1]}";
    private string FechaLarga(DateTime d) => $"{d.Day} {MesCorto[d.Month - 1]} {d.Year}";

    private bool PasaFiltros(Cita c)
        => (vetFiltro == 0 || c.Veterinario?.Id == vetFiltro)
        && estadosSel.Contains(c.Estado);

    private void ToggleEstado(EstadoCita e)
    {
        if (!estadosSel.Remove(e)) estadosSel.Add(e);
    }

    private string EstadosResumen
    {
        get
        {
            if (estadosSel.Count == 0) return "Ninguno";
            if (estadosSel.Count == EstadosTodos.Length) return "Todos los estados";
            if (estadosSel.Count == 1) return EstadoLabel(estadosSel.First());
            return $"{estadosSel.Count} estados";
        }
    }

    private IEnumerable<Cita> CitasEn(DateTime dia, int hora)
        => citas.Where(c => c.FechaHoraInicio.Date == dia.Date && c.FechaHoraInicio.Hour == hora && PasaFiltros(c))
                .OrderBy(c => c.FechaHoraInicio);

    private string NombreCliente(Cita c)
    {
        var cl = c.Mascota?.Cliente;
        return cl is null ? "—" : $"{cl.Nombres} {cl.Apellidos}".Trim();
    }

    private string NombreVet(Veterinario v)
        => $"{v.Nombres} {v.Apellidos}" + (string.IsNullOrWhiteSpace(v.Especialidad) ? "" : $" — {v.Especialidad}");

    private int ModBy(Cita c) => c.Veterinario?.Id ?? (veterinarios.FirstOrDefault()?.Id ?? 0);

    private string CitaClase(EstadoCita e) => "cita-" + e switch
    {
        EstadoCita.PENDIENTE => "pendiente",
        EstadoCita.CONFIRMADA => "confirmada",
        EstadoCita.EN_CONSULTA => "enconsulta",
        EstadoCita.ATENDIDA => "atendida",
        EstadoCita.CANCELADA => "cancelada",
        _ => "noasistio"
    };

    private string CitaBadge(EstadoCita e) => "dt-badge dt-" + e switch
    {
        EstadoCita.PENDIENTE => "pendiente",
        EstadoCita.CONFIRMADA => "confirmada",
        EstadoCita.EN_CONSULTA => "enconsulta",
        EstadoCita.ATENDIDA => "atendida",
        EstadoCita.CANCELADA => "cancelada",
        _ => "noasistio"
    };

    private string EstadoLabel(EstadoCita e) => e switch
    {
        EstadoCita.PENDIENTE => "Pendiente",
        EstadoCita.CONFIRMADA => "Confirmada",
        EstadoCita.EN_CONSULTA => "En consulta",
        EstadoCita.ATENDIDA => "Atendida",
        EstadoCita.CANCELADA => "Cancelada",
        EstadoCita.NO_ASISTIO => "No asistió",
        _ => e.ToString()
    };

    // ===== Crear =====
    private void AbrirCrear()
    {
        clienteSel = 0; mascotaSel = 0; servicioSel = 0; vetSel = 0;
        mascotasCliente = new();
        clienteBusqueda = "";
        clienteDropdownAbierto = false;
        resultadosCliente = new();
        buscandoCliente = false;
        clienteCts?.Cancel();
        fechaNueva = DateTime.Today;
        horaNueva = new TimeOnly(8, 0);
        veterinariosDisponiblesCrear = new();
        cargandoVeterinariosCrear = false;
        errorCrear = null;
        mostrarCrear = true;
    }

    private async Task OnServicioNuevaSel(int value)
    {
        servicioSel = value;
        await ActualizarVeterinariosDisponibles();
    }

    private async Task ActualizarVeterinariosDisponibles()
    {
        vetSel = 0;
        veterinariosDisponiblesCrear = new();

        if (!mostrarCrear || servicioSel <= 0 || fechaNueva.Date < DateTime.Today)
        {
            return;
        }

        cargandoVeterinariosCrear = true;
        try
        {
            var inicio = fechaNueva.Date.Add(horaNueva.ToTimeSpan());
            veterinariosDisponiblesCrear = await Task.Run(() => VeterinarioService.ListarDisponibles(inicio, servicioSel));
        }
        catch
        {
            veterinariosDisponiblesCrear = new();
            errorCrear = "No se pudo consultar la disponibilidad de veterinarios.";
        }
        finally
        {
            cargandoVeterinariosCrear = false;
        }
    }

    // Busca clientes en el servidor al escribir (mínimo 2 caracteres, con debounce).
    // Los resultados se muestran con scroll incremental (<Virtualize>), así no se precarga toda la lista.
    private async Task OnClienteBuscar()
    {
        clienteDropdownAbierto = true;
        // Al cambiar el texto se considera que aún no hay cliente confirmado
        clienteSel = 0;
        mascotaSel = 0;
        mascotasCliente = new();

        var texto = clienteBusqueda.Trim();
        clienteCts?.Cancel();

        if (texto.Length < 2)
        {
            resultadosCliente = new();
            buscandoCliente = false;
            return;
        }

        clienteCts = new CancellationTokenSource();
        var token = clienteCts.Token;
        try
        {
            await Task.Delay(400, token); // debounce
            buscandoCliente = true;
            await InvokeAsync(StateHasChanged);

            var lista = await Task.Run(() => ClienteService.ListarPorNombreApellidoODni(texto));
            if (token.IsCancellationRequested) return;
            resultadosCliente = lista;
        }
        catch (TaskCanceledException) { return; }
        catch
        {
            resultadosCliente = new();
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                buscandoCliente = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task SeleccionarCliente(Cliente c)
    {
        clienteCts?.Cancel();
        clienteSel = c.Id;
        clienteBusqueda = $"{c.Nombres} {c.Apellidos}";
        clienteDropdownAbierto = false;
        resultadosCliente = new();
        mascotaSel = 0;
        var mascotasDelCliente = await Task.Run(() => MascotaService.ListarPorCliente(clienteSel));
        mascotasCliente = mascotasDelCliente.Where(m => m.Activo).ToList(); // solo mascotas activas para agendar
    }

    public void Dispose() => clienteCts?.Cancel();

    private void AbrirCrearEn(DateTime dia, int hora)
    {
        AbrirCrear();
        fechaNueva = dia.Date;
        horaNueva = new TimeOnly(hora, 0);
    }

    private async Task GuardarCita()
    {
        if (procesando) return;
        if (clienteSel == 0 || mascotaSel == 0 || servicioSel == 0 || vetSel == 0)
        {
            errorCrear = "Completa cliente, mascota, servicio y veterinario.";
            return;
        }
        if (fechaNueva.Date < DateTime.Today)
        {
            errorCrear = "No se puede agendar una cita en una fecha anterior a hoy.";
            return;
        }

        var inicio = fechaNueva.Date.Add(horaNueva.ToTimeSpan());
        var servicio = servicios.FirstOrDefault(s => s.Id == servicioSel);
        int dur = servicio?.DuracionMinutos ?? 30;
        var fin = inicio.AddMinutes(dur);

        procesando = true;
        errorCrear = null;
        try
        {
            // Pre-chequeo opcional; si falla (p. ej. el endpoint no responde JSON),
            // continuamos: el backend vuelve a validar horario y cruces al insertar.
            bool disponible = true;
            try { disponible = await Task.Run(() => CitaService.ValidarDisponibilidadSlot(vetSel, inicio, fin)); }
            catch
            {
                errorCrear = "No se pudo validar la disponibilidad del veterinario. Intenta nuevamente.";
                procesando = false;
                return;
            }
            if (!disponible)
            {
                errorCrear = "El veterinario no está disponible en ese horario. Elige otro horario o veterinario.";
                procesando = false;
                return;
            }

            var disponibles = await Task.Run(() => VeterinarioService.ListarDisponibles(inicio, servicioSel));
            if (!disponibles.Any(v => v.Id == vetSel))
            {
                veterinariosDisponiblesCrear = disponibles;
                vetSel = 0;
                errorCrear = "El veterinario seleccionado ya no esta disponible. Elige otro veterinario.";
                procesando = false;
                return;
            }

            var cita = new Cita
            {
                FechaHoraInicio = inicio,
                FechaHoraFin = fin,
                Estado = EstadoCita.PENDIENTE,
                Mascota = new Mascota { Id = mascotaSel },
                Veterinario = new Veterinario { Id = vetSel },
                Servicio = new Servicio { Id = servicioSel }
            };

            int r = await Task.Run(() => CitaService.InsertarCita(cita));
            if (r > 0)
            {
                Toasts.Exito("Cita agendada correctamente.");
                mostrarCrear = false;
                await CargarCitas();
            }
            else
            {
                errorCrear = "No se pudo agendar la cita. Verifica que el veterinario tenga horario ese día y que no se cruce con otra cita.";
            }
        }
        catch (Exception ex)
        {
            errorCrear = "No se pudo agendar la cita. Inténtalo nuevamente.";
        }
        finally
        {
            procesando = false;
        }
    }

    // ===== Detalle =====
    private void AbrirDetalle(Cita c) => citaDetalle = c;

    private void AbrirReprogramar(Cita c)
    {
        citaAccion = c;
        reprogFecha = c.FechaHoraInicio.Date;
        reprogHora = TimeOnly.FromDateTime(c.FechaHoraInicio);
        reprogMotivo = "";
        citaDetalle = null;
        mostrarReprogramar = true;
    }

    private void AbrirCambiarVet(Cita c)
    {
        citaAccion = c;
        cambiarVetSel = 0;
        citaDetalle = null;
        mostrarCambiarVet = true;
    }

    private void AbrirCancelar(Cita c)
    {
        citaAccion = c;
        cancelarMotivo = "";
        citaDetalle = null;
        mostrarCancelar = true;
    }

    private async Task ConfirmarDesdeDetalle(Cita c)
    {
        await Ejecutar(() => CitaService.ConfirmarCita(c.Id, ModBy(c)), "Cita confirmada correctamente.", cerrarDetalle: true);
    }

    private async Task ConfirmarReprogramar()
    {
        if (procesando || citaAccion is null) return;
        if (reprogFecha.Date < DateTime.Today)
        {
            Toasts.Error("No se puede reprogramar la cita a una fecha anterior a hoy.");
            return;
        }
        var inicio = reprogFecha.Date.Add(reprogHora.ToTimeSpan());
        int dur = servicios.FirstOrDefault(s => s.Id == (citaAccion.Servicio?.Id ?? 0))?.DuracionMinutos ?? 30;
        var fin = inicio.AddMinutes(dur);
        string motivo = string.IsNullOrWhiteSpace(reprogMotivo) ? "Reprogramación" : reprogMotivo.Trim();

        await Ejecutar(() => CitaService.Reprogramar(citaAccion.Id, inicio, fin, motivo, ModBy(citaAccion)),
                       "Cita reprogramada correctamente.", () => mostrarReprogramar = false);
    }

    private async Task ConfirmarCambiarVet()
    {
        if (procesando || citaAccion is null) return;
        if (cambiarVetSel == 0)
        {
            Toasts.Error("Selecciona un veterinario.");
            return;
        }
        await Ejecutar(() => CitaService.CambiarVeterinario(citaAccion.Id, cambiarVetSel, ModBy(citaAccion)),
                       "Veterinario actualizado correctamente.", () => mostrarCambiarVet = false);
    }

    private async Task ConfirmarCancelar()
    {
        if (procesando || citaAccion is null) return;
        if (string.IsNullOrWhiteSpace(cancelarMotivo))
        {
            Toasts.Error("Indica el motivo de la cancelación.");
            return;
        }
        await Ejecutar(() => CitaService.CancelarCita(citaAccion.Id, cancelarMotivo.Trim(), ModBy(citaAccion)),
                       "Cita cancelada correctamente.", () => mostrarCancelar = false);
    }

    // Ejecuta una acción que devuelve int (1 = ok), muestra toast y recarga
    private async Task Ejecutar(Func<int> accion, string okMsg, Action? cerrar = null, bool cerrarDetalle = false)
    {
        if (procesando) return;
        procesando = true;
        try
        {
            int r = await Task.Run(accion);
            if (r == 1)
            {
                Toasts.Exito(okMsg);
                cerrar?.Invoke();
                if (cerrarDetalle) citaDetalle = null;
                await CargarCitas();
            }
            else
            {
                Toasts.Error("No se pudo completar la operación. Inténtalo nuevamente.");
            }
        }
        catch (Exception ex)
        {
            Toasts.Error("Ocurrió un error. Inténtalo nuevamente.");
        }
        finally
        {
            procesando = false;
        }
    }
