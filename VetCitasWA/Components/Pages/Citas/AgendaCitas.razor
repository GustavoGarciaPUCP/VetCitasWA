    private string ReprogramarHint
    {
        get
        {
            if (citaAccion is null) return "";
            var dur = DuracionCita(citaAccion);
            var vet = citaAccion.Veterinario is null ? "el veterinario" : NombreVet(citaAccion.Veterinario);
            return $"Se muestran bloques de {MinutosPasoAgenda} min dentro del horario de {vet}, respetando la duracion del servicio ({dur} min), descansos y citas existentes.";
        }
    }

    private async Task CargarSlotsReprogramacion()
    {
        reprogInicioSeleccionado = null;
        slotsReprogramacion = new();
        citasDiaReprogramacion = new();
        errorReprogramar = null;

        if (citaAccion?.Veterinario is null || citaAccion.Servicio is null || citaAccion.Mascota is null)
        {
            errorReprogramar = "No se pudo cargar la informacion de la cita.";
            return;
        }

        if (reprogFecha.Date < DateTime.Today)
        {
            errorReprogramar = "No se puede reprogramar a una fecha anterior a hoy.";
            return;
        }

        cargandoSlotsReprogramacion = true;
        try
        {
            var dia = reprogFecha.Date;
            citasDiaReprogramacion = await Task.Run(() => CitaService.ListarFiltradas(0, dia, dia, "", ""));
            slotsReprogramacion = CalcularSlotsReprogramacion();

            var actual = citaAccion.FechaHoraInicio;
            if (actual.Date == dia && slotsReprogramacion.Contains(actual))
            {
                SeleccionarSlotReprogramacion(actual);
            }
        }
        catch (Exception ex)
        {
            errorReprogramar = string.IsNullOrWhiteSpace(ex.Message)
                ? "No se pudieron consultar los horarios disponibles."
                : ex.Message;
        }
        finally
        {
            cargandoSlotsReprogramacion = false;
        }
    }

    private List<DateTime> CalcularSlotsReprogramacion()
    {
        if (citaAccion?.Veterinario is null || citaAccion.Servicio is null || citaAccion.Mascota is null)
        {
            return new();
        }

        var idVeterinario = citaAccion.Veterinario.Id;
        var idMascota = citaAccion.Mascota.Id;
        var idCliente = citaAccion.Mascota.Cliente?.Id ?? 0;
        var duracion = DuracionCita(citaAccion);
        var diaSemana = DiaSemanaNum(reprogFecha);
        var maxHora = new TimeOnly(HoraCierreMaxima, 59);

        var horarios = horariosAgenda
            .Where(h => h.Activo && h.Veterinario?.Id == idVeterinario && h.DiaSemana == diaSemana)
            .OrderBy(h => h.HoraInicio)
            .ToList();

        var slots = new List<DateTime>();

        foreach (var horario in horarios)
        {
            var inicioHorario = horario.HoraInicio;
            var finHorario = horario.HoraFin > maxHora ? maxHora : horario.HoraFin;

            for (var hora = inicioHorario; hora.AddMinutes(duracion) <= finHorario; hora = hora.AddMinutes(MinutosPasoAgenda))
            {
                var inicio = reprogFecha.Date.Add(hora.ToTimeSpan());
                var fin = inicio.AddMinutes(duracion);

                if (inicio < DateTime.Now) continue;
                if (CruzaDescanso(inicio, fin, horario)) continue;
                if (CruzaConCitasExistentes(inicio, fin, idVeterinario, idMascota, idCliente, citaAccion.Id)) continue;

                slots.Add(inicio);
            }
        }

        return slots.Distinct().OrderBy(x => x).ToList();
    }

    private int DuracionCita(Cita c)
    {
        var servicioId = c.Servicio?.Id ?? 0;
        return servicios.FirstOrDefault(s => s.Id == servicioId)?.DuracionMinutos
            ?? c.Servicio?.DuracionMinutos
            ?? Math.Max(15, (int)Math.Round((c.FechaHoraFin - c.FechaHoraInicio).TotalMinutes));
    }

    private static bool CruzaDescanso(DateTime inicio, DateTime fin, HorarioVeterinario horario)
    {
        if (horario.HoraDescansoInicio is null || horario.HoraDescansoFin is null) return false;

        var descansoInicio = inicio.Date.Add(horario.HoraDescansoInicio.Value.ToTimeSpan());
        var descansoFin = inicio.Date.Add(horario.HoraDescansoFin.Value.ToTimeSpan());
        return RangosSeCruzan(inicio, fin, descansoInicio, descansoFin);
    }

    private bool CruzaConCitasExistentes(DateTime inicio, DateTime fin, int idVeterinario, int idMascota, int idCliente, int idCitaActual)
    {
        return citasDiaReprogramacion.Any(c =>
            c.Id != idCitaActual
            && EsEstadoBloqueante(c.Estado)
            && (
                c.Veterinario?.Id == idVeterinario
                || c.Mascota?.Id == idMascota
                || (idCliente > 0 && c.Mascota?.Cliente?.Id == idCliente)
            )
            && RangosSeCruzan(inicio, fin, c.FechaHoraInicio, c.FechaHoraFin));
    }

    private static bool EsEstadoBloqueante(EstadoCita estado)
        => estado == EstadoCita.PENDIENTE
        || estado == EstadoCita.CONFIRMADA
        || estado == EstadoCita.EN_CONSULTA;

    private static bool RangosSeCruzan(DateTime inicioA, DateTime finA, DateTime inicioB, DateTime finB)
        => inicioA < finB && finA > inicioB;

    private async Task ConfirmarReprogramar()
    {
        if (procesando || citaAccion is null) return;
        errorReprogramar = null;
        if (reprogFecha.Date < DateTime.Today)
        {
            errorReprogramar = "No se puede reprogramar la cita a una fecha anterior a hoy.";
            return;
        }
        if (reprogInicioSeleccionado is null)
        {
            errorReprogramar = "Selecciona un horario disponible.";
            return;
        }

        var inicio = reprogInicioSeleccionado.Value;
        int dur = DuracionCita(citaAccion);
        var fin = inicio.AddMinutes(dur);
        string motivo = string.IsNullOrWhiteSpace(reprogMotivo) ? "Reprogramación" : reprogMotivo.Trim();

        var idVeterinario = citaAccion.Veterinario?.Id ?? 0;

        if (idVeterinario <= 0)
        {
            errorReprogramar = "No se pudo identificar el veterinario actual de la cita.";
            return;
        }

        procesando = true;
        try
        {
            var resultado = await Task.Run(() => CitaService.ReprogramarSeguro(citaAccion.Id, inicio, fin, motivo, ModBy(citaAccion)));
            if (resultado.Ok)
            {
                Toasts.Exito("Cita reprogramada correctamente.");
                mostrarReprogramar = false;
                await CargarCitas();
            }
            else
            {
                await CargarSlotsReprogramacion();
                errorReprogramar = string.IsNullOrWhiteSpace(resultado.Mensaje)
                    ? "No se pudo reprogramar la cita."
                    : resultado.Mensaje;
            }
        }
        finally
        {
            procesando = false;
        }
    }

    private async Task ConfirmarCambiarVet()
    {
        if (procesando || citaAccion is null) return;
        if (cambiarVetSel == 0)
        {
            Toasts.Error("Selecciona un veterinario.");
            return;
        }
        if (!veterinariosDisponiblesCambio.Any(v => v.Id == cambiarVetSel))
        {
            Toasts.Error("El veterinario seleccionado ya no esta disponible para esta cita.");
            await CargarVeterinariosDisponiblesCambio();
            return;
        }
        await Ejecutar(() => CitaService.CambiarVeterinario(citaAccion.Id, cambiarVetSel, ModBy(citaAccion)),
                       "Veterinario actualizado correctamente.", () => mostrarCambiarVet = false);
    }

    private async Task CargarVeterinariosDisponiblesCambio()
    {
        if (citaAccion?.Servicio is null)
        {
            veterinariosDisponiblesCambio = new();
            return;
        }

        cargandoVeterinariosCambio = true;
        try
        {
            var disponibles = await Task.Run(() => VeterinarioService.ListarDisponibles(citaAccion.FechaHoraInicio, citaAccion.Servicio.Id));
            var idActual = citaAccion.Veterinario?.Id ?? 0;
            veterinariosDisponiblesCambio = disponibles
                .Where(v => v.Id != idActual)
                .OrderBy(NombreVet)
                .ToList();
        }
        catch
        {
            veterinariosDisponiblesCambio = new();
            Toasts.Error("No se pudo consultar veterinarios disponibles.");
        }
        finally
        {
            cargandoVeterinariosCambio = false;
        }
    }

    private async Task ConfirmarCancelar()
    {
        if (procesando || citaAccion is null) return;
        if (string.IsNullOrWhiteSpace(cancelarMotivo))
        {
            Toasts.Error("Indica el motivo de la cancelación.");
            return;
        }
        await Ejecutar(() => CitaService.CancelarCita(citaAccion.Id, cancelarMotivo.Trim(), ModBy(citaAccion)),
                       "Cita cancelada correctamente.", () => mostrarCancelar = false);
    }

    // Ejecuta una acción que devuelve int (1 = ok), muestra toast y recarga
    private async Task Ejecutar(Func<int> accion, string okMsg, Action? cerrar = null, bool cerrarDetalle = false)
    {
        if (procesando) return;
        procesando = true;
        try
        {
            int r = await Task.Run(accion);
            if (r == 1)
            {
                Toasts.Exito(okMsg);
                cerrar?.Invoke();
                if (cerrarDetalle) citaDetalle = null;
                await CargarCitas();
            }
            else
            {
                Toasts.Error("No se pudo completar la operación. Inténtalo nuevamente.");
            }
        }
        catch (Exception ex)
        {
            Toasts.Error(string.IsNullOrWhiteSpace(ex.Message)
                ? "Ocurrio un error. Intentalo nuevamente."
                : ex.Message);
        }
        finally
        {
            procesando = false;
        }
    }
