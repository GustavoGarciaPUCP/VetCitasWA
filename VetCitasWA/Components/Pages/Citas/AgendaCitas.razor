@page "/agenda-citas"
@using VetCitasWA.Servicios.Modelo.Cita
@using VetCitasWA.Servicios.Modelo.Cliente
@using VetCitasWA.Servicios.Modelo.Usuario
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.CitaRS.CitaRestService CitaService
@inject VetCitasWA.Servicios.REST.UsuarioRS.VeterinarioRestService VetService

<PageTitle>Agenda de Citas - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Agenda de Citas</span>
</SectionContent>

@*
    Checkboxes invisibles que controlan los modales.
    "agenda-nueva-modal" abre el formulario de Nueva Cita; los seis
    "agenda-det-*" abren un modal de detalle distinto según el estado.
*@
<input type="checkbox" id="agenda-nueva-modal"        class="ac-modal-toggle" />
<input type="checkbox" id="agenda-det-pendiente"      class="ac-modal-toggle" />
<input type="checkbox" id="agenda-det-confirmada"     class="ac-modal-toggle" />
<input type="checkbox" id="agenda-det-enconsulta"     class="ac-modal-toggle" />
<input type="checkbox" id="agenda-det-atendida"       class="ac-modal-toggle" />
<input type="checkbox" id="agenda-det-cancelada"      class="ac-modal-toggle" />
<input type="checkbox" id="agenda-det-noasistio"      class="ac-modal-toggle" />

<div class="page-section">

    <div class="page-head">
        <h1 class="page-title">Gestión de Citas - Vista Semanal</h1>
        <label for="agenda-nueva-modal" class="btn-new-cita">
            <span class="btn-plus" aria-hidden="true">+</span>
            <span>Nueva Cita</span>
        </label>
    </div>

    @* ----- Toolbar superior: filtros + rango de fechas ----- *@
    <div class="cal-toolbar">

        @* === Rango de fechas: Desde — Hasta === *@
        <div class="tb-range" role="group" aria-label="Filtro de fechas">
            <div class="tb-field tb-field-date">
                <label class="tb-label" for="dateFrom">Desde</label>
                <div class="tb-control">
                    <input id="dateFrom" type="date" class="tb-input" value="@fechaDesde.ToString("yyyy-MM-dd")" @onchange="OnDesdeChanged" />
                </div>
            </div>
            <span class="tb-range-sep" aria-hidden="true">→</span>
            <div class="tb-field tb-field-date">
                <label class="tb-label" for="dateTo">Hasta</label>
                <div class="tb-control">
                    <input id="dateTo" type="date" class="tb-input" value="@fechaHasta.ToString("yyyy-MM-dd")" @onchange="OnHastaChanged" />
                </div>
            </div>
        </div>

        @* === Presets rápidos === *@
        <div class="tb-field tb-field-presets">
            <label class="tb-label">Presets</label>
            <div class="tb-presets">
                <button type="button" class="tb-preset">Hoy</button>
                <button type="button" class="tb-preset tb-preset-active">Esta semana</button>
                <button type="button" class="tb-preset">Próx. 7 días</button>
                <button type="button" class="tb-preset">Este mes</button>
            </div>
        </div>

        @* === Veterinario === *@
        <div class="tb-field tb-field-vet">
            <label class="tb-label" for="vetFilter">Veterinario</label>
            <div class="tb-control">
                <select id="vetFilter" class="tb-select" @onchange="OnVetChanged">
                    <option value="0">Todos</option>
                    @foreach (var vet in listaVeterinarios)
                    {
                        <option value="@vet.Id">@vet.Nombres @vet.Apellidos</option>
                    }
                </select>
            </div>
        </div>

        @* === Estado === *@
        <div class="tb-field tb-field-state">
            <label class="tb-label" for="stateFilter">Estado</label>
            <div class="tb-control">
                <select id="stateFilter" class="tb-select" @onchange="OnEstadoChanged">
                    <option value="">Todos</option>
                    <option value="PENDIENTE">Pendiente</option>
                    <option value="CONFIRMADA">Confirmada</option>
                    <option value="EN_CONSULTA">En consulta</option>
                    <option value="ATENDIDA">Atendida</option>
                    <option value="CANCELADA">Cancelada</option>
                    <option value="NO_ASISTIO">No asistió</option>
                </select>
            </div>
        </div>

        @* === Navegación rápida === *@
        <div class="tb-field tb-field-nav">
            <label class="tb-label">Navegación</label>
            <div class="tb-nav">
                <button type="button" class="tb-nav-btn" aria-label="Período anterior">‹</button>
                <button type="button" class="tb-nav-btn tb-nav-today">Hoy</button>
                <button type="button" class="tb-nav-btn" aria-label="Período siguiente">›</button>
            </div>
        </div>

    </div>

    @* Resumen del rango activo *@
    <div class="cal-range-summary">
        <span class="range-label">Mostrando:</span>
        <strong class="range-value">@fechaDesde.ToString("dd MMM yyyy") — @fechaHasta.ToString("dd MMM yyyy")</strong>
        <span class="range-sub">(@((fechaHasta - fechaDesde).Days + 1) días · @listaCitas.Count citas)</span>
    </div>

    @* ----- Grilla del calendario ----- *@
    <div class="cal-card">
        <div class="cal-grid">

            @* Header con nombres de días (Lunes a Viernes de la semana mostrada) *@
            <div class="cal-cell cal-head cal-corner"></div>
            @foreach (var dia in DiasSemana)
            {
                <div class="cal-cell cal-head">@NombreDia(dia)<span class="cal-head-date">@dia.ToString("dd MMM")</span></div>
            }

            @* Filas por hora (08:00 a 16:00); 13:00 es refrigerio *@
            @foreach (var hora in Horas)
            {
                <div class="cal-cell cal-time">@(hora.ToString("00")):00</div>

                @if (hora == 13)
                {
                    <div class="cal-cell cal-break cal-break-start">REFRIGERIO (No Disponible)</div>
                    <div class="cal-cell cal-break"></div>
                    <div class="cal-cell cal-break"></div>
                    <div class="cal-cell cal-break"></div>
                    <div class="cal-cell cal-break"></div>
                }
                else
                {
                    @foreach (var dia in DiasSemana)
                    {
                        var cita = listaCitas.FirstOrDefault(c =>
                            c.FechaHoraInicio.Date == dia.Date && c.FechaHoraInicio.Hour == hora);
                        <div class="cal-cell cal-slot">
                            @if (cita != null)
                            {
                                <label for="@ModalDetalleId(cita.Estado)" class="cita @CssEstado(cita.Estado)">
                                    <div class="cita-title">@(cita.Mascota?.Nombre) (@EspecieTexto(cita.Mascota))</div>
                                    <div class="cita-sub">@(cita.Mascota?.Cliente?.Nombres) @(cita.Mascota?.Cliente?.Apellidos) · @(cita.Servicio?.Nombre)</div>
                                    <div class="cita-foot">@cita.FechaHoraInicio.ToString("HH:mm") · @EstadoTexto(cita.Estado)</div>
                                </label>
                            }
                            else
                            {
                                <label for="agenda-nueva-modal" class="slot-trigger" aria-label="Nueva cita"></label>
                            }
                        </div>
                    }
                }
            }

        </div>
    </div>

    @* ----- Leyenda de estados ----- *@
    <div class="cal-legend">
        <span class="legend-item"><span class="dot dot-pendiente"></span> Pendiente</span>
        <span class="legend-item"><span class="dot dot-confirmada"></span> Confirmada</span>
        <span class="legend-item"><span class="dot dot-enconsulta"></span> En consulta</span>
        <span class="legend-item"><span class="dot dot-atendida"></span> Atendida</span>
        <span class="legend-item"><span class="dot dot-cancelada"></span> Cancelada</span>
        <span class="legend-item"><span class="dot dot-noasistio"></span> No asistió</span>
    </div>

</div>

@* ============================================================ *@
@* =============== MODAL: Agendar Nueva Cita ================= *@
@* ============================================================ *@
<div class="ac-modal-backdrop ac-modal-nueva">
    <div class="ac-modal-card" role="dialog" aria-modal="true" aria-labelledby="nueva-title">
        <header class="ac-modal-head">
            <div>
                <h2 id="nueva-title" class="ac-modal-title">Agendar Nueva Cita</h2>
                <p class="ac-modal-subtitle">Completa los datos para reservar el slot</p>
            </div>
            <label for="agenda-nueva-modal" class="ac-modal-close" aria-label="Cerrar">×</label>
        </header>

        <div class="ac-modal-body">

            <div class="ff">
                <label class="ff-label" for="m-client">Cliente</label>
                <input id="m-client" type="text" class="ff-input" placeholder="Buscar por nombre o DNI..." />
                <span class="ff-hint">Busca por DNI (8 dígitos) o nombre</span>
            </div>

            <div class="ff">
                <label class="ff-label" for="m-pet">Mascota</label>
                <div class="ff-select-wrap">
                    <select id="m-pet" class="ff-select">
                        <option value="" selected disabled hidden>Primero selecciona un cliente...</option>
                        <option>Max (Perro - Golden Retriever)</option>
                        <option>Thor (Perro - Pastor Alemán)</option>
                    </select>
                </div>
                <span class="ff-hint">Solo las mascotas activas del cliente</span>
            </div>

            <div class="ff">
                <label class="ff-label" for="m-srv">Servicio</label>
                <div class="ff-select-wrap">
                    <select id="m-srv" class="ff-select">
                        <option value="" selected disabled hidden>Seleccionar servicio...</option>
                        <option>Consulta General — 30 min · S/ 50.00</option>
                        <option>Esterilización Canina — 120 min · S/ 250.00</option>
                        <option>Vacunación Múltiple — 15 min · S/ 35.00</option>
                        <option>Cirugía Menor — 60 min · S/ 300.00</option>
                        <option>Control Post-Operatorio — 20 min · S/ 30.00</option>
                    </select>
                </div>
                <span class="ff-hint">Muestra duración y precio referencial</span>
            </div>

            <div class="ff ff-row">
                <div class="ff-col">
                    <label class="ff-label" for="m-date">Fecha</label>
                    <input id="m-date" type="date" class="ff-input" value="2026-05-13" />
                </div>
                <div class="ff-col">
                    <label class="ff-label" for="m-time">Hora</label>
                    <input id="m-time" type="time" class="ff-input" value="10:00" step="900" />
                </div>
            </div>

            <div class="ff">
                <label class="ff-label" for="m-vet">Veterinario</label>
                <div class="ff-select-wrap">
                    <select id="m-vet" class="ff-select">
                        @foreach (var vet in listaVeterinarios)
                        {
                            <option value="@vet.Id">@vet.Nombres @vet.Apellidos</option>
                        }
                    </select>
                </div>
                <span class="ff-hint">Se valida disponibilidad y horario</span>
            </div>

        </div>

        <footer class="ac-modal-foot">
            <button type="button" class="btn-modal btn-modal-primary">Confirmar Cita</button>
        </footer>
    </div>
</div>

@* ============================================================ *@
@* === MODALES DE DETALLE (uno por estado de cita) ============ *@
