            <div class="cal-cell cal-head">Viernes<span class="cal-head-date">16 May</span></div>
            <div class="cal-cell cal-head">Sábado<span class="cal-head-date">17 May</span></div>
            <div class="cal-cell cal-head">Domingo<span class="cal-head-date">18 May</span></div>

            @* === 08:00 === *@
            <div class="cal-cell cal-time">08:00</div>
