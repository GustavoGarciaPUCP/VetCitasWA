@page "/mis-horarios"

<PageTitle>Mis Horarios - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Mis Horarios</span>
</SectionContent>

@*
    Un toggle por estado de cita: cada cita del calendario abre el modal
    que corresponde a su estado, con la información y CTAs específicos.
*@
<input type="checkbox" id="mh-modal-pendiente"   class="mh-modal-toggle" />
<input type="checkbox" id="mh-modal-confirmada"  class="mh-modal-toggle" />
<input type="checkbox" id="mh-modal-enconsulta"  class="mh-modal-toggle" />
<input type="checkbox" id="mh-modal-atendida"    class="mh-modal-toggle" />
