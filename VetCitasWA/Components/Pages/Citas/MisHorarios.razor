            <label for="cancelar-cita-modal" class="btn-mh btn-mh-danger-ghost recep-only">Cancelar</label>
            <label for="reprogramar-cita-modal" class="btn-mh btn-mh-secondary recep-only">Reprogramar</label>
        </footer>
    </div>
</div>

