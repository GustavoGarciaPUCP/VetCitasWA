@* ----- 1) PENDIENTE: cliente aún no ha confirmado ----- *@
<div class="mh-modal-backdrop" data-state="pendiente">
    <div class="mh-modal-card" role="dialog" aria-modal="true" aria-labelledby="mh-title-pendiente">
        <header class="mh-modal-head">
            <div class="mh-head-info">
                <h2 id="mh-title-pendiente" class="mh-modal-title">Cita #1003</h2>
