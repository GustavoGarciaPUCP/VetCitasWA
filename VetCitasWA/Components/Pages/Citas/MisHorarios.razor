                <span class="legend-item"><span class="legend-swatch legend-break-swatch"></span> Refrigerio</span>
                <span class="legend-item"><span class="legend-swatch legend-off-swatch"></span> Indisponible</span>
            </div>
        </div>
        <div class="legend-group">
            <h3 class="legend-title">Estado de citas</h3>
            <div class="legend-items">
                <span class="legend-item"><span class="legend-dot dot-pendiente"></span> Pendiente</span>
                <span class="legend-item"><span class="legend-dot dot-confirmada"></span> Confirmada</span>
                <span class="legend-item"><span class="legend-dot dot-enconsulta"></span> En consulta</span>
