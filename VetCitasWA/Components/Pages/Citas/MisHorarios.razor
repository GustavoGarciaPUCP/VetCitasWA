@page "/mis-horarios"
@using VetCitasWA.Servicios.Modelo.Cita
@using VetCitasWA.Servicios.Modelo.Cliente
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.CitaRS.CitaRestService CitaService

<PageTitle>Mis Horarios - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Mis Horarios</span>
</SectionContent>

@*
    Un toggle por estado de cita: cada cita del calendario abre el modal
    que corresponde a su estado, con la información y CTAs específicos.
*@
<input type="checkbox" id="mh-modal-pendiente"   class="mh-modal-toggle" />
<input type="checkbox" id="mh-modal-confirmada"  class="mh-modal-toggle" />
<input type="checkbox" id="mh-modal-enconsulta"  class="mh-modal-toggle" />
<input type="checkbox" id="mh-modal-atendida"    class="mh-modal-toggle" />
<input type="checkbox" id="mh-modal-cancelada"   class="mh-modal-toggle" />
<input type="checkbox" id="mh-modal-noasistio"   class="mh-modal-toggle" />

<div class="page-section">

    <div class="page-head">
        <h1 class="page-title">Mi Agenda Semanal — Dr. Carlos</h1>
        <p class="page-subtitle">Tu horario laboral y las citas programadas para esta semana. Hover sobre una cita para ver detalles.</p>
    </div>

    @* ================= Toolbar superior ================= *@
    <div class="cal-toolbar">
        <div class="tb-field">
            <label class="tb-label" for="weekPicker">Semana</label>
            <div class="tb-control">
                <input id="weekPicker" type="text" class="tb-input" value="Semana del 12 al 18 de Mayo 2026" readonly />
                <span class="tb-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z" />
                    </svg>
                </span>
            </div>
        </div>
        <div class="tb-field tb-field-nav">
            <label class="tb-label">Navegación rápida</label>
            <div class="tb-nav">
                <button type="button" class="tb-nav-btn" aria-label="Semana anterior">‹ Anterior</button>
                <button type="button" class="tb-nav-btn tb-nav-today">Hoy</button>
                <button type="button" class="tb-nav-btn" aria-label="Semana siguiente">Siguiente ›</button>
            </div>
        </div>
    </div>

