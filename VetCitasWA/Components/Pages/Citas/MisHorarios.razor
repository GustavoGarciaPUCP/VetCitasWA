            </div>
            <label for="mh-modal-pendiente" class="mh-modal-close" aria-label="Cerrar">×</label>
        </header>

        <div class="mh-modal-body">

            <div class="mh-banner mh-banner-warn">
                <strong>Cliente aún no ha confirmado.</strong>
                Sugerimos enviar un recordatorio antes del día de la cita.
            </div>

            <div class="mh-section">
                <h3 class="mh-section-title">Mascota</h3>
                <div class="mh-row"><span class="mh-label">Nombre</span><span class="mh-value">Luna</span></div>
                <div class="mh-row"><span class="mh-label">Especie · Raza</span><span class="mh-value">Gato · Siamés</span></div>
                <div class="mh-row"><span class="mh-label">Edad</span><span class="mh-value">2 años</span></div>
            </div>

            <div class="mh-section">
                <h3 class="mh-section-title">Cliente</h3>
                <div class="mh-row"><span class="mh-label">Nombre</span><span class="mh-value">María García</span></div>
                <div class="mh-row"><span class="mh-label">Teléfono</span><span class="mh-value">+51 987 612 543</span></div>
            </div>

            <div class="mh-section">
                <h3 class="mh-section-title">Servicio &amp; Programación</h3>
                <div class="mh-row"><span class="mh-label">Servicio</span><span class="mh-value">Vacunación</span></div>
                <div class="mh-row"><span class="mh-label">Duración</span><span class="mh-value">15 min</span></div>
                <div class="mh-row"><span class="mh-label">Fecha</span><span class="mh-value">Martes 13/05/2026</span></div>
                <div class="mh-row"><span class="mh-label">Hora</span><span class="mh-value">11:30 — 11:45</span></div>
            </div>

        </div>

        @* Cancelar y Reprogramar requieren rol de Recepcionista — el veterinario solo ve el detalle. *@
