@page "/clientes-mascotas"
@using VetCitasWA.Servicios.Modelo.Cliente
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.ClienteRS.ClienteRestService ClienteService
@inject VetCitasWA.Servicios.REST.ClienteRS.MascotaRestService MascotaService

<PageTitle>Clientes y Mascotas - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Clientes y Mascotas</span>
</SectionContent>

<div class="page-section">

    @* ================= Cabecera: título + buscador + botón nuevo ================= *@
    <div class="page-head">
        <h1 class="page-title">Clientes y Mascotas</h1>

        <div class="page-head-tools">
            <div class="search-box">
                <span class="search-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                    </svg>
                </span>
                <input type="text" class="search-input" placeholder="Buscar..." @oninput="OnBuscar" />
            </div>

            @* Botones de "Nuevo …": el visible depende del tab activo
               Y de tener rol recepcionista. La regla de visibilidad
               vive en el CSS de esta página (combina :has() + role class). *@
            <label for="cliente-form-modal" class="btn-new btn-new-cliente">
                <span class="btn-plus" aria-hidden="true">+</span>
                <span>Nuevo Cliente</span>
            </label>
            <label for="mascota-form-modal" class="btn-new btn-new-mascota">
                <span class="btn-plus" aria-hidden="true">+</span>
                <span>Nueva Mascota</span>
            </label>
        </div>
    </div>

    @* ================= Panel con tabs (Clientes / Mascotas) ================= *@
    <section class="panel">

        @* Radios invisibles que controlan el tab activo *@
        <input type="radio" name="cm-tab" id="cm-tab-clientes" class="cm-tab-radio" />
        <input type="radio" name="cm-tab" id="cm-tab-mascotas" class="cm-tab-radio" checked />

        <div class="tabs" role="tablist">
            <label for="cm-tab-clientes" class="tab tab-link tab-clientes" role="tab">CLIENTES</label>
            <label for="cm-tab-mascotas" class="tab tab-link tab-mascotas" role="tab">MASCOTAS</label>
        </div>

        @* =============== TAB CLIENTES =============== *@
        <div class="table-wrapper tab-panel tab-panel-clientes">
            <table class="vet-table">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>DNI</th>
                        <th>Teléfono</th>
                        <th>Correo</th>
                        <th>Mascotas</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (listaClientes == null || !listaClientes.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center" style="padding: 2rem;">
                                <em>Cargando datos desde el servidor o no se encontraron resultados...</em>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var c in listaClientes)
                        {
                            <tr>
                                <td data-label="Cliente">
                                    <div class="pet-cell">
                                        <span class="client-avatar" aria-hidden="true">@GetIniciales(c.Nombres, c.Apellidos)</span>
                                        <span class="pet-name">@c.Nombres @c.Apellidos</span>
                                    </div>
                                </td>
                                <td data-label="DNI">@c.Dni</td>
                                <td data-label="Teléfono">@c.Telefono</td>
                                <td data-label="Correo">@c.Email</td>
                                <td data-label="Mascotas">
                                    <span class="pet-count-badge">@(c.Mascotas?.Count ?? 0)</span>
                                    <span class="pet-list-inline">@(c.Mascotas != null ? string.Join(", ", c.Mascotas.Select(m => m.Nombre)) : "")</span>
                                </td>
                                <td data-label="Acciones">
                                    <div class="row-actions">
                                        <a href="/clientes-mascotas/cliente" class="btn-eye" aria-label="Ver detalle">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                                            </svg>
                                        </a>
                                        <label for="cliente-form-modal" class="btn-pencil recep-only" aria-label="Editar cliente">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" /></svg>
                                        </label>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* =============== TAB MASCOTAS =============== *@
        <div class="table-wrapper tab-panel tab-panel-mascotas">
            <table class="vet-table">
                <thead>
                    <tr>
                        <th>Mascota</th>
                        <th>Especie</th>
                        <th>Raza</th>
                        <th>Edad</th>
                        <th>Peso</th>
                        <th>Dueño</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (listaMascotas == null || !listaMascotas.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center" style="padding: 2rem;">
                                <em>Cargando datos desde el servidor o no se encontraron resultados...</em>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var m in listaMascotas)
                        {
                            bool esPerro = m.Especie == TipoEspecie.PERRO;
                            <tr>
                                <td data-label="Mascota">
                                    <div class="pet-cell">
                                        <span class="pet-avatar @(esPerro ? "pet-dog" : "pet-cat")" aria-hidden="true">@(string.IsNullOrWhiteSpace(m.Nombre) ? "?" : m.Nombre.Substring(0, 1).ToUpper())</span>
                                        <span class="pet-name">@m.Nombre</span>
                                    </div>
                                </td>
                                <td data-label="Especie">
                                    <span class="species @(esPerro ? "species-dog" : "species-cat")">@(esPerro ? "Perro" : "Gato")</span>
                                </td>
                                <td data-label="Raza">@m.Raza</td>
                                <td data-label="Edad">@CalcularEdad(m.FechaNacimiento)</td>
                                <td data-label="Peso">@m.Peso kg</td>
                                <td data-label="Dueño">@(m.Cliente != null ? $"{m.Cliente.Nombres} {m.Cliente.Apellidos}" : "")</td>
                                <td data-label="Acciones">
                                    <div class="row-actions">
                                        <a href="/clientes-mascotas/detalle" class="btn-eye" aria-label="Ver detalle">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                                            </svg>
                                        </a>
                                        <label for="mascota-form-modal" class="btn-pencil recep-only" aria-label="Editar mascota">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" /></svg>
                                        </label>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

    </section>

</div>

@code {
    private List<Cliente> listaClientes = new();
    private List<Mascota> listaMascotas = new();

    protected override void OnInitialized()
    {
        listaClientes = ClienteService.ListarTodos();
        listaMascotas = MascotaService.ListarTodos();
    }

    private void OnBuscar(ChangeEventArgs e)
    {
        string texto = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(texto))
        {
            listaClientes = ClienteService.ListarTodos();
            listaMascotas = MascotaService.ListarTodos();
        }
        else
        {
            listaClientes = ClienteService.ListarPorNombreApellidoODni(texto);
            listaMascotas = MascotaService.ListarPorNombreODueno(texto);
        }
    }

    private string GetIniciales(string? nombres, string? apellidos)
    {
        string n = !string.IsNullOrWhiteSpace(nombres) ? nombres.Substring(0, 1).ToUpper() : "";
        string a = !string.IsNullOrWhiteSpace(apellidos) ? apellidos.Substring(0, 1).ToUpper() : "";
        string iniciales = (n + a);
        return string.IsNullOrEmpty(iniciales) ? "?" : iniciales;
    }

    private string CalcularEdad(DateTime? fechaNacimiento)
    {
        if (fechaNacimiento == null) return "—";
        int anios = DateTime.Today.Year - fechaNacimiento.Value.Year;
        if (fechaNacimiento.Value.Date > DateTime.Today.AddYears(-anios)) anios--;
        if (anios < 0) anios = 0;
        return anios + (anios == 1 ? " año" : " años");
    }
}
