@page "/clientes-mascotas/detalle"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "VETERINARIO,RECEPCIONISTA")]
@using VetCitasWA.Servicios.Modelo.Cliente
@using VetCitasWA.Servicios.Modelo.Cita
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.ClienteRS.MascotaRestService MascotaService
@inject VetCitasWA.Servicios.REST.ClienteRS.ClienteRestService ClienteService
@inject VetCitasWA.Servicios.REST.CitaRS.AtencionRestService AtencionService
@inject VetCitasWA.Servicios.REST.CitaRS.CitaRestService CitaService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Detalle de mascota - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <a class="crumb crumb-link" href="/clientes-mascotas">Clientes y mascotas</a>
    <span class="crumb-sep">›</span>
    <span class="crumb current">@(mascota is null ? "Detalle" : mascota.Nombre)</span>
</SectionContent>

<div class="page-section">
    <div class="card-wrapper">

        <a href="/clientes-mascotas" class="back-link">
            <span class="back-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                </svg>
            </span>
            Volver a la lista
        </a>

        @if (cargando)
        {
            <p class="estado-mensaje">Cargando...</p>
        }
        else if (mascota is null)
        {
            <p class="estado-mensaje estado-error">No se encontró la mascota solicitada.</p>
        }
        else
        {
            <div class="pet-header">
                <div class="pet-avatar-big" aria-hidden="true">@PrimeraLetra(mascota.Nombre)</div>
                <div class="pet-info">
                    <h1 class="pet-name">@mascota.Nombre</h1>
                    <div class="pet-meta">
                        <span class="pet-badge">@(mascota.Especie == TipoEspecie.PERRO ? "Perro" : "Gato")</span>
                        <span class="pet-age">@EdadTexto(mascota.FechaNacimiento)</span>
                    </div>
                </div>
            </div>

            <hr class="divider" />

            <div class="info-grid">

                <section class="info-block">
                    <h2 class="block-title">Información de la mascota</h2>
                    <div class="info-list">
                        <div class="info-item">
                            <div class="info-label">RAZA</div>
                            <div class="info-value">@(string.IsNullOrWhiteSpace(mascota.Raza) ? "—" : mascota.Raza)</div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">EDAD</div>
                            <div class="info-value">@EdadTexto(mascota.FechaNacimiento)</div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">PESO</div>
                            <div class="info-value">@(mascota.Peso > 0 ? $"{mascota.Peso:0.#} kg" : "—")</div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">ESTERILIZADO</div>
                            <div class="info-value">@(mascota.Esterilizado ? "Sí" : "No")</div>
                        </div>
                    </div>
                </section>

                <section class="info-block">
                    <h2 class="block-title">Información del dueño</h2>
                    @if (dueno is null)
                    {
                        <p class="estado-mensaje">Sin dueño asociado.</p>
                    }
                    else
                    {
                        <div class="info-list">
                            <div class="info-item">
                                <div class="info-label">NOMBRE</div>
                                <div class="info-value">@dueno.Nombres @dueno.Apellidos</div>
                            </div>
                            <div class="info-item">
                                <div class="info-label">DNI</div>
                                <div class="info-value">@dueno.Dni</div>
                            </div>
                            <div class="info-item">
                                <div class="info-label">TELÉFONO</div>
                                <div class="info-value">@(string.IsNullOrWhiteSpace(dueno.Telefono) ? "—" : dueno.Telefono)</div>
                            </div>
                            <div class="info-item">
                                <div class="info-label">EMAIL</div>
                                <div class="info-value">@(string.IsNullOrWhiteSpace(dueno.Email) ? "—" : dueno.Email)</div>
                            </div>
                        </div>
                    }
                </section>

            </div>

            <section class="history-section">
                <h2 class="block-title">Historial de visitas</h2>

                @if (!historial.Any())
                {
                    <p class="estado-mensaje">Esta mascota aún no tiene atenciones registradas.</p>
                }
                else
                {
                    <div class="history-table-wrapper">
                        <table class="history-table">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Diagnóstico</th>
                                    <th>Nota clínica</th>
                                    <th>Recomendación</th>
                                    <th>Costo</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in historial.OrderByDescending(x => x.FechaHora))
                                {
                                    <tr>
                                        <td data-label="Fecha">@a.FechaHora.ToString("yyyy-MM-dd")</td>
                                        <td data-label="Diagnóstico">@(string.IsNullOrWhiteSpace(a.Diagnostico) ? "—" : a.Diagnostico)</td>
                                        <td data-label="Nota clínica">@(string.IsNullOrWhiteSpace(a.NotaClinica) ? "—" : a.NotaClinica)</td>
                                        <td data-label="Recomendación">@(string.IsNullOrWhiteSpace(a.RecomendacionControl) ? "—" : a.RecomendacionControl)</td>
                                        <td data-label="Costo"><span class="cost">S/ @((a.MontoReferencial - a.DescuentoAplicado).ToString("0.00"))</span></td>
                                        <td data-label="" class="history-action">
                                            @if (a.Cita is not null && a.Cita.Id > 0)
                                            {
                                                <a class="ver-detalle" href="@($"/citas-hoy/atender?id={a.Cita.Id}&modo=ver")" title="Ver detalle de la atención">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                                        <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                                                        <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                                                    </svg>
                                                    Ver detalle
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        }

    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "id")]
    public int Id { get; set; }

    private Mascota? mascota;
    private Cliente? dueno;
    private List<Atencion> historial = new();
    private bool cargando = true;
    private int usuarioActualId;
    private bool usuarioEsVeterinario;
    private bool usuarioEsRecepcionista;
    private bool usuarioEsAdministrador;

    private bool EsVeterinarioPuro => usuarioEsVeterinario && !usuarioEsRecepcionista && !usuarioEsAdministrador;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await CargarContextoUsuario();
            mascota = await Task.Run(() => MascotaService.BuscarPorId(Id));

            if (mascota is not null)
            {
                if (EsVeterinarioPuro && !await MascotaPermitidaParaVeterinario(Id))
                {
                    mascota = null;
                    return;
                }

                if (mascota.Cliente is not null && mascota.Cliente.Id > 0)
                {
                    dueno = await Task.Run(() => ClienteService.BuscarPorId(mascota.Cliente.Id));
                }

                // El historial es opcional: si falla, mostramos el estado vacío
                try
                {
                    historial = await Task.Run(() => AtencionService.ListarHistorialPorMascota(Id));
                }
                catch
                {
                    historial = new();
                }
            }
        }
        catch
        {
            mascota = null;
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task CargarContextoUsuario()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        usuarioEsVeterinario = user.IsInRole("VETERINARIO");
        usuarioEsRecepcionista = user.IsInRole("RECEPCIONISTA");
        usuarioEsAdministrador = user.IsInRole("ADMINISTRADOR");

        var claim = user.FindFirst("IdUsuario")?.Value
            ?? user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        usuarioActualId = int.TryParse(claim, out var id) ? id : 0;
    }

    private async Task<bool> MascotaPermitidaParaVeterinario(int idMascota)
    {
        if (usuarioActualId <= 0) return false;

        var citasVet = await Task.Run(() => CitaService.ListarFiltradas(usuarioActualId, null, null, "", ""));
        if (citasVet.Any(c => c.Veterinario?.Id == usuarioActualId && c.Mascota?.Id == idMascota))
        {
            return true;
        }

        try
        {
            var atencionesVet = await Task.Run(() => AtencionService.ListarFiltradas(usuarioActualId, "", null, ""));
            return atencionesVet.Any(a => a.Cita?.Veterinario?.Id == usuarioActualId && a.Cita?.Mascota?.Id == idMascota);
        }
        catch
        {
            return false;
        }
    }

    private string PrimeraLetra(string? texto)
        => !string.IsNullOrWhiteSpace(texto) ? char.ToUpper(texto![0]).ToString() : "?";

    private string EdadTexto(DateTime? fecha)
    {
        if (!fecha.HasValue) return "—";
        var hoy = DateTime.Today;
        int anios = hoy.Year - fecha.Value.Year;
        if (fecha.Value.Date > hoy.AddYears(-anios)) anios--;
        return anios <= 0 ? "< 1 año" : $"{anios} año{(anios == 1 ? "" : "s")}";
    }
}
