@page "/clientes-mascotas/detalle"
@using VetCitasWA.Servicios.Modelo.Cliente
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.ClienteRS.MascotaRestService MascotaService

<PageTitle>Detalle de Mascota - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <a class="crumb crumb-link" href="/clientes-mascotas">Clientes y Mascotas</a>
    <span class="crumb-sep">›</span>
    <span class="crumb current">@(mascota?.Nombre ?? "Mascota")</span>
</SectionContent>

<div class="page-section">

    <div class="card-wrapper">

        @* ================= Back link ================= *@
        <a href="/clientes-mascotas" class="back-link">
            <span class="back-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                </svg>
            </span>
            VOLVER A LA LISTA
        </a>

        @* ================= Header de la mascota ================= *@
        <div class="pet-header">
            <div class="pet-avatar-big" aria-hidden="true">@(string.IsNullOrWhiteSpace(mascota?.Nombre) ? "?" : mascota!.Nombre.Substring(0, 1).ToUpper())</div>
            <div class="pet-info">
                <h1 class="pet-name">@mascota?.Nombre</h1>
                <div class="pet-meta">
                    <span class="pet-badge">@(mascota != null && mascota.Especie == TipoEspecie.PERRO ? "Perro" : "Gato")</span>
                    <span class="pet-age">@CalcularEdad(mascota?.FechaNacimiento)</span>
                </div>
            </div>
            <div class="pet-header-actions">
                <label for="mascota-form-modal" class="btn-edit-mas recep-only">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" /></svg>
                    Editar Mascota
                </label>
            </div>
        </div>

        <hr class="divider" />

        @* ================= Dos columnas: Mascota / Dueño ================= *@
        <div class="info-grid">

            <section class="info-block">
                <h2 class="block-title">Información de la Mascota</h2>
                <div class="info-list">
                    <div class="info-item">
                        <div class="info-label">RAZA</div>
                        <div class="info-value">@mascota?.Raza</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">EDAD</div>
                        <div class="info-value">@CalcularEdad(mascota?.FechaNacimiento)</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">PESO</div>
                        <div class="info-value">@mascota?.Peso kg</div>
                    </div>
                </div>
            </section>

            <section class="info-block">
                <h2 class="block-title">Información del Dueño</h2>
                <div class="info-list">
                    <div class="info-item">
                        <div class="info-label">NOMBRE</div>
                        <div class="info-value">@(mascota?.Cliente != null ? $"{mascota.Cliente.Nombres} {mascota.Cliente.Apellidos}" : "")</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">DNI</div>
                        <div class="info-value">@mascota?.Cliente?.Dni</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">TELÉFONO</div>
                        <div class="info-value">@mascota?.Cliente?.Telefono</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">EMAIL</div>
                        <div class="info-value">@mascota?.Cliente?.Email</div>
                    </div>
                </div>
            </section>

        </div>

        @* ================= Historial de Visitas ================= *@
        <section class="history-section">
            <h2 class="block-title">Historial de Visitas</h2>

            <div class="history-table-wrapper">
                <table class="history-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Motivo</th>
                            <th>Diagnóstico</th>
                            <th>Costo</th>
                            <th>Tratamiento</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td data-label="Fecha">2024-03-15</td>
                            <td data-label="Motivo">Consulta General</td>
                            <td data-label="Diagnóstico">Saludable</td>
                            <td data-label="Costo"><span class="cost">$35.00</span></td>
                            <td data-label="Tratamiento">Ninguno</td>
                        </tr>
                        <tr>
                            <td data-label="Fecha">2024-04-10</td>
                            <td data-label="Motivo">Vacunación</td>
                            <td data-label="Diagnóstico">N/A</td>
                            <td data-label="Costo"><span class="cost">$20.00</span></td>
                            <td data-label="Tratamiento">Vacuna antirábica</td>
                        </tr>
                        <tr>
                            <td data-label="Fecha">2024-05-15</td>
                            <td data-label="Motivo">Control</td>
                            <td data-label="Diagnóstico">Sobrepeso leve</td>
                            <td data-label="Costo"><span class="cost">$15.00</span></td>
                            <td data-label="Tratamiento">Dieta recomendada</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

    </div>

</div>

@code {
    private Mascota? mascota;

    protected override void OnInitialized()
    {
        // La ruta no recibe Id; se carga la primera mascota disponible como
        // ejemplo representativo (la maqueta original mostraba una mascota fija).
        var mascotas = MascotaService.ListarTodos();
        mascota = mascotas.FirstOrDefault();
    }

    private string CalcularEdad(DateTime? fechaNacimiento)
    {
        if (fechaNacimiento == null) return "—";
        int anios = DateTime.Today.Year - fechaNacimiento.Value.Year;
        if (fechaNacimiento.Value.Date > DateTime.Today.AddYears(-anios)) anios--;
        if (anios < 0) anios = 0;
        return anios + (anios == 1 ? " año" : " años");
    }
}
