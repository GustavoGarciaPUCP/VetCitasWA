@page "/clientes-mascotas/cliente"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "VETERINARIO,RECEPCIONISTA")]
@using VetCitasWA.Servicios.Modelo.Cliente
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.ClienteRS.ClienteRestService ClienteService
@inject VetCitasWA.Servicios.REST.ClienteRS.MascotaRestService MascotaService

<PageTitle>Detalle de cliente - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <a class="crumb crumb-link" href="/clientes-mascotas">Clientes y mascotas</a>
    <span class="crumb-sep">›</span>
    <span class="crumb current">@(cliente is null ? "Detalle" : $"{cliente.Nombres} {cliente.Apellidos}")</span>
</SectionContent>

<div class="page-section">
    <div class="card-wrapper">

        <a href="/clientes-mascotas" class="back-link">
            <span class="back-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                </svg>
            </span>
            Volver a la lista
        </a>

        @if (cargando)
        {
            <p class="estado-mensaje">Cargando...</p>
        }
        else if (cliente is null)
        {
            <p class="estado-mensaje estado-error">No se encontró el cliente solicitado.</p>
        }
        else
        {
            <div class="client-header">
                <div class="client-avatar-big" aria-hidden="true">@Iniciales(cliente.Nombres, cliente.Apellidos)</div>
                <div class="client-info">
                    <h1 class="client-name">@cliente.Nombres @cliente.Apellidos</h1>
                    <div class="client-meta">
                        <span class="client-id">DNI: @cliente.Dni</span>
                    </div>
                </div>
            </div>

            <hr class="divider" />

            <section class="info-block info-block-full">
                <h2 class="block-title">Información del cliente</h2>
                <div class="info-grid-2">
                    <div class="info-item">
                        <div class="info-label">DNI</div>
                        <div class="info-value">@cliente.Dni</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">TELÉFONO</div>
                        <div class="info-value">@(string.IsNullOrWhiteSpace(cliente.Telefono) ? "—" : cliente.Telefono)</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">EMAIL</div>
                        <div class="info-value">@(string.IsNullOrWhiteSpace(cliente.Email) ? "—" : cliente.Email)</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">ESTADO</div>
                        <div class="info-value">
                            <span class="status-pill @(cliente.Activo ? "status-active" : "status-inactive")">@(cliente.Activo ? "Activo" : "Inactivo")</span>
                        </div>
                    </div>
                    <div class="info-item info-item-full">
                        <div class="info-label">OBSERVACIONES</div>
                        <div class="info-value">@(string.IsNullOrWhiteSpace(cliente.Observaciones) ? "—" : cliente.Observaciones)</div>
                    </div>
                </div>
            </section>

            <section class="pets-section">
                <div class="pets-header">
                    <h2 class="block-title">Mascotas del cliente</h2>
                    <div class="pets-header-right">
                        <span class="pets-count">@mascotas.Count mascota@(mascotas.Count == 1 ? "" : "s") registrada@(mascotas.Count == 1 ? "" : "s")</span>
                    </div>
                </div>

                @if (!mascotas.Any())
                {
                    <p class="estado-mensaje">Este cliente no tiene mascotas registradas.</p>
                }
                else
                {
                    <div class="pets-grid">
                        @foreach (var m in mascotas)
                        {
                            <article class="pet-card">
                                <div class="pet-card-head">
                                    <span class="pet-avatar @(m.Especie == TipoEspecie.PERRO ? "pet-dog" : "pet-cat")" aria-hidden="true">@PrimeraLetra(m.Nombre)</span>
                                    <div class="pet-card-meta">
                                        <div class="pet-card-name">@m.Nombre</div>
                                        <span class="species-pill @(m.Especie == TipoEspecie.PERRO ? "species-dog" : "species-cat")">@(m.Especie == TipoEspecie.PERRO ? "Perro" : "Gato")</span>
                                        @if (!m.Activo)
                                        {
                                            <span class="status-badge status-inactive">Inactiva</span>
                                        }
                                    </div>
                                </div>
                                <div class="pet-card-body">
                                    <div class="pet-row-info"><span class="pet-row-label">Raza</span><span>@(string.IsNullOrWhiteSpace(m.Raza) ? "—" : m.Raza)</span></div>
                                    <div class="pet-row-info"><span class="pet-row-label">Edad</span><span>@EdadTexto(m.FechaNacimiento)</span></div>
                                    <div class="pet-row-info"><span class="pet-row-label">Peso</span><span>@(m.Peso > 0 ? $"{m.Peso:0.#} kg" : "—")</span></div>
                                    <div class="pet-row-info"><span class="pet-row-label">Esterilizado</span><span>@(m.Esterilizado ? "Sí" : "No")</span></div>
                                </div>
                                <div class="pet-card-actions">
                                    <a href="@($"/clientes-mascotas/detalle?id={m.Id}")" class="pet-card-link">
                                        <span class="eye-icon" aria-hidden="true">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" /><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" /></svg>
                                        </span>
                                        Ver detalle
                                    </a>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        }

    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "id")]
    public int Id { get; set; }

    private Cliente? cliente;
    private List<Mascota> mascotas = new();
    private bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            cliente = await Task.Run(() => ClienteService.BuscarPorId(Id));
            if (cliente is not null)
            {
                mascotas = await Task.Run(() => MascotaService.ListarPorCliente(Id));
            }
        }
        catch
        {
            cliente = null;
        }
        finally
        {
            cargando = false;
        }
    }

    private string Iniciales(string? nombres, string? apellidos)
    {
        char n = !string.IsNullOrWhiteSpace(nombres) ? char.ToUpper(nombres![0]) : '?';
        char a = !string.IsNullOrWhiteSpace(apellidos) ? char.ToUpper(apellidos![0]) : ' ';
        return $"{n}{a}".Trim();
    }

    private string PrimeraLetra(string? texto)
        => !string.IsNullOrWhiteSpace(texto) ? char.ToUpper(texto![0]).ToString() : "?";

    private string EdadTexto(DateTime? fecha)
    {
        if (!fecha.HasValue) return "—";
        var hoy = DateTime.Today;
        int anios = hoy.Year - fecha.Value.Year;
        if (fecha.Value.Date > hoy.AddYears(-anios)) anios--;
        return anios <= 0 ? "< 1 año" : $"{anios} año{(anios == 1 ? "" : "s")}";
    }
}
