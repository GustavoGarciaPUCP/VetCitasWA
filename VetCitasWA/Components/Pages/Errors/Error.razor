@page "/Error"
@using System.Diagnostics
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]

<PageTitle>Error</PageTitle>

<h1 class="text-danger">Error</h1>
<h2 class="text-danger">Ocurrió un error al procesar la solicitud.</h2>

@if (ShowRequestId)
{
    <p>
        <strong>ID de la solicitud:</strong> <code>@RequestId</code>
    </p>
}

<h3>Modo de desarrollo</h3>
<p>
    Cambiar al entorno de <strong>desarrollo</strong> muestra información más detallada sobre el error.
</p>
<p>
    <strong>El entorno de desarrollo no debe habilitarse en aplicaciones desplegadas.</strong>
    Puede exponer información sensible de las excepciones a los usuarios.
    Para depurar de forma local, habilita el entorno de <strong>desarrollo</strong> asignando el valor <strong>Development</strong> a la variable de entorno <strong>ASPNETCORE_ENVIRONMENT</strong>
    y reinicia la aplicación.
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
