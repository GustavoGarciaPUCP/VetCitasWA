@page "/gestionar-horarios"
@using VetCitasWA.Servicios.Modelo.Usuario
@inject VetCitasWA.Servicios.REST.UsuarioRS.VeterinarioRestService VetService
@inject VetCitasWA.Servicios.REST.UsuarioRS.HorarioVeterinarioRestService HorarioService

<PageTitle>Gestionar horarios - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Gestionar horarios</span>
</SectionContent>

<div class="page-section">
    <section class="panel">
        <div class="vet-field">
            <label class="field-label" for="veterinario">Veterinario</label>
            <div class="select-wrap">
                <select id="veterinario" class="select" @onchange="OnVetChanged">
                    <option value="0">Selecciona un veterinario</option>
                    @foreach (var vet in listaVeterinarios)
                    {
                        <option value="@vet.Id">@vet.Nombres @vet.Apellidos</option>
                    }
                </select>
            </div>
        </div>

        <h2 class="section-title">Resumen semanal de horarios</h2>

        <div class="table-wrapper">
            <table class="schedule-table">
                <thead>
                    <tr>
                        <th>Día</th>
                        <th>Horario</th>
                        <th>Refrigerio</th>
                        <th>Activo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (listaHorarios == null || !listaHorarios.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center">Selecciona un veterinario para ver sus horarios.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var h in listaHorarios)
                        {
                            <tr class="@(!h.Activo ? "row-inactive" : "")">
                                <td data-label="Día">@GetNombreDia(h.DiaSemana)</td>
                                <td data-label="Horario">@h.HoraInicio - @h.HoraFin</td>
                                <td data-label="Refrigerio">@h.HoraDescansoInicio - @h.HoraDescansoFin</td>
                                <td data-label="Activo">@(h.Activo ? "Sí" : "No")</td>
                                <td data-label="Acciones">
                                    <button type="button" class="btn-inactivar">Inactivar</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@code {
    private List<Veterinario> listaVeterinarios = new();
    private List<HorarioVeterinario> listaHorarios = new();
    private int idVetSeleccionado = 0;

    protected override void OnInitialized()
    {
        listaVeterinarios = VetService.ListarTodos();
    }

    private void OnVetChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            idVetSeleccionado = id;
            if (id > 0)
            {
                listaHorarios = HorarioService.ListarPorVeterinario(id);
            }
            else
            {
                listaHorarios = new();
            }
        }
    }

    private string GetNombreDia(int dia) => dia switch
    {
        1 => "Lunes",
        2 => "Martes",
        3 => "Miércoles",
        4 => "Jueves",
        5 => "Viernes",
        6 => "Sábado",
        7 => "Domingo",
        _ => "Desconocido"
    };
}