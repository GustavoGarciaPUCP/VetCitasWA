@page "/gestionar-horarios"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "RECEPCIONISTA")]
@using System.Security.Claims
@using VetCitasWA.Servicios.Modelo.Cita
@using VetCitasWA.Servicios.Modelo.Common.Enums
@using VetCitasWA.Servicios.Modelo.Usuario
@inject VetCitasWA.Servicios.REST.CitaRS.CitaRestService CitaService
@inject VetCitasWA.Servicios.REST.UsuarioRS.VeterinarioRestService VetService
@inject VetCitasWA.Servicios.REST.UsuarioRS.HorarioVeterinarioRestService HorarioService
@inject VetCitasWA.Servicios.UI.ToastService Toasts
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Gestionar horarios - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">&gt;</span>
    <span class="crumb current">Gestionar horarios</span>
</SectionContent>

<div class="page-section">
    <div class="page-head">
        <div>
            <h1 class="page-title">Gestionar horarios</h1>
            <p class="page-subtitle">Administra la disponibilidad semanal de cada veterinario.</p>
        </div>
    </div>

    <section class="panel">
        <div class="schedule-toolbar">
            <div class="vet-field">
                <label class="field-label" for="veterinario">Veterinario</label>
                <div class="select-wrap">
                    <VcSelect TValue="int"
                              Value="idVetSeleccionado"
                              ValueChanged="OnVetChanged"
                              Options="OpcionesVeterinarios"
                              Placeholder="Selecciona un veterinario" />
                </div>
            </div>

            @if (PuedeCrearNuevoHorario)
            {
                <button type="button" class="vc-btn vc-btn-primary btn-toolbar"
                        disabled="@procesando"
                        @onclick="NuevoHorario">
                    <span aria-hidden="true">+</span>
                    <span>Nuevo horario</span>
                </button>
            }
            else if (idVetSeleccionado > 0 && !cargandoHorarios)
            {
                <div class="schedule-complete" role="status">
                    Semana completa. Edita o reactiva un dia existente.
                </div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(mensajeError))
        {
            <div class="schedule-alert">@mensajeError</div>
        }

        <h2 class="section-title">Resumen semanal de horarios</h2>

        <div class="table-wrapper">
            <table class="schedule-table">
                <thead>
                    <tr>
                        <th>Dia</th>
                        <th>Horario</th>
                        <th>Refrigerio</th>
                        <th>Activo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (idVetSeleccionado <= 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center">Selecciona un veterinario para ver sus horarios.</td>
                        </tr>
                    }
                    else if (cargandoHorarios)
                    {
                        <tr>
                            <td colspan="5" class="text-center">Cargando horarios...</td>
                        </tr>
                    }
                    else if (listaHorarios == null || !listaHorarios.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center">Este veterinario aun no tiene horarios registrados.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var h in listaHorarios.OrderBy(x => x.DiaSemana).ThenBy(x => x.HoraInicio))
                        {
                            <tr class="@(!h.Activo ? "row-inactive" : "")">
                                <td data-label="Dia">@GetNombreDia(h.DiaSemana)</td>
                                <td data-label="Horario">@FormatoHora(h.HoraInicio) - @FormatoHora(h.HoraFin)</td>
                                <td data-label="Refrigerio">@FormatoDescanso(h)</td>
                                <td data-label="Activo">
                                    <span class="status-badge @(h.Activo ? "status-active" : "status-inactive")">
                                        @(h.Activo ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td data-label="Acciones">
                                    <div class="schedule-actions">
                                        <button type="button"
                                                class="btn-pencil btn-edit"
                                                title="Editar horario"
                                                aria-label="Editar horario"
                                                @onclick="() => EditarHorario(h)"
                                                disabled="@procesando">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" />
                                            </svg>
                                        </button>
                                        @if (h.Activo)
                                        {
                                            <button type="button"
                                                    class="btn-pencil btn-del"
                                                    title="Desactivar horario"
                                                    aria-label="Desactivar horario"
                                                    @onclick="() => DesactivarHorario(h)"
                                                    disabled="@procesando">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z" />
                                                    <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1 0-2H5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1h2.5a1 1 0 0 1 1 1M4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                                                </svg>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="btn-pencil btn-reactivate"
                                                    title="Reactivar horario"
                                                    aria-label="Reactivar horario"
                                                    @onclick="() => ReactivarHorario(h)"
                                                    disabled="@procesando">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M10.854 6.146a.5.5 0 0 1 0 .708l-3.75 3.75a.5.5 0 0 1-.708 0l-1.75-1.75a.5.5 0 1 1 .708-.708L6.75 9.543l3.396-3.397a.5.5 0 0 1 .708 0" />
                                                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                                                </svg>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@if (mostrarEditor)
{
    <div class="vc-modal-backdrop" role="presentation">
        <div class="vc-modal-card vc-modal-card-lg schedule-modal-card" role="dialog" aria-modal="true" aria-labelledby="horarioEditorTitulo">
            <button type="button" class="vc-modal-close" aria-label="Cerrar" @onclick="CancelarEdicion" disabled="@procesando">x</button>
            <h2 id="horarioEditorTitulo" class="vc-modal-title">@(editando ? "Editar horario" : "Registrar horario")</h2>
            <p class="vc-modal-subtitle">
                @(editando ? "Ajusta el rango sin afectar citas pendientes o confirmadas." : "Registra un dia libre para la disponibilidad semanal.")
            </p>

            <div class="editor-body">
                <div class="time-grid">
                    <div class="form-field">
                        <label class="field-label-sm">Dia</label>
                        @if (editando)
                        {
                            <div class="readonly-day">
                                <span>@GetNombreDia(diaSemana)</span>
                            </div>
                        }
                        else
                        {
                            <VcSelect TValue="int"
                                      @bind-Value="diaSemana"
                                      Options="OpcionesDiasEditor"
                                      Placeholder="Selecciona un dia"
                                      EmptyText="No hay dias libres para este veterinario." />
                        }
                    </div>

                    <label class="check-row active-row">
                        <input type="checkbox" class="check-input" @bind="activoModelo" disabled="@(!editando)" />
                        <span class="check-visual"></span>
                        <span class="check-label">Horario activo</span>
                    </label>
                </div>

                <div class="time-grid">
                    <div class="form-field">
                        <label class="field-label-sm">Hora inicio</label>
                        <input type="time" class="input" step="900" value="@horaInicioTexto"
                               @onchange="e => horaInicioTexto = e.Value?.ToString() ?? string.Empty" />
                    </div>
                    <div class="form-field">
                        <label class="field-label-sm">Hora fin</label>
                        <input type="time" class="input" step="900" value="@horaFinTexto"
                               @onchange="e => horaFinTexto = e.Value?.ToString() ?? string.Empty" />
                    </div>
                </div>

                <label class="check-row">
                    <input type="checkbox" class="check-input" @bind="usarDescanso" />
                    <span class="check-visual"></span>
                    <span class="check-label">Agregar refrigerio</span>
                </label>

                @if (usarDescanso)
                {
                    <div class="time-grid">
                        <div class="form-field">
                            <label class="field-label-sm">Inicio refrigerio</label>
                            <input type="time" class="input" step="900" value="@descansoInicioTexto"
                                   @onchange="e => descansoInicioTexto = e.Value?.ToString() ?? string.Empty" />
                        </div>
                        <div class="form-field">
                            <label class="field-label-sm">Fin refrigerio</label>
                            <input type="time" class="input" step="900" value="@descansoFinTexto"
                                   @onchange="e => descansoFinTexto = e.Value?.ToString() ?? string.Empty" />
                        </div>
                    </div>
                }

                <div class="vc-modal-actions schedule-modal-actions">
                    <button type="button" class="vc-btn vc-btn-secondary" @onclick="LimpiarFormulario" disabled="@procesando">Limpiar formulario</button>
                    <button type="button" class="vc-btn vc-btn-primary" @onclick="GuardarHorario" disabled="@procesando">
                        @(procesando ? "Guardando..." : editando ? "Guardar cambios" : "Registrar horario")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Veterinario> listaVeterinarios = new();
    private List<HorarioVeterinario> listaHorarios = new();
    private int idVetSeleccionado;
    private int usuarioActualId;
    private bool cargandoHorarios;
    private bool procesando;
    private bool mostrarEditor;
    private bool editando;
    private bool activoModelo = true;
    private int horarioEditandoId;
    private int diaSemana = 1;
    private string horaInicioTexto = "08:00";
    private string horaFinTexto = "17:00";
    private bool usarDescanso;
    private string descansoInicioTexto = "";
    private string descansoFinTexto = "";
    private string? mensajeError;

    private IEnumerable<VcSelectOption<int>> OpcionesVeterinarios =>
        listaVeterinarios
            .Where(vet => vet.Activo)
            .OrderBy(vet => vet.Nombres)
            .ThenBy(vet => vet.Apellidos)
            .Select(vet => new VcSelectOption<int>(vet.Id, $"{vet.Nombres} {vet.Apellidos}".Trim()));

    private static readonly VcSelectOption<int>[] TodasOpcionesDias = new[]
    {
        new VcSelectOption<int>(1, "Lunes"),
        new VcSelectOption<int>(2, "Martes"),
        new VcSelectOption<int>(3, "Miercoles"),
        new VcSelectOption<int>(4, "Jueves"),
        new VcSelectOption<int>(5, "Viernes"),
        new VcSelectOption<int>(6, "Sabado"),
        new VcSelectOption<int>(7, "Domingo")
    };

    private IEnumerable<int> DiasOcupados(int idExcluir = 0)
        => listaHorarios
            .Where(h => h.Id != idExcluir && h.DiaSemana >= 1 && h.DiaSemana <= 7)
            .Select(h => h.DiaSemana)
            .Distinct();

    private List<int> DiasDisponiblesNuevo
    {
        get
        {
            var ocupados = DiasOcupados().ToHashSet();
            return Enumerable.Range(1, 7).Where(d => !ocupados.Contains(d)).ToList();
        }
    }

    private bool PuedeCrearNuevoHorario
        => idVetSeleccionado > 0 && !cargandoHorarios && DiasDisponiblesNuevo.Any();

    private IEnumerable<VcSelectOption<int>> OpcionesDiasEditor
    {
        get
        {
            var idExcluir = editando ? horarioEditandoId : 0;
            var ocupados = DiasOcupados(idExcluir).ToHashSet();
            return TodasOpcionesDias.Where(o => !ocupados.Contains(o.Value));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        usuarioActualId = await ObtenerUsuarioActualId();
        try
        {
            listaVeterinarios = VetService.ListarTodos();
        }
        catch
        {
            listaVeterinarios = new();
            mensajeError = "No se pudieron cargar los veterinarios.";
        }
    }

    private async Task OnVetChanged(int id)
    {
        idVetSeleccionado = id;
        mostrarEditor = false;
        LimpiarFormulario();
        await CargarHorarios();
    }

    private Task CargarHorarios()
    {
        if (idVetSeleccionado <= 0)
        {
            listaHorarios = new();
            return Task.CompletedTask;
        }

        cargandoHorarios = true;
        mensajeError = null;

        try
        {
            listaHorarios = HorarioService.ListarPorVeterinario(idVetSeleccionado);
        }
        catch
        {
            listaHorarios = new();
            mensajeError = "No se pudieron cargar los horarios.";
        }
        finally
        {
            cargandoHorarios = false;
        }

        return Task.CompletedTask;
    }

    private void NuevoHorario()
    {
        var primerDiaLibre = DiasDisponiblesNuevo.FirstOrDefault();
        if (primerDiaLibre == 0)
        {
            mensajeError = "Este veterinario ya tiene horarios registrados para toda la semana.";
            Toasts.Info("La semana de este veterinario ya esta completa.");
            return;
        }

        editando = false;
        horarioEditandoId = 0;
        activoModelo = true;
        LimpiarFormulario();
        diaSemana = primerDiaLibre;
        mostrarEditor = true;
    }

    private void EditarHorario(HorarioVeterinario horario)
    {
        if (horario is null) return;

        editando = true;
        horarioEditandoId = horario.Id;
        diaSemana = horario.DiaSemana;
        horaInicioTexto = FormatoHora(horario.HoraInicio);
        horaFinTexto = FormatoHora(horario.HoraFin);
        usarDescanso = horario.HoraDescansoInicio.HasValue && horario.HoraDescansoFin.HasValue;
        descansoInicioTexto = horario.HoraDescansoInicio.HasValue ? FormatoHora(horario.HoraDescansoInicio.Value) : "";
        descansoFinTexto = horario.HoraDescansoFin.HasValue ? FormatoHora(horario.HoraDescansoFin.Value) : "";
        activoModelo = horario.Activo;
        mensajeError = null;
        mostrarEditor = true;
    }

    private void CancelarEdicion()
    {
        mostrarEditor = false;
        mensajeError = null;
        LimpiarFormulario();
    }

    private void LimpiarFormulario()
    {
        if (!editando)
        {
            horarioEditandoId = 0;
            activoModelo = true;
        }

        if (!editando)
        {
            var primerDiaLibre = DiasDisponiblesNuevo.FirstOrDefault();
            diaSemana = primerDiaLibre == 0 ? 1 : primerDiaLibre;
        }
        horaInicioTexto = "08:00";
        horaFinTexto = "17:00";
        usarDescanso = false;
        descansoInicioTexto = "";
        descansoFinTexto = "";
    }

    private async Task GuardarHorario()
    {
        if (procesando) return;
        if (!TryCrearHorarioDesdeFormulario(out var horario)) return;

        procesando = true;
        mensajeError = null;

        try
        {
            var resultado = editando
                ? HorarioService.Modificar(horario)
                : HorarioService.Insertar(horario);

            if (resultado <= 0)
            {
                mensajeError = "No se pudo guardar el horario. Verifica que no exista un cruce.";
                return;
            }

            Toasts.Exito(editando ? "Horario actualizado." : "Horario registrado.");
            mostrarEditor = false;
            editando = false;
            await CargarHorarios();
        }
        catch (Exception ex)
        {
            mensajeError = $"No se pudo guardar el horario. {ex.Message}";
            Toasts.Error("No se pudo guardar el horario.");
        }
        finally
        {
            procesando = false;
        }
    }

    private async Task DesactivarHorario(HorarioVeterinario horario)
    {
        if (horario is null || procesando) return;

        mensajeError = null;
        if (!TryValidarSinCitasParaDesactivar(horario))
        {
            return;
        }

        procesando = true;

        try
        {
            var resultado = HorarioService.Eliminar(horario.Id, usuarioActualId);
            if (resultado <= 0)
            {
                mensajeError = "No se pudo desactivar el horario.";
                return;
            }

            Toasts.Exito("Horario desactivado.");
            await CargarHorarios();
        }
        catch (Exception ex)
        {
            mensajeError = $"No se pudo desactivar el horario. {ex.Message}";
            Toasts.Error("No se pudo desactivar el horario.");
        }
        finally
        {
            procesando = false;
        }
    }

    private async Task ReactivarHorario(HorarioVeterinario horario)
    {
        if (horario is null || procesando) return;

        if (DiaOcupadoPorOtro(horario.DiaSemana, horario.Id))
        {
            mensajeError = "No se puede reactivar porque ese dia ya tiene otro horario registrado.";
            return;
        }

        if (TieneSolapamiento(horario.HoraInicio, horario.HoraFin, horario.Id, horario.DiaSemana))
        {
            mensajeError = "No se puede reactivar porque se cruza con otro horario activo del mismo veterinario.";
            return;
        }

        procesando = true;
        mensajeError = null;

        try
        {
            var copia = CopiarHorario(horario);
            copia.Activo = true;
            copia.ModifiedBy = new Usuario { Id = usuarioActualId };

            var resultado = HorarioService.Modificar(copia);
            if (resultado <= 0)
            {
                mensajeError = "No se pudo reactivar el horario.";
                return;
            }

            Toasts.Exito("Horario reactivado.");
            await CargarHorarios();
        }
        catch (Exception ex)
        {
            mensajeError = $"No se pudo reactivar el horario. {ex.Message}";
            Toasts.Error("No se pudo reactivar el horario.");
        }
        finally
        {
            procesando = false;
        }
    }

    private bool TryCrearHorarioDesdeFormulario(out HorarioVeterinario horario)
    {
        horario = new HorarioVeterinario();
        mensajeError = null;

        if (idVetSeleccionado <= 0)
        {
            mensajeError = "Selecciona un veterinario.";
            return false;
        }

        if (diaSemana < 1 || diaSemana > 7)
        {
            mensajeError = "Selecciona un dia valido.";
            return false;
        }

        var idExcluir = editando ? horarioEditandoId : 0;
        if (DiaOcupadoPorOtro(diaSemana, idExcluir))
        {
            mensajeError = "Ese dia ya tiene un horario registrado para este veterinario. Edita o reactiva el horario existente.";
            return false;
        }

        if (!TryParseHora(horaInicioTexto, out var inicio) || !TryParseHora(horaFinTexto, out var fin))
        {
            mensajeError = "Ingresa una hora de inicio y fin validas.";
            return false;
        }

        if (fin <= inicio)
        {
            mensajeError = "La hora de fin debe ser posterior a la hora de inicio.";
            return false;
        }

        TimeOnly? descansoInicio = null;
        TimeOnly? descansoFin = null;
        if (usarDescanso)
        {
            if (!TryParseHora(descansoInicioTexto, out var di) || !TryParseHora(descansoFinTexto, out var df))
            {
                mensajeError = "Ingresa el inicio y fin del refrigerio.";
                return false;
            }

            if (df <= di)
            {
                mensajeError = "El fin del refrigerio debe ser posterior al inicio.";
                return false;
            }

            if (di < inicio || df > fin)
            {
                mensajeError = "El refrigerio debe estar dentro del horario laboral.";
                return false;
            }

            descansoInicio = di;
            descansoFin = df;
        }

        if (activoModelo && TieneSolapamiento(inicio, fin, idExcluir, diaSemana))
        {
            mensajeError = "Este horario se cruza con otro horario activo del mismo veterinario.";
            return false;
        }

        if (editando && !TryValidarImpactoCitas(inicio, fin, descansoInicio, descansoFin, activoModelo))
        {
            return false;
        }

        horario = new HorarioVeterinario
        {
            Id = idExcluir,
            Veterinario = new Veterinario { Id = idVetSeleccionado },
            DiaSemana = diaSemana,
            HoraInicio = inicio,
            HoraFin = fin,
            HoraDescansoInicio = descansoInicio,
            HoraDescansoFin = descansoFin,
            Activo = activoModelo,
            ModifiedBy = new Usuario { Id = usuarioActualId }
        };

        return true;
    }

    private bool TryValidarImpactoCitas(
        TimeOnly inicio,
        TimeOnly fin,
        TimeOnly? descansoInicio,
        TimeOnly? descansoFin,
        bool quedaraActivo)
    {
        if (!TryObtenerCitasBloqueantesDelDia(diaSemana, out var citas, out var error))
        {
            mensajeError = error;
            Toasts.Error("No se pudo validar el impacto del horario.");
            return false;
        }

        if (!quedaraActivo)
        {
            if (citas.Any())
            {
                mensajeError = CrearMensajeCitasBloqueantes(citas, "desactivar");
                Toasts.Error("Hay citas que dependen de este horario.");
                return false;
            }

            return true;
        }

        var afectadas = citas
            .Where(cita => !CitaCabeEnHorario(cita, inicio, fin, descansoInicio, descansoFin))
            .ToList();

        if (!afectadas.Any())
        {
            return true;
        }

        mensajeError = CrearMensajeCitasBloqueantes(afectadas, "modificar");
        Toasts.Error("El cambio afecta citas existentes.");
        return false;
    }

    private bool TryValidarSinCitasParaDesactivar(HorarioVeterinario horario)
    {
        if (!TryObtenerCitasBloqueantesDelDia(horario.DiaSemana, out var citas, out var error))
        {
            mensajeError = error;
            Toasts.Error("No se pudo validar si existen citas afectadas.");
            return false;
        }

        if (!citas.Any())
        {
            return true;
        }

        mensajeError = CrearMensajeCitasBloqueantes(citas, "desactivar");
        Toasts.Error("Hay citas que dependen de este horario.");
        return false;
    }

    private bool TryObtenerCitasBloqueantesDelDia(int dia, out List<Cita> citas, out string error)
    {
        citas = new();
        error = string.Empty;

        try
        {
            var desdeHoy = DateTime.Today;
            citas = CitaService
                .ListarFiltradas(idVetSeleccionado, desdeHoy, null, string.Empty, string.Empty)
                .Where(cita => cita.FechaHoraInicio != default)
                .Where(cita => NumeroDiaSemana(cita.FechaHoraInicio) == dia)
                .Where(cita => EstadoBloqueaHorario(cita.Estado))
                .ToList();
            return true;
        }
        catch (Exception ex)
        {
            error = $"No se pudo validar si existen citas afectadas. {ex.Message}";
            return false;
        }
    }

    private static bool CitaCabeEnHorario(
        Cita cita,
        TimeOnly inicio,
        TimeOnly fin,
        TimeOnly? descansoInicio,
        TimeOnly? descansoFin)
    {
        var citaInicio = TimeOnly.FromDateTime(cita.FechaHoraInicio);
        var citaFin = TimeOnly.FromDateTime(cita.FechaHoraFin);
        var dentroDelRango = citaInicio >= inicio && citaFin <= fin;
        var cruzaDescanso = descansoInicio.HasValue
            && descansoFin.HasValue
            && citaInicio < descansoFin.Value
            && citaFin > descansoInicio.Value;

        return dentroDelRango && !cruzaDescanso;
    }

    private string CrearMensajeCitasBloqueantes(List<Cita> citas, string accion)
    {
        var cantidad = citas.Count;
        var tieneConfirmadas = citas.Any(c => c.Estado == EstadoCita.CONFIRMADA || c.Estado == EstadoCita.EN_CONSULTA);
        var tienePendientes = citas.Any(c => c.Estado == EstadoCita.PENDIENTE);
        var ejemplo = citas
            .OrderBy(c => c.FechaHoraInicio)
            .Select(c => $"{NombreMascota(c)} {c.FechaHoraInicio:dd/MM HH:mm} ({EstadoTexto(c.Estado)})")
            .FirstOrDefault();

        if (tieneConfirmadas)
        {
            return $"No se puede {accion} este horario porque tiene {cantidad} cita(s) confirmada(s) o en consulta. Cancela o reprograma esas citas antes. Ejemplo: {ejemplo}.";
        }

        if (tienePendientes)
        {
            return $"No se puede {accion} este horario porque tiene {cantidad} cita(s) pendiente(s). Reprograma o cancela esas citas antes. Ejemplo: {ejemplo}.";
        }

        return $"No se puede {accion} este horario porque tiene {cantidad} cita(s) vigentes. Revisa la agenda antes de continuar.";
    }

    private static bool EstadoBloqueaHorario(EstadoCita estado)
        => estado == EstadoCita.PENDIENTE
           || estado == EstadoCita.CONFIRMADA
           || estado == EstadoCita.EN_CONSULTA;

    private static int NumeroDiaSemana(DateTime fecha)
        => fecha.DayOfWeek == DayOfWeek.Sunday ? 7 : (int)fecha.DayOfWeek;

    private static string NombreMascota(Cita cita)
        => string.IsNullOrWhiteSpace(cita.Mascota?.Nombre) ? "Cita" : cita.Mascota.Nombre;

    private static string EstadoTexto(EstadoCita estado)
        => estado switch
        {
            EstadoCita.PENDIENTE => "pendiente",
            EstadoCita.CONFIRMADA => "confirmada",
            EstadoCita.EN_CONSULTA => "en consulta",
            _ => estado.ToString().ToLowerInvariant()
        };

    private bool TieneSolapamiento(TimeOnly inicio, TimeOnly fin, int idExcluir, int dia)
        => listaHorarios.Any(h =>
            h.Activo &&
            h.Id != idExcluir &&
            h.DiaSemana == dia &&
            inicio < h.HoraFin &&
            fin > h.HoraInicio);

    private bool DiaOcupadoPorOtro(int dia, int idExcluir)
        => listaHorarios.Any(h => h.Id != idExcluir && h.DiaSemana == dia);

    private HorarioVeterinario CopiarHorario(HorarioVeterinario horario) => new()
    {
        Id = horario.Id,
        Veterinario = new Veterinario { Id = idVetSeleccionado },
        DiaSemana = horario.DiaSemana,
        HoraInicio = horario.HoraInicio,
        HoraFin = horario.HoraFin,
        HoraDescansoInicio = horario.HoraDescansoInicio,
        HoraDescansoFin = horario.HoraDescansoFin,
        Activo = horario.Activo
    };

    private static bool TryParseHora(string? valor, out TimeOnly hora)
        => TimeOnly.TryParse(valor, out hora);

    private async Task<int> ObtenerUsuarioActualId()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var raw = user.FindFirst("IdUsuario")?.Value
                  ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value
                  ?? user.FindFirst("nameid")?.Value;

        return int.TryParse(raw, out var id) ? id : 0;
    }

    private static string FormatoHora(TimeOnly hora) => hora.ToString("HH:mm");

    private static string FormatoDescanso(HorarioVeterinario horario)
        => horario.HoraDescansoInicio.HasValue && horario.HoraDescansoFin.HasValue
            ? $"{FormatoHora(horario.HoraDescansoInicio.Value)} - {FormatoHora(horario.HoraDescansoFin.Value)}"
            : "Sin refrigerio";

    private string GetNombreDia(int dia) => dia switch
    {
        1 => "Lunes",
        2 => "Martes",
        3 => "Miercoles",
        4 => "Jueves",
        5 => "Viernes",
        6 => "Sabado",
        7 => "Domingo",
        _ => "Desconocido"
    };
}
