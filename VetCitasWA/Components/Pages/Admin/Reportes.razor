@page "/consolidados"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "ADMINISTRADOR")]
@implements IDisposable
@using VetCitasWA.Servicios.Modelo.Cita
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.CitaRS.CitaRestService CitaService
@inject VetCitasWA.Servicios.REST.ClienteRS.ClienteRestService ClienteService
@inject IJSRuntime JS

<PageTitle>Consolidados - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">&gt;</span>
    <span class="crumb current">Consolidados</span>
</SectionContent>

<div class="page-section">

    <h1 class="page-title">Consolidados</h1>

    @if (pdfError is not null)
    {
        <div class="admin-alert" role="alert">@pdfError</div>
    }
    @if (pdfAviso is not null)
    {
        <div class="report-status" role="status">
            <div class="report-status-text">
                <strong>Exportacion PDF</strong>
                <span>@pdfAviso</span>
            </div>
            <button type="button" class="report-status-close" aria-label="Cerrar aviso" @onclick="CerrarAvisoPdf">x</button>
        </div>
    }

    <div class="reports-grid">

        <section class="report-card">
            <header class="report-head">
                <span class="report-icon report-icon-blue" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4 11H2v3h2zm5-4H7v7h2zm5-5v12h-2V2zm-2-1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zM6 7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1zm-5 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1z" />
                    </svg>
                </span>
                <h2 class="report-title">Consolidado de citas</h2>
            </header>

            <div class="report-body">
                <div class="filters-grid">
                    <div class="filter-field">
                        <label class="filter-label" for="rep1-fini">Fecha de inicio</label>
                        <input id="rep1-fini" type="date" class="filter-input" @bind="fechaInicioCitas" @bind:after="OcultarConsolidadoCitas" />
                    </div>
                    <div class="filter-field">
                        <label class="filter-label" for="rep1-ffin">Fecha de fin</label>
                        <input id="rep1-ffin" type="date" class="filter-input" @bind="fechaFinCitas" @bind:after="OcultarConsolidadoCitas" />
                    </div>
                    <div class="filter-field">
                        <label class="filter-label" for="rep1-estado">Estado</label>
                        <VcSelect TValue="string"
                                  Value="filtroEstado"
                                  ValueChanged="OnEstadoChanged"
                                  Options="OpcionesEstado" />
                    </div>
                    <div class="filter-field">
                        <label class="filter-label" for="rep1-servicio">Servicio</label>
                        <VcSelect TValue="string"
                                  Value="filtroServicio"
                                  ValueChanged="OnServicioChanged"
                                  Options="OpcionesServicio" />
                    </div>
                </div>

                <div class="report-actions">
                    <button type="button" class="btn-generar" @onclick="GenerarCitas" disabled="@cargandoCitas">
                        Generar consolidado
                    </button>
                </div>

                @if (citasGenerado)
                {
                    @if (!string.IsNullOrWhiteSpace(errorCitas))
                    {
                        <p class="estado-mensaje estado-error">@errorCitas</p>
                    }
                    else if (cargandoCitas)
                    {
                        <p class="estado-mensaje">Cargando consolidado...</p>
                    }
                    else
                    {
                        <div class="report-note">
                            <span class="report-note-label">Resumen del rango:</span>
                            @CitasFiltradas.Count cita(s), @TotalPorEstado(EstadoCita.ATENDIDA) atendida(s),
                            @TotalPorEstado(EstadoCita.CANCELADA) cancelada(s) y @TotalPorEstado(EstadoCita.NO_ASISTIO) no asistio.
                        </div>

                        <div class="records-wrapper">
                            <table class="records-table">
                                <thead>
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Mascota</th>
                                        <th>Cliente</th>
                                        <th>Veterinario</th>
                                        <th>Servicio</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!CitasFiltradas.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="estado-mensaje">No hay citas para el rango y filtros seleccionados.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var cita in CitasFiltradas.Take(12))
                                        {
                                            <tr>
                                                <td data-label="Fecha">@cita.FechaHoraInicio.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td data-label="Mascota">@(cita.Mascota?.Nombre ?? "-")</td>
                                                <td data-label="Cliente">@NombreCliente(cita)</td>
                                                <td data-label="Veterinario">@NombreVeterinario(cita)</td>
                                                <td data-label="Servicio">@(cita.Servicio?.Nombre ?? "-")</td>
                                                <td data-label="Estado"><span class="state @EstadoCss(cita.Estado)">@EstadoLabel(cita.Estado)</span></td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="report-actions">
                            <button type="button"
                                    class="btn-export-pdf @ClaseCooldownPdf"
                                    @onclick="ExportarPdfCitas"
                                    disabled="@(generandoPdf || PdfEnCooldown)"
                                    aria-disabled="@PdfEnCooldown"
                                    title="@TituloBotonPdf">
                                <span class="pdf-icon" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M5.5 7a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 1 0v-1h.5a1.5 1.5 0 0 0 0-3zm.5.5h.5a.5.5 0 0 1 0 1H6z" />
                                        <path d="M8 7.5A.5.5 0 0 1 8.5 7H10a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H8.5A.5.5 0 0 1 8 10.5zm1 .5v2h1V8z" />
                                        <path d="M11.5 7a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 1 0V9.5h.75a.5.5 0 0 0 0-1H12V8h1a.5.5 0 0 0 0-1z" />
                                        <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z" />
                                    </svg>
                                </span>
                                @TextoBotonPdf(TipoPdf.Citas)
                            </button>
                        </div>
                    }
                }
            </div>
        </section>

        <section class="report-card">
            <header class="report-head">
                <span class="report-icon report-icon-blue" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4 11H2v3h2zm5-4H7v7h2zm5-5v12h-2V2zm-2-1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zM6 7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1zm-5 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1z" />
                    </svg>
                </span>
                <h2 class="report-title">Clientes frecuentes</h2>
            </header>

            <div class="report-body">
                <div class="filters-grid">
                    <div class="filter-field">
                        <label class="filter-label" for="rep2-fini">Fecha de inicio</label>
                        <input id="rep2-fini" type="date" class="filter-input" @bind="fechaInicioClientes" @bind:after="OcultarConsolidadoClientes" />
                    </div>
                    <div class="filter-field">
                        <label class="filter-label" for="rep2-ffin">Fecha de fin</label>
                        <input id="rep2-ffin" type="date" class="filter-input" @bind="fechaFinClientes" @bind:after="OcultarConsolidadoClientes" />
                    </div>
                    <div class="filter-field filter-field-full">
                        <label class="filter-label" for="rep2-metrica">Minimo de citas</label>
                        <input id="rep2-metrica" type="number" class="filter-input" min="1" @bind="minimoCitasCliente" @bind:after="OcultarConsolidadoClientes" />
                    </div>
                </div>

                <div class="report-actions">
                    <button type="button" class="btn-generar" @onclick="GenerarClientes" disabled="@cargandoClientes">
                        Generar consolidado
                    </button>
                </div>

                @if (clientesGenerado)
                {
                    @if (!string.IsNullOrWhiteSpace(errorClientes))
                    {
                        <p class="estado-mensaje estado-error">@errorClientes</p>
                    }
                    else if (cargandoClientes)
                    {
                        <p class="estado-mensaje">Cargando clientes frecuentes...</p>
                    }
                    else
                    {
                        <div class="records-wrapper">
                            <table class="records-table">
                                <thead>
                                    <tr>
                                        <th>Cliente</th>
                                        <th>DNI</th>
                                        <th>Telefono</th>
                                        <th># Citas</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!ClientesFrecuentes.Any())
                                    {
                                        <tr>
                                            <td colspan="4" class="estado-mensaje">No hay clientes que superen la metrica en este rango.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var cliente in ClientesFrecuentes.Take(10))
                                        {
                                            <tr>
                                                <td data-label="Cliente">@cliente.Nombre</td>
                                                <td data-label="DNI">@cliente.Dni</td>
                                                <td data-label="Telefono">@cliente.Telefono</td>
                                                <td data-label="# Citas"><span class="count-badge">@cliente.TotalCitas</span></td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <p class="report-note">
                            <span class="report-note-label">Este consolidado incluye:</span>
                            clientes con al menos @Math.Max(1, minimoCitasCliente) cita(s) dentro del rango seleccionado.
                        </p>

                        <div class="report-actions">
                            <button type="button"
                                    class="btn-export-pdf @ClaseCooldownPdf"
                                    @onclick="ExportarPdfClientes"
                                    disabled="@(generandoPdf || PdfEnCooldown)"
                                    aria-disabled="@PdfEnCooldown"
                                    title="@TituloBotonPdf">
                                <span class="pdf-icon" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M5.5 7a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 1 0v-1h.5a1.5 1.5 0 0 0 0-3zm.5.5h.5a.5.5 0 0 1 0 1H6z" />
                                        <path d="M8 7.5A.5.5 0 0 1 8.5 7H10a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H8.5A.5.5 0 0 1 8 10.5zm1 .5v2h1V8z" />
                                        <path d="M11.5 7a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 1 0V9.5h.75a.5.5 0 0 0 0-1H12V8h1a.5.5 0 0 0 0-1z" />
                                        <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z" />
                                    </svg>
                                </span>
                                @TextoBotonPdf(TipoPdf.Clientes)
                            </button>
                        </div>
                    }
                }
            </div>
        </section>

    </div>

</div>

@code {
    private const int SegundosCooldownPowerBi = 259;
    private bool generandoPdf;
    private TipoPdf? pdfEnProceso;
    private string? pdfError;
    private string? pdfAviso;
    private DateTimeOffset? pdfBloqueadoHasta;
    private System.Threading.CancellationTokenSource? pdfCooldownCts;
    private System.Threading.CancellationTokenSource? pdfAvisoCts;

    private bool PdfEnCooldown => SegundosRestantesPdf > 0;
    private int SegundosRestantesPdf
    {
        get
        {
            if (pdfBloqueadoHasta is null) return 0;
            var restantes = (int)Math.Ceiling((pdfBloqueadoHasta.Value - DateTimeOffset.UtcNow).TotalSeconds);
            return Math.Max(0, restantes);
        }
    }

    private string ClaseCooldownPdf => PdfEnCooldown ? "btn-export-pdf-cooldown" : "";
    private string TituloBotonPdf => PdfEnCooldown
        ? $"Power BI permite una exportacion cada {SegundosCooldownPowerBi} segundos. Espera {TiempoRestantePdfTexto}."
        : "Exportar consolidado a PDF";

    private string TiempoRestantePdfTexto => FormatoEspera(SegundosRestantesPdf);

    private Task ExportarPdfCitas()
        => ExportarPdf(TipoPdf.Citas);

    private Task ExportarPdfClientes()
        => ExportarPdf(TipoPdf.Clientes);

    private async Task ExportarPdf(TipoPdf tipo)
    {
        if (PdfEnCooldown)
        {
            MostrarAvisoPdf($"Power BI permite generar un PDF cada {SegundosCooldownPowerBi} segundos. Espera {TiempoRestantePdfTexto} antes de intentar nuevamente.");
            pdfError = null;
            return;
        }

        generandoPdf = true;
        pdfEnProceso = tipo;
        pdfError = null;
        pdfAviso = null;
        try
        {
            var (fIni, fFin, estadoFiltro, servicioFiltro, archivo) = tipo == TipoPdf.Citas
                ? (fechaInicioCitas, fechaFinCitas, filtroEstado, filtroServicio, "consolidado-citas.pdf")
                : (fechaInicioClientes, fechaFinClientes, "TODOS", "TODOS", "clientes-frecuentes.pdf");
            var tipoReporte = tipo == TipoPdf.Clientes ? "clientes" : "citas";

            var partes = new List<string>();
            partes.Add($"tipo={tipoReporte}");
            partes.Add($"fechaInicio={fIni:yyyy-MM-dd}");
            partes.Add($"fechaFin={fFin:yyyy-MM-dd}");
            if (!string.IsNullOrWhiteSpace(estadoFiltro) && estadoFiltro != "TODOS")
                partes.Add($"estado={Uri.EscapeDataString(estadoFiltro)}");
            if (!string.IsNullOrWhiteSpace(servicioFiltro) && servicioFiltro != "TODOS")
                partes.Add($"servicio={Uri.EscapeDataString(servicioFiltro)}");
            if (tipo == TipoPdf.Clientes)
                partes.Add($"minimoCitas={Math.Max(1, minimoCitasCliente)}");

            var url = "/consolidados/pdf" + (partes.Count > 0 ? "?" + string.Join("&", partes) : "");

            // El endpoint hace la exportacion en el servidor y devuelve el archivo;
            // el helper JS dispara la descarga con la cookie de sesion.
            await JS.InvokeVoidAsync("descargarArchivo", url, archivo);
            IniciarCooldownPdf(SegundosCooldownPowerBi);
            MostrarAvisoPdf($"PDF generado. Podras exportar otro en {TiempoRestantePdfTexto}.");
        }
        catch (Exception ex)
        {
            var segundos = ExtraerSegundosEspera(ex.Message);
            if (segundos > 0)
            {
                // Limite de Power BI (429): se bloquea el boton con el tiempo de espera
                // que indica el propio error y NO se muestra el HTTP 500 crudo.
                IniciarCooldownPdf(segundos);
                MostrarAvisoPdf($"Power BI esta limitando las exportaciones. Espera {TiempoRestantePdfTexto} antes de volver a generar un PDF.");
                pdfError = null;
            }
            else
            {
                // Otros errores si se muestran con su detalle real.
                pdfError = $"No se pudo generar el PDF. {ex.Message}";
            }
        }
        finally
        {
            generandoPdf = false;
            pdfEnProceso = null;
        }
    }

    private void MostrarAvisoPdf(string mensaje)
    {
        pdfAviso = mensaje;
        pdfAvisoCts?.Cancel();
        pdfAvisoCts?.Dispose();
        pdfAvisoCts = new System.Threading.CancellationTokenSource();
        _ = OcultarAvisoPdfAsync(pdfAvisoCts.Token);
    }

    private async Task OcultarAvisoPdfAsync(System.Threading.CancellationToken token)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(7), token);
            if (!token.IsCancellationRequested)
            {
                pdfAviso = null;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException)
        {
        }
    }

    private void CerrarAvisoPdf()
    {
        pdfAvisoCts?.Cancel();
        pdfAviso = null;
    }

    private string TextoBotonPdf(TipoPdf tipo)
    {
        if (generandoPdf && pdfEnProceso == tipo)
        {
            return "Generando PDF...";
        }

        if (PdfEnCooldown)
        {
            return $"PDF en {TiempoRestantePdfTexto}";
        }

        return "Exportar a PDF";
    }

    private void IniciarCooldownPdf(int segundos)
    {
        if (segundos <= 0) return;

        pdfBloqueadoHasta = DateTimeOffset.UtcNow.AddSeconds(segundos);
        pdfCooldownCts?.Cancel();
        pdfCooldownCts?.Dispose();
        pdfCooldownCts = new System.Threading.CancellationTokenSource();
        _ = ActualizarCooldownPdfAsync(pdfCooldownCts.Token);
    }

    private async Task ActualizarCooldownPdfAsync(System.Threading.CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested && PdfEnCooldown)
            {
                await InvokeAsync(StateHasChanged);
                await Task.Delay(1000, token);
            }
        }
        catch (TaskCanceledException)
        {
            return;
        }

        if (!token.IsCancellationRequested)
        {
            pdfBloqueadoHasta = null;
            if (pdfAviso is not null && pdfAviso.Contains("Espera", StringComparison.OrdinalIgnoreCase))
            {
                pdfAviso = null;
            }
            await InvokeAsync(StateHasChanged);
        }
    }

    private static int ExtraerSegundosEspera(string? texto)
    {
        if (string.IsNullOrWhiteSpace(texto)) return 0;

        var match = System.Text.RegularExpressions.Regex.Match(texto, @"(\d+)\s*segundo", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (match.Success && int.TryParse(match.Groups[1].Value, out var segundos))
        {
            return Math.Max(1, segundos);
        }

        match = System.Text.RegularExpressions.Regex.Match(texto, @"(\d+)\s*min", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (match.Success && int.TryParse(match.Groups[1].Value, out var minutos))
        {
            return Math.Max(1, minutos * 60);
        }

        return texto.Contains("limitando", StringComparison.OrdinalIgnoreCase) ? SegundosCooldownPowerBi : 0;
    }

    private static string FormatoEspera(int segundos)
    {
        if (segundos <= 0) return "0 s";
        var minutos = segundos / 60;
        var resto = segundos % 60;

        if (minutos <= 0) return $"{resto} s";
        if (resto == 0) return $"{minutos} min";
        return $"{minutos} min {resto:00} s";
    }

    private readonly DateTime hoy = DateTime.Today;
    private DateTime fechaInicioCitas = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime fechaFinCitas = DateTime.Today;
    private DateTime fechaInicioClientes = DateTime.Today.AddMonths(-5).Date;
    private DateTime fechaFinClientes = DateTime.Today;
    private string filtroEstado = "TODOS";
    private string filtroServicio = "TODOS";
    private int minimoCitasCliente = 2;
    private bool cargandoCitas;
    private bool cargandoClientes;
    // La tabla y el boton de exportar solo aparecen tras pulsar "Generar consolidado".
    private bool citasGenerado;
    private bool clientesGenerado;
    private string? errorCitas;
    private string? errorClientes;
    private List<Cita> citasBase = new();
    private List<Cita> citasClientes = new();
    private List<string> serviciosDisponibles = new();
    // telefono no vienen en el cliente anidado de las citas; se enriquecen
    // con la lista completa de clientes (id -> cliente).
    private Dictionary<int, VetCitasWA.Servicios.Modelo.Cliente.Cliente> clientesPorId = new();

    private static readonly IEnumerable<VcSelectOption<string>> OpcionesEstado = new[]
    {
        new VcSelectOption<string>("TODOS", "Todos"),
        new VcSelectOption<string>("PENDIENTE", "Pendiente"),
        new VcSelectOption<string>("CONFIRMADA", "Confirmada"),
        new VcSelectOption<string>("EN_CONSULTA", "En consulta"),
        new VcSelectOption<string>("ATENDIDA", "Atendida"),
        new VcSelectOption<string>("CANCELADA", "Cancelada"),
        new VcSelectOption<string>("NO_ASISTIO", "No asistio")
    };

    private IEnumerable<VcSelectOption<string>> OpcionesServicio
        => new[] { new VcSelectOption<string>("TODOS", "Todos") }
            .Concat(serviciosDisponibles.Select(s => new VcSelectOption<string>(s, s)));

    private List<Cita> CitasFiltradas
        => citasBase
            .Where(c => filtroServicio == "TODOS" || string.Equals(c.Servicio?.Nombre, filtroServicio, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(c => c.FechaHoraInicio)
            .ToList();

    private List<ClienteFrecuenteVm> ClientesFrecuentes
        => citasClientes
            .Where(c => c.Mascota?.Cliente is not null)
            .GroupBy(c => c.Mascota.Cliente.Id > 0
                ? c.Mascota.Cliente.Id.ToString()
                : $"{c.Mascota.Cliente.Dni}|{c.Mascota.Cliente.Nombres}|{c.Mascota.Cliente.Apellidos}")
            .Select(g =>
            {
                var cliente = g.First().Mascota.Cliente;
                // El cliente anidado en la cita no trae telefono: se completan
                // desde la lista maestra de clientes por Id cuando estan vacios.
                var maestro = cliente.Id > 0 && clientesPorId.TryGetValue(cliente.Id, out var m) ? m : null;
                var dni = !string.IsNullOrWhiteSpace(cliente.Dni) ? cliente.Dni : maestro?.Dni;
                var telefono = !string.IsNullOrWhiteSpace(cliente.Telefono) ? cliente.Telefono : maestro?.Telefono;
                return new ClienteFrecuenteVm(
                    $"{cliente.Nombres} {cliente.Apellidos}".Trim(),
                    string.IsNullOrWhiteSpace(dni) ? "-" : dni,
                    string.IsNullOrWhiteSpace(telefono) ? "-" : telefono,
                    g.Count());
            })
            .Where(c => c.TotalCitas >= Math.Max(1, minimoCitasCliente))
            .OrderByDescending(c => c.TotalCitas)
            .ThenBy(c => c.Nombre)
            .ToList();

    // No se consulta nada al cargar la pagina: la API solo se llama al pulsar
    // "Generar consolidado" (ahorro de queries).
    private void OnEstadoChanged(string value)
    {
        // Solo guarda el filtro; se aplicara en la siguiente generacion.
        filtroEstado = value;
        citasGenerado = false;
    }

    private Task OnServicioChanged(string value)
    {
        filtroServicio = value;
        citasGenerado = false;
        return Task.CompletedTask;
    }

    // Al cambiar cualquier filtro, se oculta el consolidado generado previamente
    // (hay que volver a pulsar "Generar consolidado" para ver los nuevos resultados).
    private void OcultarConsolidadoCitas() => citasGenerado = false;
    private void OcultarConsolidadoClientes() => clientesGenerado = false;

    // Dispara la generacion del consolidado: muestra la tabla y el boton de exportar.
    private async Task GenerarCitas()
    {
        citasGenerado = true;
        await CargarCitasAsync();
    }

    private async Task CargarCitasAsync()
    {
        if (!ValidarRango(fechaInicioCitas, fechaFinCitas, out errorCitas))
        {
            citasBase = new();
            return;
        }

        cargandoCitas = true;
        errorCitas = null;

        try
        {
            var estado = filtroEstado == "TODOS" ? "" : filtroEstado;
            citasBase = await Task.Run(() => CitaService.ListarFiltradas(0, fechaInicioCitas, fechaFinCitas, estado, ""));
            serviciosDisponibles = citasBase
                .Select(c => c.Servicio?.Nombre)
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(s => s)
                .ToList()!;

            if (filtroServicio != "TODOS" && !serviciosDisponibles.Contains(filtroServicio, StringComparer.OrdinalIgnoreCase))
            {
                filtroServicio = "TODOS";
            }
        }
        catch (Exception ex)
        {
            citasBase = new();
            serviciosDisponibles = new();
            errorCitas = $"No se pudo cargar el consolidado de citas. {ex.Message}";
        }
        finally
        {
            cargandoCitas = false;
        }
    }

    private async Task GenerarClientes()
    {
        clientesGenerado = true;
        await CargarClientesAsync();
    }

    private async Task CargarClientesAsync()
    {
        if (!ValidarRango(fechaInicioClientes, fechaFinClientes, out errorClientes))
        {
            citasClientes = new();
            return;
        }

        cargandoClientes = true;
        errorClientes = null;

        try
        {
            citasClientes = await Task.Run(() => CitaService.ListarFiltradas(0, fechaInicioClientes, fechaFinClientes, "", ""));
            if (clientesPorId.Count == 0)
            {
                var todos = await Task.Run(() => ClienteService.ListarTodos());
                clientesPorId = todos
                    .Where(c => c.Id > 0)
                    .GroupBy(c => c.Id)
                    .ToDictionary(g => g.Key, g => g.First());
            }
        }
        catch (Exception ex)
        {
            citasClientes = new();
            errorClientes = $"No se pudo cargar el consolidado de clientes. {ex.Message}";
        }
        finally
        {
            cargandoClientes = false;
        }
    }

    private static bool ValidarRango(DateTime inicio, DateTime fin, out string? error)
    {
        error = null;
        if (inicio.Date > fin.Date)
        {
            error = "La fecha de inicio no puede ser posterior a la fecha de fin.";
            return false;
        }

        return true;
    }

    private int TotalPorEstado(EstadoCita estado) => CitasFiltradas.Count(c => c.Estado == estado);

    private static string NombreCliente(Cita cita)
    {
        var cliente = cita.Mascota?.Cliente;
        return cliente is null ? "-" : $"{cliente.Nombres} {cliente.Apellidos}".Trim();
    }

    private static string NombreVeterinario(Cita cita)
        => cita.Veterinario is null ? "-" : $"{cita.Veterinario.Nombres} {cita.Veterinario.Apellidos}".Trim();

    private static string EstadoLabel(EstadoCita estado) => estado switch
    {
        EstadoCita.PENDIENTE => "Pendiente",
        EstadoCita.CONFIRMADA => "Confirmada",
        EstadoCita.EN_CONSULTA => "En consulta",
        EstadoCita.ATENDIDA => "Atendida",
        EstadoCita.CANCELADA => "Cancelada",
        EstadoCita.NO_ASISTIO => "No asistio",
        _ => estado.ToString()
    };

    private static string EstadoCss(EstadoCita estado) => estado switch
    {
        EstadoCita.ATENDIDA => "state-attended",
        EstadoCita.CANCELADA => "state-cancelled",
        EstadoCita.NO_ASISTIO => "state-noshow",
        EstadoCita.EN_CONSULTA => "state-progress",
        _ => "state-pending"
    };

    private sealed record ClienteFrecuenteVm(string Nombre, string Dni, string Telefono, int TotalCitas);

    private enum TipoPdf
    {
        Citas,
        Clientes
    }

    public void Dispose()
    {
        pdfCooldownCts?.Cancel();
        pdfCooldownCts?.Dispose();
        pdfAvisoCts?.Cancel();
        pdfAvisoCts?.Dispose();
    }
