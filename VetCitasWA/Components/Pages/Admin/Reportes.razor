@page "/consolidados"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "ADMINISTRADOR")]
@using VetCitasWA.Servicios.Modelo.Cita
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.CitaRS.CitaRestService CitaService
@inject VetCitasWA.Servicios.REST.ClienteRS.ClienteRestService ClienteService
@inject IJSRuntime JS

<PageTitle>Consolidados - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">&gt;</span>
    <span class="crumb current">Consolidados</span>
</SectionContent>

<div class="page-section">

    <h1 class="page-title">Consolidados</h1>

    @if (pdfError is not null)
    {
        <div class="admin-alert" role="alert">@pdfError</div>
    }

    <div class="reports-grid">

        <section class="report-card">
            <header class="report-head">
                <span class="report-icon report-icon-blue" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4 11H2v3h2zm5-4H7v7h2zm5-5v12h-2V2zm-2-1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zM6 7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1zm-5 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1z" />
                    </svg>
                </span>
                <h2 class="report-title">Consolidado de citas</h2>
            </header>

            <div class="report-body">
                <div class="filters-grid">
                    <div class="filter-field">
                        <label class="filter-label" for="rep1-fini">Fecha de inicio</label>
                        <input id="rep1-fini" type="date" class="filter-input" @bind="fechaInicioCitas" @bind:after="CargarCitasAsync" />
                    </div>
                    <div class="filter-field">
                        <label class="filter-label" for="rep1-ffin">Fecha de fin</label>
                        <input id="rep1-ffin" type="date" class="filter-input" @bind="fechaFinCitas" @bind:after="CargarCitasAsync" />
                    </div>
                    <div class="filter-field">
                        <label class="filter-label" for="rep1-estado">Estado</label>
                        <VcSelect TValue="string"
                                  Value="filtroEstado"
                                  ValueChanged="OnEstadoChanged"
                                  Options="OpcionesEstado" />
                    </div>
                    <div class="filter-field">
                        <label class="filter-label" for="rep1-servicio">Servicio</label>
                        <VcSelect TValue="string"
                                  Value="filtroServicio"
                                  ValueChanged="OnServicioChanged"
                                  Options="OpcionesServicio" />
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(errorCitas))
                {
                    <p class="estado-mensaje estado-error">@errorCitas</p>
                }
                else if (cargandoCitas)
                {
                    <p class="estado-mensaje">Cargando consolidado...</p>
                }
                else
                {
                    <div class="report-note">
                        <span class="report-note-label">Resumen del rango:</span>
                        @CitasFiltradas.Count cita(s), @TotalPorEstado(EstadoCita.ATENDIDA) atendida(s),
                        @TotalPorEstado(EstadoCita.CANCELADA) cancelada(s) y @TotalPorEstado(EstadoCita.NO_ASISTIO) no asistio.
                    </div>

                    <div class="records-wrapper">
                        <table class="records-table">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Mascota</th>
                                    <th>Cliente</th>
                                    <th>Veterinario</th>
                                    <th>Servicio</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!CitasFiltradas.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="estado-mensaje">No hay citas para el rango y filtros seleccionados.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var cita in CitasFiltradas.Take(12))
                                    {
                                        <tr>
                                            <td data-label="Fecha">@cita.FechaHoraInicio.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td data-label="Mascota">@(cita.Mascota?.Nombre ?? "-")</td>
                                            <td data-label="Cliente">@NombreCliente(cita)</td>
                                            <td data-label="Veterinario">@NombreVeterinario(cita)</td>
                                            <td data-label="Servicio">@(cita.Servicio?.Nombre ?? "-")</td>
                                            <td data-label="Estado"><span class="state @EstadoCss(cita.Estado)">@EstadoLabel(cita.Estado)</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="report-actions">
                    <button type="button" class="btn-generar" @onclick="CargarCitasAsync" disabled="@cargandoCitas">
                        Generar consolidado
                    </button>
                    <button type="button" class="btn-export-pdf" @onclick="ExportarPdfCitas" disabled="@generandoPdf">
                        @(generandoPdf ? "Generando PDF…" : "Exportar a PDF")
                    </button>
                </div>
            </div>
        </section>

        <section class="report-card">
            <header class="report-head">
                <span class="report-icon report-icon-blue" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4 11H2v3h2zm5-4H7v7h2zm5-5v12h-2V2zm-2-1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zM6 7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1zm-5 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1z" />
                    </svg>
                </span>
                <h2 class="report-title">Clientes frecuentes</h2>
            </header>

            <div class="report-body">
                <div class="filters-grid">
                    <div class="filter-field">
                        <label class="filter-label" for="rep2-fini">Fecha de inicio</label>
                        <input id="rep2-fini" type="date" class="filter-input" @bind="fechaInicioClientes" @bind:after="CargarClientesAsync" />
                    </div>
                    <div class="filter-field">
                        <label class="filter-label" for="rep2-ffin">Fecha de fin</label>
                        <input id="rep2-ffin" type="date" class="filter-input" @bind="fechaFinClientes" @bind:after="CargarClientesAsync" />
                    </div>
                    <div class="filter-field filter-field-full">
                        <label class="filter-label" for="rep2-metrica">Minimo de citas</label>
                        <input id="rep2-metrica" type="number" class="filter-input" min="1" @bind="minimoCitasCliente" />
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(errorClientes))
                {
                    <p class="estado-mensaje estado-error">@errorClientes</p>
                }
                else if (cargandoClientes)
                {
                    <p class="estado-mensaje">Cargando clientes frecuentes...</p>
                }
                else
                {
                    <div class="records-wrapper">
                        <table class="records-table">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th>DNI</th>
                                    <th>Telefono</th>
                                    <th># Citas</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!ClientesFrecuentes.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="estado-mensaje">No hay clientes que superen la metrica en este rango.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var cliente in ClientesFrecuentes.Take(10))
                                    {
                                        <tr>
                                            <td data-label="Cliente">@cliente.Nombre</td>
                                            <td data-label="DNI">@cliente.Dni</td>
                                            <td data-label="Telefono">@cliente.Telefono</td>
                                            <td data-label="# Citas"><span class="count-badge">@cliente.TotalCitas</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <button type="button" class="btn-generar" @onclick="CargarClientesAsync" disabled="@cargandoClientes">
                    Generar consolidado
                </button>

                <p class="report-note">
                    <span class="report-note-label">Este consolidado incluye:</span>
                    clientes con al menos @Math.Max(1, minimoCitasCliente) cita(s) dentro del rango seleccionado.
                </p>
            </div>
        </section>

    </div>

</div>

@code {
    private bool generandoPdf;
    private string? pdfError;

    // Exporta el consolidado de citas con sus filtros (fechas, estado, servicio).
    private Task ExportarPdfCitas()
        => ExportarPdf(fechaInicioCitas, fechaFinCitas, filtroEstado, filtroServicio);

    private async Task ExportarPdf(DateTime fIni, DateTime fFin, string estadoFiltro, string servicioFiltro)
    {
        generandoPdf = true;
        pdfError = null;
        try
        {
            var url = "/consolidados/pdf"
                + $"?fechaInicio={fIni:yyyy-MM-dd}"
                + $"&fechaFin={fFin:yyyy-MM-dd}"
                + $"&estado={Uri.EscapeDataString(estadoFiltro ?? "TODOS")}"
                + $"&servicio={Uri.EscapeDataString(servicioFiltro ?? "TODOS")}";

            // El endpoint hace la exportacion en el servidor y devuelve el archivo;
            // el helper JS dispara la descarga con la cookie de sesion.
            await JS.InvokeVoidAsync("descargarArchivo", url, "consolidados.pdf");
        }
        catch (Exception ex)
        {
            // Se muestra el detalle real (incluye el mensaje que devuelve Power BI).
            pdfError = $"No se pudo generar el PDF. {ex.Message}";
        }
        finally
        {
            generandoPdf = false;
        }
    }

    private readonly DateTime hoy = DateTime.Today;
    private DateTime fechaInicioCitas = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime fechaFinCitas = DateTime.Today;
    private DateTime fechaInicioClientes = DateTime.Today.AddMonths(-5).Date;
    private DateTime fechaFinClientes = DateTime.Today;
    private string filtroEstado = "TODOS";
    private string filtroServicio = "TODOS";
    private int minimoCitasCliente = 2;
    private bool cargandoCitas;
    private bool cargandoClientes;
    private string? errorCitas;
    private string? errorClientes;
    private List<Cita> citasBase = new();
    private List<Cita> citasClientes = new();
    private List<string> serviciosDisponibles = new();
    // DNI/telefono no vienen en el cliente anidado de las citas; se enriquecen
    // con la lista completa de clientes (id -> cliente).
    private Dictionary<int, VetCitasWA.Servicios.Modelo.Cliente.Cliente> clientesPorId = new();

    private static readonly IEnumerable<VcSelectOption<string>> OpcionesEstado = new[]
    {
        new VcSelectOption<string>("TODOS", "Todos"),
        new VcSelectOption<string>("PENDIENTE", "Pendiente"),
        new VcSelectOption<string>("CONFIRMADA", "Confirmada"),
        new VcSelectOption<string>("EN_CONSULTA", "En consulta"),
        new VcSelectOption<string>("ATENDIDA", "Atendida"),
        new VcSelectOption<string>("CANCELADA", "Cancelada"),
        new VcSelectOption<string>("NO_ASISTIO", "No asistio")
    };

    private IEnumerable<VcSelectOption<string>> OpcionesServicio
        => new[] { new VcSelectOption<string>("TODOS", "Todos") }
            .Concat(serviciosDisponibles.Select(s => new VcSelectOption<string>(s, s)));

    private List<Cita> CitasFiltradas
        => citasBase
            .Where(c => filtroServicio == "TODOS" || string.Equals(c.Servicio?.Nombre, filtroServicio, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(c => c.FechaHoraInicio)
            .ToList();

    private List<ClienteFrecuenteVm> ClientesFrecuentes
        => citasClientes
            .Where(c => c.Mascota?.Cliente is not null)
            .GroupBy(c => c.Mascota.Cliente.Id > 0
                ? c.Mascota.Cliente.Id.ToString()
                : $"{c.Mascota.Cliente.Dni}|{c.Mascota.Cliente.Nombres}|{c.Mascota.Cliente.Apellidos}")
            .Select(g =>
            {
                var cliente = g.First().Mascota.Cliente;
                // El cliente anidado en la cita no trae DNI/telefono: se completan
                // desde la lista maestra de clientes por Id cuando estan vacios.
                var maestro = cliente.Id > 0 && clientesPorId.TryGetValue(cliente.Id, out var m) ? m : null;
                var dni = !string.IsNullOrWhiteSpace(cliente.Dni) ? cliente.Dni : maestro?.Dni;
                var telefono = !string.IsNullOrWhiteSpace(cliente.Telefono) ? cliente.Telefono : maestro?.Telefono;
                return new ClienteFrecuenteVm(
                    $"{cliente.Nombres} {cliente.Apellidos}".Trim(),
                    string.IsNullOrWhiteSpace(dni) ? "-" : dni,
                    string.IsNullOrWhiteSpace(telefono) ? "-" : telefono,
                    g.Count());
            })
            .Where(c => c.TotalCitas >= Math.Max(1, minimoCitasCliente))
            .OrderByDescending(c => c.TotalCitas)
            .ThenBy(c => c.Nombre)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        await CargarCitasAsync();
        await CargarClientesAsync();
    }

    private async Task OnEstadoChanged(string value)
    {
        filtroEstado = value;
        await CargarCitasAsync();
    }

    private Task OnServicioChanged(string value)
    {
        filtroServicio = value;
        return Task.CompletedTask;
    }

    private async Task CargarCitasAsync()
    {
        if (!ValidarRango(fechaInicioCitas, fechaFinCitas, out errorCitas))
        {
            citasBase = new();
            return;
        }

        cargandoCitas = true;
        errorCitas = null;

        try
        {
            var estado = filtroEstado == "TODOS" ? "" : filtroEstado;
            citasBase = await Task.Run(() => CitaService.ListarFiltradas(0, fechaInicioCitas, fechaFinCitas, estado, ""));
            serviciosDisponibles = citasBase
                .Select(c => c.Servicio?.Nombre)
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(s => s)
                .ToList()!;

            if (filtroServicio != "TODOS" && !serviciosDisponibles.Contains(filtroServicio, StringComparer.OrdinalIgnoreCase))
            {
                filtroServicio = "TODOS";
            }
        }
        catch (Exception ex)
        {
            citasBase = new();
            serviciosDisponibles = new();
            errorCitas = $"No se pudo cargar el consolidado de citas. {ex.Message}";
        }
        finally
        {
            cargandoCitas = false;
        }
    }

    private async Task CargarClientesAsync()
    {
        if (!ValidarRango(fechaInicioClientes, fechaFinClientes, out errorClientes))
        {
            citasClientes = new();
            return;
        }

        cargandoClientes = true;
        errorClientes = null;

        try
        {
            citasClientes = await Task.Run(() => CitaService.ListarFiltradas(0, fechaInicioClientes, fechaFinClientes, "", ""));
            if (clientesPorId.Count == 0)
            {
                var todos = await Task.Run(() => ClienteService.ListarTodos());
                clientesPorId = todos
                    .Where(c => c.Id > 0)
                    .GroupBy(c => c.Id)
                    .ToDictionary(g => g.Key, g => g.First());
            }
        }
        catch (Exception ex)
        {
            citasClientes = new();
            errorClientes = $"No se pudo cargar el consolidado de clientes. {ex.Message}";
        }
        finally
        {
            cargandoClientes = false;
        }
    }

    private static bool ValidarRango(DateTime inicio, DateTime fin, out string? error)
    {
        error = null;
        if (inicio.Date > fin.Date)
        {
            error = "La fecha de inicio no puede ser posterior a la fecha de fin.";
            return false;
        }

        return true;
    }

    private int TotalPorEstado(EstadoCita estado) => CitasFiltradas.Count(c => c.Estado == estado);

    private static string NombreCliente(Cita cita)
    {
        var cliente = cita.Mascota?.Cliente;
        return cliente is null ? "-" : $"{cliente.Nombres} {cliente.Apellidos}".Trim();
    }

    private static string NombreVeterinario(Cita cita)
        => cita.Veterinario is null ? "-" : $"{cita.Veterinario.Nombres} {cita.Veterinario.Apellidos}".Trim();

    private static string EstadoLabel(EstadoCita estado) => estado switch
    {
        EstadoCita.PENDIENTE => "Pendiente",
        EstadoCita.CONFIRMADA => "Confirmada",
        EstadoCita.EN_CONSULTA => "En consulta",
        EstadoCita.ATENDIDA => "Atendida",
        EstadoCita.CANCELADA => "Cancelada",
        EstadoCita.NO_ASISTIO => "No asistio",
        _ => estado.ToString()
    };

    private static string EstadoCss(EstadoCita estado) => estado switch
    {
        EstadoCita.ATENDIDA => "state-attended",
        EstadoCita.CANCELADA => "state-cancelled",
        EstadoCita.NO_ASISTIO => "state-noshow",
        EstadoCita.EN_CONSULTA => "state-progress",
        _ => "state-pending"
    };

    private sealed record ClienteFrecuenteVm(string Nombre, string Dni, string Telefono, int TotalCitas);
}
