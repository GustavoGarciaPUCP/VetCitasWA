    private async Task GuardarNuevoAsync()
    {
        if (usuarioNuevo is null)
        {
            return;
        }

        // Toma el numero internacional (con codigo de pais) del campo con banderas.
        if (phoneInputNuevo is not null)
        {
            var num = await phoneInputNuevo.GetNumberAsync();
            if (!string.IsNullOrWhiteSpace(num)) usuarioNuevo.Telefono = num;
        }

        var error = ValidarNuevoUsuario();
        if (error is not null)
        {
            Toasts.Error(error);
            return;
        }

        // Verificacion final de username unico, por si no se disparo el chequeo en linea.
        if (await AdminService.ExisteUsernameAsync(usuarioNuevo.Username ?? ""))
        {
            usernameError = "Este nombre de usuario ya está en uso.";
            Toasts.Error(usernameError);
            return;
        }

        await EjecutarOperacionAsync(() =>
        {
            var auditor = new Usuario { Id = usuarioActualId };
            var idCreado = RolPrincipalEfectivo switch
            {
                CodigoRol.ADMINISTRADOR => AdminService.Insertar(new Administrador
                {
                    Username = usuarioNuevo.Username,
                    ContrasenaHash = passwordNuevo,
                    Nombres = usuarioNuevo.Nombres,
                    Apellidos = usuarioNuevo.Apellidos,
                    Telefono = usuarioNuevo.Telefono,
                    Email = usuarioNuevo.Email,
                    Activo = true,
                    Area = areaAdminNuevo,
                    EsSuperAdmin = false,
                    ModifiedBy = auditor
                }),
                CodigoRol.RECEPCIONISTA => RecepcionistaService.Insertar(new Recepcionista
                {
                    Username = usuarioNuevo.Username,
                    ContrasenaHash = passwordNuevo,
                    Nombres = usuarioNuevo.Nombres,
                    Apellidos = usuarioNuevo.Apellidos,
                    Telefono = usuarioNuevo.Telefono,
                    Email = usuarioNuevo.Email,
                    Activo = true,
                    Area = areaRecepNuevo,
                    ModifiedBy = auditor
                }),
                _ => VeterinarioService.Insertar(new Veterinario
                {
                    Username = usuarioNuevo.Username,
                    ContrasenaHash = passwordNuevo,
                    Nombres = usuarioNuevo.Nombres,
                    Apellidos = usuarioNuevo.Apellidos,
                    Telefono = usuarioNuevo.Telefono,
                    Email = usuarioNuevo.Email,
                    Activo = true,
                    Cmp = cmpvNuevo,
                    Especialidad = especialidadNuevo,
                    ModifiedBy = auditor
                })
            };

            if (idCreado <= 0)
            {
                throw new InvalidOperationException("El backend no confirmo la creacion del usuario.");
            }

            // Asigna los demas roles seleccionados (ademas del subtipo principal).
            foreach (var rolExtra in rolesSeleccionados.Where(r => r != RolPrincipalEfectivo))
            {
                AdminService.AsignarRol(idCreado, rolExtra.ToString());
            }

            // asignar_rol crea la fila de subtipo con area vacia; aqui se guarda el
            // area capturada en el formulario para los subtipos administrativos que
            // se asignaron como rol secundario (no son el subtipo principal).
            if (RolPrincipalEfectivo != CodigoRol.ADMINISTRADOR
                && rolesSeleccionados.Contains(CodigoRol.ADMINISTRADOR))
            {
                AdminService.Modificar(new Administrador
                {
                    Id = idCreado,
                    Username = usuarioNuevo.Username,
                    ContrasenaHash = passwordNuevo,
                    Nombres = usuarioNuevo.Nombres,
                    Apellidos = usuarioNuevo.Apellidos,
                    Telefono = usuarioNuevo.Telefono,
                    Email = usuarioNuevo.Email,
                    Activo = true,
                    Area = areaAdminNuevo,
                    EsSuperAdmin = false,
                    ModifiedBy = auditor
                });
            }

            if (RolPrincipalEfectivo != CodigoRol.RECEPCIONISTA
                && rolesSeleccionados.Contains(CodigoRol.RECEPCIONISTA))
            {
                RecepcionistaService.Modificar(new Recepcionista
                {
                    Id = idCreado,
                    Username = usuarioNuevo.Username,
                    ContrasenaHash = passwordNuevo,
                    Nombres = usuarioNuevo.Nombres,
                    Apellidos = usuarioNuevo.Apellidos,
                    Telefono = usuarioNuevo.Telefono,
                    Email = usuarioNuevo.Email,
                    Activo = true,
                    Area = areaRecepNuevo,
                    ModifiedBy = auditor
                });
            }

            Toasts.Exito(rolesSeleccionados.Count > 1
                ? "Usuario creado con sus roles."
                : "Usuario creado.");
        });

        // Solo cierra el modal si la operacion fue exitosa; ante error se mantiene
        // abierto con los datos para que el usuario pueda corregir.
        if (errorMensaje is null)
        {
            usuarioNuevo = null;
            paginaActual = 1;
            await CargarUsuariosAsync();
        }
    }

