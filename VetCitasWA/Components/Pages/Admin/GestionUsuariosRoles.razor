    }

    private async Task RestablecerContrasenaAsync()
    {
        if (usuarioEditando is null) return;

        if (usuarioEditando.Id == usuarioActualId)
        {
            Toasts.Error("No puedes restablecer tu propia contrasena desde aqui.");
            return;
        }
        if (EsSuperAdminUsuario(usuarioEditando))
        {
            Toasts.Error("No se puede restablecer la contrasena del SuperAdmin.");
            return;
        }
        if (!usuarioEditando.Activo)
        {
            Toasts.Error("El usuario debe estar activo para restablecer su contrasena.");
            return;
        }

        var pass = (nuevaPasswordReset ?? "").Trim();
        if (pass.Length < 8)
        {
            Toasts.Error("La nueva contrasena debe tener al menos 8 caracteres.");
            return;
        }

        var idObjetivo = usuarioEditando.Id;
        await EjecutarOperacionAsync(() =>
        {
            UsuarioService.RestablecerContrasena(idObjetivo, pass, usuarioActualId);
            Toasts.Exito("Contrasena restablecida.");
        });

        nuevaPasswordReset = "";
    }

    // Validacion de username unico (en linea, dentro del modal).
    private string? usernameError;
    private bool verificandoUsername;
    private System.Threading.CancellationTokenSource? usernameDebounceCts;

    private async Task OnUsernameChanged()
    {
        usernameError = null;
        var actual = (usuarioNuevo?.Username ?? "").Trim();

        usernameDebounceCts?.Cancel();
        if (actual.Length < 4)
        {
            verificandoUsername = false;
            return;
        }

        usernameDebounceCts = new System.Threading.CancellationTokenSource();
        var token = usernameDebounceCts.Token;
        verificandoUsername = true;

        try
        {
            await Task.Delay(500, token);
            var existe = await AdminService.ExisteUsernameAsync(actual);
            if (token.IsCancellationRequested) return;
            usernameError = existe ? "Este nombre de usuario ya está en uso." : null;
        }
        catch (TaskCanceledException) { /* se siguio escribiendo */ }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                verificandoUsername = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

