@page "/usuarios-roles"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "ADMINISTRADOR")]
@implements IDisposable
@using System.Security.Claims
@using VetCitasWA.Servicios.Modelo.Common.Enums
@using VetCitasWA.Servicios.Modelo.Usuario
@inject AuthenticationStateProvider AuthStateProvider
@inject VetCitasWA.Servicios.REST.UsuarioRS.AdministradorRestService AdminService
@inject VetCitasWA.Servicios.REST.UsuarioRS.VeterinarioRestService VeterinarioService
@inject VetCitasWA.Servicios.REST.UsuarioRS.RecepcionistaRestService RecepcionistaService
@inject VetCitasWA.Servicios.REST.UsuarioRS.UsuarioRestService UsuarioService
@inject VetCitasWA.Servicios.REST.CitaRS.CitaRestService CitaService
@inject VetCitasWA.Servicios.UI.ToastService Toasts

<PageTitle>Usuarios y roles - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">></span>
    <span class="crumb current">Usuarios y roles</span>
</SectionContent>

<div class="page-section">

    <h1 class="page-title">Usuarios y roles</h1>

    <div class="filters">
        <div class="filter-field filter-buscar">
            <label class="filter-label" for="buscar">Buscar</label>
            <input id="buscar"
                   type="text"
                   class="search-input"
                   placeholder="Buscar por nombre, usuario o telefono"
                   value="@textoBusqueda"
                   @oninput="OnBusquedaInput" />
        </div>
        <div class="filter-field filter-rol">
            <label class="filter-label" for="filtroRol">Filtrar por rol</label>
            <div class="select-wrap">
                <VcSelect TValue="string"
                          Value="filtroRol"
                          ValueChanged="OnRolChanged"
                          Options="OpcionesRoles" />
            </div>
        </div>
        <div class="filter-field filter-estado">
            <label class="filter-label" for="filtroEstado">Estado</label>
            <div class="select-wrap">
                <VcSelect TValue="string"
                          Value="filtroEstado"
                          ValueChanged="OnEstadoChanged"
                          Options="OpcionesEstado" />
            </div>
        </div>
        <div class="filter-action">
            <button type="button" class="btn-new" @onclick="AbrirNuevo" disabled="@procesando">
                <span class="btn-plus" aria-hidden="true">+</span>
                <span>Nuevo usuario</span>
            </button>
        </div>
    </div>

    @if (!HayModalAbierto && !string.IsNullOrWhiteSpace(errorMensaje))
    {
        <div class="admin-alert" role="alert">
            <span>@errorMensaje</span>
            <button type="button" class="alert-close" aria-label="Cerrar alerta" @onclick="CerrarAlerta">x</button>
        </div>
    }

    <section class="panel">
        <h2 class="panel-title">Lista de usuarios</h2>

        <div class="table-wrapper">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Usuario</th>
                        <th>Nombre</th>
                        <th>DNI/Telefono</th>
                        <th>Correo</th>
                        <th>Roles</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (cargando)
                    {
                        <tr>
                            <td colspan="8" class="empty-cell">
                                <em>Cargando informacion...</em>
                            </td>
                        </tr>
                    }
                    else if (listaUsuarios == null || !listaUsuarios.Any())
                    {
                        <tr>
                            <td colspan="8" class="empty-cell">
                                <em>No se encontraron usuarios con los filtros actuales.</em>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var usuario in UsuariosPaginados)
                        {
                            <tr class="@(!usuario.Activo ? "row-inactive" : "")">
                                <td data-label="ID">@usuario.Id</td>
                                <td data-label="Usuario">
                                    <div class="user-cell">
                                        <span class="user-avatar-small">
                                            @(string.IsNullOrWhiteSpace(usuario.Username) ? "U" : usuario.Username.Substring(0, 1).ToUpper())
                                        </span>
                                        <span class="user-username">@usuario.Username</span>
                                    </div>
                                </td>
                                <td data-label="Nombre">@usuario.Nombres @usuario.Apellidos</td>
                                <td data-label="DNI/Telefono">@usuario.Telefono</td>
                                <td data-label="Correo">@usuario.Email</td>
                                <td data-label="Roles">
                                    @if (usuario.Roles != null && usuario.Roles.Any())
                                    {
                                        <div class="role-pills-list">
                                            @foreach (var rol in usuario.Roles)
                                            {
                                                <span class="role-pill @CssRol(rol.Codigo)">@NombreRol(rol)</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin roles</span>
                                    }

                                </td>
                                <td data-label="Estado">
                                    @if (usuario.Activo)
                                    {
                                        <span class="status-pill status-active">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill status-inactive">Desactivado</span>
                                    }
                                </td>
                                <td data-label="Acciones">
                                    <div class="row-actions">
                                        <button type="button"
                                                class="btn-pencil btn-edit"
                                                title="@(EsSuperAdminUsuario(usuario) && usuario.Id != usuarioActualId ? "No puedes editar al SuperAdmin" : "Editar")"
                                                aria-label="Editar"
                                                disabled="@(procesando || (EsSuperAdminUsuario(usuario) && usuario.Id != usuarioActualId))"
                                                @onclick="() => AbrirEditar(usuario)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" />
                                            </svg>
                                        </button>

                                        @if (usuario.Activo)
                                        {
                                            <button type="button"
                                                    class="btn-pencil btn-del"
                                                    title="Desactivar"
                                                    aria-label="Desactivar"
                                                    disabled="@(procesando || usuario.Id == usuarioActualId || EsSuperAdminUsuario(usuario))"
                                                    @onclick="() => PedirCambioEstado(usuario, false)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                                                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708" />
                                                </svg>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="btn-pencil btn-reactivate"
                                                    title="Activar usuario"
                                                    aria-label="Activar"
                                                    disabled="@procesando"
                                                    @onclick="() => PedirCambioEstado(usuario, true)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                                                </svg>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <Pager CurrentPage="paginaActual" TotalPages="TotalPaginas" CurrentPageChanged="IrAPagina" />
    </section>

</div>

@if (usuarioNuevo is not null)
{
    <div class="inline-modal-backdrop" @onclick="CerrarNuevo"></div>
    <section class="inline-modal user-form-modal" role="dialog" aria-modal="true" aria-labelledby="nuevoUsuarioTitulo">
        <div class="inline-modal-header">
            <div>
                <h2 id="nuevoUsuarioTitulo">Nuevo usuario</h2>
                <p>Registra un usuario con su rol principal. Luego puedes ajustar roles desde editar.</p>
            </div>
            <button type="button" class="modal-close" aria-label="Cerrar" @onclick="CerrarNuevo">x</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMensaje))
        {
            <div class="admin-alert modal-alert" role="alert">
                <span>@errorMensaje</span>
                <button type="button" class="alert-close" aria-label="Cerrar alerta" @onclick="CerrarAlerta">x</button>
            </div>
        }

        <div class="edit-grid">
            <div class="field-block edit-grid-wide">
                <span>Roles <span class="req">*</span></span>
                <div class="vc-ms">
                    <button type="button" class="search-input vc-ms-toggle" @onclick="() => rolesDropdownAbierto = !rolesDropdownAbierto">
                        @RolesResumen
                    </button>
                    @if (rolesDropdownAbierto)
                    {
                        <div class="vc-ms-overlay" @onclick="() => rolesDropdownAbierto = false"></div>
                        <div class="vc-ms-panel">
                            @foreach (var r in RolesAsignables)
                            {
                                <label class="vc-ms-item">
                                    <input type="checkbox" checked="@rolesSeleccionados.Contains(r)" @onchange="() => ToggleRolSeleccion(r)" />
                                    <span>@EtiquetaRol(r)</span>
                                </label>
                            }
                        </div>
                    }
                </div>
            </div>
            <label>
                <span>Usuario <span class="req">*</span></span>
                <input class="search-input @(usernameError is not null ? "input-error" : "")"
                       required
                       @bind="usuarioNuevo.Username"
                       @bind:event="oninput"
                       @bind:after="OnUsernameChanged"
                       autocomplete="off" />
                @if (verificandoUsername)
                {
                    <span class="field-hint">Verificando disponibilidad...</span>
                }
                else if (usernameError is not null)
                {
                    <span class="field-error">@usernameError</span>
                }
            </label>
            <label>
                <span>Contrasena inicial <span class="req">*</span></span>
                <input class="search-input" type="password" required @bind="passwordNuevo" autocomplete="new-password" />
            </label>
            <label>
                <span>Nombres <span class="req">*</span></span>
                <input class="search-input" required @bind="usuarioNuevo.Nombres" />
            </label>
            <label>
                <span>Apellidos <span class="req">*</span></span>
                <input class="search-input" required @bind="usuarioNuevo.Apellidos" />
            </label>
            <label>
                <span>Telefono</span>
                <PhoneInput @ref="phoneInputNuevo" Initial="@usuarioNuevo.Telefono" />
            </label>
            <label class="edit-grid-wide">
                <span>Correo <span class="req">*</span></span>
                <input class="search-input" type="email" required @bind="usuarioNuevo.Email" />
            </label>

            @if (rolesSeleccionados.Contains(CodigoRol.ADMINISTRADOR))
            {
                <label class="edit-grid-wide">
                    <span>Area de administrador <span class="req">*</span></span>
                    <input class="search-input" required @bind="areaAdminNuevo" placeholder="Ej. Sistemas" />
                </label>
            }

            @if (rolesSeleccionados.Contains(CodigoRol.RECEPCIONISTA))
            {
                <label class="edit-grid-wide">
                    <span>Area de recepcionista <span class="req">*</span></span>
                    <input class="search-input" required @bind="areaRecepNuevo" placeholder="Ej. Recepcion" />
                </label>
            }

            @if (rolesSeleccionados.Contains(CodigoRol.VETERINARIO))
            {
                <label>
                    <span>CMPV <span class="req">*</span></span>
                    <input class="search-input" required @bind="cmpvNuevo" />
                </label>
                <label>
                    <span>Especialidad <span class="req">*</span></span>
                    <input class="search-input" required @bind="especialidadNuevo" />
                </label>
            }
        </div>

        <div class="modal-actions">
            <button type="button" class="btn-secondary" disabled="@procesando" @onclick="CerrarNuevo">Cancelar</button>
            <button type="button" class="btn-new" disabled="@procesando" @onclick="GuardarNuevoAsync">
                @(procesando ? "Creando..." : "Crear usuario")
            </button>
        </div>
    </section>
}

@if (usuarioEditando is not null)
{
    <div class="inline-modal-backdrop" @onclick="CerrarEditar"></div>
    <section class="inline-modal user-form-modal" role="dialog" aria-modal="true" aria-labelledby="editarUsuarioTitulo">
        <div class="inline-modal-header">
            <div>
                <h2 id="editarUsuarioTitulo">Editar usuario</h2>
                <p>Actualiza los datos generales sin cambiar la contrasena.</p>
            </div>
            <button type="button" class="modal-close" aria-label="Cerrar" @onclick="CerrarEditar">x</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMensaje))
        {
            <div class="admin-alert modal-alert" role="alert">
                <span>@errorMensaje</span>
                <button type="button" class="alert-close" aria-label="Cerrar alerta" @onclick="CerrarAlerta">x</button>
            </div>
        }

        <div class="edit-grid">
            <label>
                <span>Usuario</span>
                <input class="search-input" @bind="usuarioEditando.Username" />
            </label>
            <label>
                <span>Nombres</span>
                <input class="search-input" @bind="usuarioEditando.Nombres" />
            </label>
            <label>
                <span>Apellidos</span>
                <input class="search-input" @bind="usuarioEditando.Apellidos" />
            </label>
            <label>
                <span>Telefono</span>
                <PhoneInput @ref="phoneInputEditar" Initial="@usuarioEditando.Telefono" />
            </label>
            <label class="edit-grid-wide">
                <span>Correo</span>
                <input class="search-input" type="email" @bind="usuarioEditando.Email" />
            </label>
            <label class="edit-check">
                <input type="checkbox" @bind="usuarioEditando.Activo" disabled="@(usuarioEditando.Id == usuarioActualId)" />
                <span>Usuario activo</span>
            </label>
        </div>

        <div class="roles-editor">
            <h3>Roles del usuario</h3>
            <p>Asigna o quita roles. Los cambios se aplican al guardar.</p>
            <div class="role-actions role-actions-editor" aria-label="Gestionar roles">
                @foreach (var rolGestionable in RolesGestionables)
                {
                    var tieneRol = rolesEditando.Contains(rolGestionable.Codigo);
                    <button type="button"
                            class="role-toggle @(tieneRol ? "role-toggle-on" : "")"
                            disabled="@(procesando || NoPuedeQuitarRolEditar(rolGestionable.Codigo))"
                            title="@TituloRolEditar(rolGestionable.Codigo, rolGestionable.Label)"
                            @onclick="() => ToggleRolEditar(rolGestionable.Codigo)">
                        @(tieneRol ? "Quitar" : "Asignar") @rolGestionable.Label
                    </button>
                }
            </div>
        </div>

        @if (rolesEditando.Contains(CodigoRol.ADMINISTRADOR) || rolesEditando.Contains(CodigoRol.RECEPCIONISTA))
        {
            <div class="roles-editor">
                <h3>Datos por rol</h3>
                <div class="edit-grid">
                    @if (rolesEditando.Contains(CodigoRol.ADMINISTRADOR))
                    {
                        <label class="edit-grid-wide">
                            <span>Area de administrador</span>
                            <input class="search-input" @bind="areaAdminEditar" placeholder="Ej. Sistemas" />
                        </label>
                    }
                    @if (rolesEditando.Contains(CodigoRol.RECEPCIONISTA))
                    {
                        <label class="edit-grid-wide">
                            <span>Area de recepcionista</span>
                            <input class="search-input" @bind="areaRecepEditar" placeholder="Ej. Recepcion" />
                        </label>
                    }
                </div>
            </div>
        }

        <div class="roles-editor">
            <h3>Restablecer contrasena</h3>
            @if (usuarioEditando.Id == usuarioActualId)
            {
                <p>Para tu propia cuenta no puedes restablecerla desde aqui.</p>
            }
            else if (EsSuperAdminUsuario(usuarioEditando))
            {
                <p>No se puede restablecer la contrasena del SuperAdmin.</p>
            }
            else if (!usuarioEditando.Activo)
            {
                <p>Activa el usuario para poder restablecer su contrasena.</p>
            }
            else
            {
                <p>Define una nueva contrasena (minimo 8 caracteres). Reemplaza la actual de inmediato.</p>
                <div class="reset-pass-row">
                    <input class="search-input"
                           type="password"
                           placeholder="Nueva contrasena"
                           autocomplete="new-password"
                           @bind="nuevaPasswordReset" />
                    <button type="button" class="btn-secondary" disabled="@procesando" @onclick="RestablecerContrasenaAsync">
                        @(procesando ? "Procesando..." : "Restablecer")
                    </button>
                </div>
            }
        </div>

        <div class="modal-actions">
            <button type="button" class="btn-secondary" disabled="@procesando" @onclick="CerrarEditar">Cancelar</button>
            <button type="button" class="btn-new" disabled="@procesando" @onclick="GuardarEdicionAsync">
                @(procesando ? "Guardando..." : "Guardar cambios")
            </button>
        </div>
    </section>
}

@if (usuarioCambioEstado is not null)
{
    <div class="inline-modal-backdrop" @onclick="CancelarCambioEstado"></div>
    <section class="confirm-modal state-modal" role="dialog" aria-modal="true" aria-labelledby="estadoUsuarioTitulo">
        <h2 id="estadoUsuarioTitulo">@(nuevoEstadoUsuario ? "Activar usuario" : "Desactivar usuario")</h2>
        <strong class="confirm-target">@usuarioCambioEstado.Username</strong>

        @if (verificandoCitasVet)
        {
            <p class="confirm-checking">Verificando si el veterinario tiene citas activas…</p>
        }
        else if (!nuevoEstadoUsuario && vetTieneCitasActivas)
        {
            <div class="confirm-block" role="alert">
                Este veterinario tiene citas <strong>pendientes, confirmadas o en consulta</strong>.
                Para desactivarlo, primero cancela o reprograma esas citas desde recepción.
            </div>
        }
        else
        {
            <p class="confirm-desc">
                @(nuevoEstadoUsuario
                    ? "El usuario volverá a estar disponible para iniciar sesión."
                    : "El usuario se marcará como desactivado sin eliminarlo físicamente.")
            </p>
        }

        @if (!string.IsNullOrWhiteSpace(errorMensaje))
        {
            <div class="admin-alert modal-alert" role="alert">
                <span>@errorMensaje</span>
                <button type="button" class="alert-close" aria-label="Cerrar alerta" @onclick="CerrarAlerta">x</button>
            </div>
        }

        <div class="modal-actions">
            <button type="button" class="btn-secondary" disabled="@procesando" @onclick="CancelarCambioEstado">
                @(!nuevoEstadoUsuario && vetTieneCitasActivas ? "Entendido" : "Cancelar")
            </button>
            @if (!verificandoCitasVet && !(!nuevoEstadoUsuario && vetTieneCitasActivas))
            {
                <button type="button" class="@(nuevoEstadoUsuario ? "btn-new" : "btn-danger")" disabled="@procesando" @onclick="ConfirmarCambioEstadoAsync">
                    @(procesando ? "Procesando..." : (nuevoEstadoUsuario ? "Activar" : "Desactivar"))
                </button>
            }
        </div>
    </section>
}

@code {
    private List<Usuario> listaUsuarios = new();
    private string textoBusqueda = "";
    private string filtroRol = "";
    // Por defecto se muestran solo los usuarios activos.
    private string filtroEstado = "activos";
    private bool cargando;
    private bool procesando;
    private string? errorMensaje;
    private int usuarioActualId;
    private int paginaActual = 1;
    private const int PageSize = 7;
    private Usuario? usuarioNuevo;
    private Usuario? usuarioEditando;
    // Campos de telefono con selector de pais (mismo componente que el modal de cliente).
    private PhoneInput? phoneInputNuevo;
    private PhoneInput? phoneInputEditar;
    private Usuario? usuarioCambioEstado;
    private bool nuevoEstadoUsuario;
    private bool verificandoCitasVet;
    private bool vetTieneCitasActivas;
    // Roles seleccionados para el nuevo usuario (multi-seleccion).
    private HashSet<CodigoRol> rolesSeleccionados = new();
    private bool rolesDropdownAbierto;
    private static readonly CodigoRol[] RolesAsignables =
        { CodigoRol.ADMINISTRADOR, CodigoRol.VETERINARIO, CodigoRol.RECEPCIONISTA };

    // Subtipo a crear: VETERINARIO tiene prioridad (lleva CMPV/especialidad),
    // luego ADMINISTRADOR, luego RECEPCIONISTA. Los demas roles se asignan como vinculo.
    private CodigoRol RolPrincipalEfectivo =>
        rolesSeleccionados.Contains(CodigoRol.VETERINARIO) ? CodigoRol.VETERINARIO
        : rolesSeleccionados.Contains(CodigoRol.ADMINISTRADOR) ? CodigoRol.ADMINISTRADOR
        : CodigoRol.RECEPCIONISTA;

    private bool HayModalAbierto => usuarioNuevo is not null || usuarioEditando is not null || usuarioCambioEstado is not null;

    private string RolesResumen => rolesSeleccionados.Count == 0
        ? "Selecciona uno o mas roles"
        : string.Join(", ", RolesAsignables.Where(rolesSeleccionados.Contains).Select(EtiquetaRol));

    private void ToggleRolSeleccion(CodigoRol rol)
    {
        if (!rolesSeleccionados.Remove(rol)) rolesSeleccionados.Add(rol);
    }
    private string passwordNuevo = "";
    private string nuevaPasswordReset = "";
    private string areaAdminNuevo = "";
    private string areaRecepNuevo = "";
    private string cmpvNuevo = "";
    private string especialidadNuevo = "";

    // Edicion diferida de roles: el toggle solo cambia este conjunto en memoria;
    // los cambios (asignar/revocar) se validan y aplican al dar "Guardar cambios".
    private HashSet<CodigoRol> rolesEditando = new();
    // Areas capturadas en el modal de edicion (se cargan al abrir, se guardan al final).
    private string areaAdminEditar = "";
    private string areaRecepEditar = "";

    private IEnumerable<Usuario> UsuariosPaginados
        => listaUsuarios.Skip((paginaActual - 1) * PageSize).Take(PageSize);

    private int TotalPaginas
        => Math.Max(1, (int)Math.Ceiling((listaUsuarios?.Count ?? 0) / (double)PageSize));

    private static readonly IEnumerable<VcSelectOption<string>> OpcionesRoles = new[]
    {
        new VcSelectOption<string>("", "Todos los roles"),
