    // Reglas de validacion del formulario de nuevo usuario.
    private string? ValidarNuevoUsuario()
    {
        var u = usuarioNuevo!;

        if (rolesSeleccionados.Count == 0)
            return "Selecciona al menos un rol.";

        var username = (u.Username ?? "").Trim();
        if (username.Length < 4)
            return "El usuario debe tener al menos 4 caracteres.";
        if (username.Contains(' '))
            return "El usuario no puede contener espacios.";

        if (string.IsNullOrWhiteSpace(passwordNuevo) || passwordNuevo.Length < 8)
            return "La contrasena debe tener al menos 8 caracteres.";

        if (string.IsNullOrWhiteSpace(u.Nombres))
            return "Los nombres son obligatorios.";
        if (string.IsNullOrWhiteSpace(u.Apellidos))
            return "Los apellidos son obligatorios.";

        if (!EsCorreoValido(u.Email))
            return "Ingresa un correo electronico valido.";

        var tel = (u.Telefono ?? "").Trim();
        if (!string.IsNullOrEmpty(tel) && (tel.Length < 6 || tel.Length > 15))
            return "El telefono debe tener entre 6 y 15 digitos.";

        if (rolesSeleccionados.Contains(CodigoRol.VETERINARIO)
            && (string.IsNullOrWhiteSpace(cmpvNuevo) || string.IsNullOrWhiteSpace(especialidadNuevo)))
            return "Para veterinario debes indicar CMPV y especialidad.";

        if (rolesSeleccionados.Contains(CodigoRol.ADMINISTRADOR)
            && string.IsNullOrWhiteSpace(areaAdminNuevo))
            return "Indica el area de administrador.";

        if (rolesSeleccionados.Contains(CodigoRol.RECEPCIONISTA)
            && string.IsNullOrWhiteSpace(areaRecepNuevo))
            return "Indica el area de recepcionista.";

        return null;
    }

    private static bool EsCorreoValido(string? email)
    {
        if (string.IsNullOrWhiteSpace(email)) return false;
        email = email.Trim();
        if (email.Contains(' ')) return false;
        var at = email.IndexOf('@');
        var dot = email.LastIndexOf('.');
        return at > 0 && dot > at + 1 && dot < email.Length - 1;
    }

