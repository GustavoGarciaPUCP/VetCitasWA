    protected override async Task OnInitializedAsync()
    {
        usuarioActualId = await ObtenerUsuarioActualIdAsync();
        if (usuarioActualId <= 0)
        {
            errorMensaje = "No se pudo identificar al usuario autenticado.";
            return;
        }

        await CargarUsuariosAsync();
    }

    private async Task BuscarUsuarios()
    {
        paginaActual = 1;
        await CargarUsuariosAsync();
    }

    // Debounce de 800 ms: evita una consulta al backend por cada tecla.
    private System.Threading.CancellationTokenSource? debounceCts;

    private async Task OnBusquedaInput(ChangeEventArgs e)
    {
        textoBusqueda = e.Value?.ToString() ?? "";

        debounceCts?.Cancel();
        debounceCts = new System.Threading.CancellationTokenSource();
        var token = debounceCts.Token;

        try
        {
            await Task.Delay(800, token);
            paginaActual = 1;
            await CargarUsuariosAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException) { /* se presiono otra tecla antes de 800ms */ }
    }

    private async Task OnRolChanged(string value)
    {
        filtroRol = value ?? "";
        paginaActual = 1;
        await CargarUsuariosAsync();
    }

    private async Task OnEstadoChanged(string value)
    {
        filtroEstado = value ?? "activos";
        paginaActual = 1;
        await CargarUsuariosAsync();
    }

    // null = todos | true = solo activos | false = solo inactivos
    private bool? ActivoFiltro => filtroEstado switch
    {
        "inactivos" => false,
        "todos" => null,
        _ => true
    };

    private async Task CargarUsuariosAsync()
    {
        cargando = true;
        errorMensaje = null;

        try
        {
            await Task.Yield();
            listaUsuarios = AdminService.ListarUsuariosFiltrados(textoBusqueda, filtroRol, ActivoFiltro);
            if (paginaActual > TotalPaginas)
            {
                paginaActual = TotalPaginas;
            }
        }
        catch (Exception ex)
        {
            listaUsuarios = new();
            errorMensaje = $"No se pudieron cargar los usuarios. {ex.Message}";
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task<int> ObtenerUsuarioActualIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var valor = user.FindFirst("IdUsuario")?.Value
            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        return int.TryParse(valor, out var id) ? id : 0;
    }

    private async Task AbrirEditar(Usuario usuario)
    {
        // Un SuperAdmin solo puede ser editado por si mismo.
        if (EsSuperAdminUsuario(usuario) && usuario.Id != usuarioActualId)
        {
            Toasts.Error("No puedes editar al SuperAdmin.");
            return;
        }

        usuarioEditando = CopiarUsuario(usuario);
        nuevaPasswordReset = "";
        errorMensaje = null;
        rolesEditando = usuarioEditando.Roles?.Select(r => r.Codigo).ToHashSet() ?? new();
        areaAdminEditar = "";
        areaRecepEditar = "";
        await CargarAreasEdicionAsync();
    }

    // Carga el area actual de los subtipos administrativos que tenga el usuario,
    // para mostrarla en el formulario. Trae el registro completo solo para leer el area.
    private async Task CargarAreasEdicionAsync()
    {
        if (usuarioEditando is null) return;
        try
        {
            if (rolesEditando.Contains(CodigoRol.ADMINISTRADOR))
            {
                var a = await Task.Run(() => AdminService.BuscarPorId(usuarioEditando.Id));
                areaAdminEditar = a?.Area ?? "";
            }
            if (rolesEditando.Contains(CodigoRol.RECEPCIONISTA))
            {
                var r = await Task.Run(() => RecepcionistaService.BuscarPorId(usuarioEditando.Id));
                areaRecepEditar = r?.Area ?? "";
            }
        }
        catch
        {
            // No se bloquea el modal por un fallo de carga.
        }
    }

