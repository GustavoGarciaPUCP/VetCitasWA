    private async Task GuardarEdicionAsync()
    {
        if (usuarioEditando is null)
        {
            return;
        }

        // Defensa: un SuperAdmin solo puede ser editado por si mismo.
        if (EsSuperAdminUsuario(usuarioEditando) && usuarioEditando.Id != usuarioActualId)
        {
            Toasts.Error("No puedes editar al SuperAdmin.");
            return;
        }

        // Toma el numero internacional (con codigo de pais) del campo con banderas.
        if (phoneInputEditar is not null)
        {
            var num = await phoneInputEditar.GetNumberAsync();
            if (!string.IsNullOrWhiteSpace(num)) usuarioEditando.Telefono = num;
        }

        if (!DatosBasicosValidos(usuarioEditando))
        {
            Toasts.Error("Completa usuario, nombres, apellidos y correo.");
            return;
        }

        if (usuarioEditando.Id == usuarioActualId && !usuarioEditando.Activo)
        {
            Toasts.Error("No puedes desactivar tu propio usuario.");
            return;
        }

        if (EsSuperAdminUsuario(usuarioEditando) && !usuarioEditando.Activo)
        {
            Toasts.Error("No se puede desactivar al SuperAdmin.");
            return;
        }

        // ===== Validaciones de roles (todas al guardar) =====
        if (rolesEditando.Count == 0)
        {
            Toasts.Error("El usuario debe tener al menos un rol.");
            return;
        }

        var rolesActuales = usuarioEditando.Roles?.Select(r => r.Codigo).ToHashSet() ?? new();
        var rolesAQuitar = rolesActuales.Where(r => !rolesEditando.Contains(r)).ToList();
        var rolesAAsignar = rolesEditando.Where(r => !rolesActuales.Contains(r)).ToList();

        // No se puede quitar ADMINISTRADOR a uno mismo ni al SuperAdmin.
        if (rolesAQuitar.Contains(CodigoRol.ADMINISTRADOR)
            && (usuarioEditando.Id == usuarioActualId || EsSuperAdminUsuario(usuarioEditando)))
        {
            Toasts.Error("No se puede quitar el rol Administrador a este usuario.");
            return;
        }

        // No se puede quitar VETERINARIO si tiene citas pendientes, confirmadas o en consulta.
        if (rolesAQuitar.Contains(CodigoRol.VETERINARIO)
            && await VeterinarioTieneCitasActivasAsync(usuarioEditando.Id))
        {
            Toasts.Error("No se puede quitar el rol Veterinario: tiene citas pendientes, confirmadas o en consulta. Cancela o reprograma esas citas primero.");
            return;
        }

        await EjecutarOperacionAsync(() =>
        {
            // 1) Datos basicos del usuario.
            AdminService.ModificarUsuarioBasico(usuarioEditando, usuarioActualId);

            // 2) Asignar roles nuevos PRIMERO (evita quedar en 0 roles al intercambiar).
            foreach (var rol in rolesAAsignar)
            {
                AdminService.AsignarRol(usuarioEditando.Id, rol.ToString());
            }

            // 3) Guardar el area de los subtipos administrativos vigentes. Se relee el
            //    registro para tomar el hash VIGENTE (por si se acaba de restablecer la
            //    contrasena) y solo se le aplica el area y los datos basicos editados.
            if (rolesEditando.Contains(CodigoRol.ADMINISTRADOR))
            {
                var actual = AdminService.BuscarPorId(usuarioEditando.Id);
                if (actual is not null)
                {
                    actual.Area = areaAdminEditar ?? "";
                    SincronizarBasicosSubtipo(actual);
                    AdminService.Modificar(actual);
                }
            }
            if (rolesEditando.Contains(CodigoRol.RECEPCIONISTA))
            {
                var actual = RecepcionistaService.BuscarPorId(usuarioEditando.Id);
                if (actual is not null)
                {
                    actual.Area = areaRecepEditar ?? "";
                    SincronizarBasicosSubtipo(actual);
                    RecepcionistaService.Modificar(actual);
                }
            }

            // 4) Revocar roles quitados al final (cuando ya hay roles suficientes).
            foreach (var rol in rolesAQuitar)
            {
                AdminService.RevocarRol(usuarioEditando.Id, rol.ToString());
            }

            Toasts.Exito("Usuario actualizado.");
        });

        // Solo cierra el modal si la operacion fue exitosa.
        if (errorMensaje is null)
        {
            usuarioEditando = null;
            rolesEditando = new();
            areaAdminEditar = "";
            areaRecepEditar = "";
            await CargarUsuariosAsync();
        }
    }

    // Copia los datos basicos editados del usuario al subtipo antes de guardarlo,
    // para que Modificar (que tambien actualiza la tabla usuario) no revierta los
    // cambios hechos en el formulario. No toca la contrasena.
    private void SincronizarBasicosSubtipo(Usuario subtipo)
    {
        if (usuarioEditando is null) return;
        subtipo.Id = usuarioEditando.Id;
        subtipo.Username = usuarioEditando.Username;
        subtipo.Nombres = usuarioEditando.Nombres;
        subtipo.Apellidos = usuarioEditando.Apellidos;
        subtipo.Telefono = usuarioEditando.Telefono;
        subtipo.Email = usuarioEditando.Email;
        subtipo.Activo = usuarioEditando.Activo;
        subtipo.ModifiedBy = new Usuario { Id = usuarioActualId };
    }

    private async Task PedirCambioEstado(Usuario usuario, bool activo)
    {
        if (!activo && usuario.Id == usuarioActualId)
        {
            Toasts.Error("No puedes desactivar tu propio usuario.");
            return;
        }

        if (!activo && EsSuperAdminUsuario(usuario))
        {
            Toasts.Error("No se puede desactivar al SuperAdmin.");
            return;
        }

        usuarioCambioEstado = CopiarUsuario(usuario);
        nuevoEstadoUsuario = activo;
        errorMensaje = null;
        vetTieneCitasActivas = false;

        // Al inactivar a un veterinario, se verifica de inmediato si tiene citas
        // activas: el backend no permitira inactivarlo, asi que se avisa antes.
        if (!activo && TieneRol(usuario, CodigoRol.VETERINARIO))
        {
            verificandoCitasVet = true;
            vetTieneCitasActivas = await VeterinarioTieneCitasActivasAsync(usuario.Id);
            verificandoCitasVet = false;
        }
    }

    // El veterinario tiene citas que impiden inactivarlo si hay alguna en estado
    // PENDIENTE, CONFIRMADA o EN_CONSULTA.
    private async Task<bool> VeterinarioTieneCitasActivasAsync(int idVet)
    {
        try
        {
            var citas = await Task.Run(() => CitaService.ListarFiltradas(idVet, null, null, "", ""));
            return citas.Any(c => c.Veterinario?.Id == idVet
                && (c.Estado == EstadoCita.PENDIENTE
                    || c.Estado == EstadoCita.CONFIRMADA
                    || c.Estado == EstadoCita.EN_CONSULTA));
        }
        catch
        {
            // Si no se puede verificar, no se bloquea aqui: el backend valida al confirmar.
            return false;
        }
    }

    private void CancelarCambioEstado()
    {
        if (!procesando)
        {
            usuarioCambioEstado = null;
        }
    }

    private async Task ConfirmarCambioEstadoAsync()
    {
        if (usuarioCambioEstado is null)
        {
            return;
        }

        // Defensa: no intentar inactivar a un veterinario con citas activas.
        if (!nuevoEstadoUsuario && vetTieneCitasActivas)
        {
            return;
        }

        usuarioCambioEstado.Activo = nuevoEstadoUsuario;

        await EjecutarOperacionAsync(() =>
        {
            AdminService.ModificarUsuarioBasico(usuarioCambioEstado, usuarioActualId);
            Toasts.Exito(nuevoEstadoUsuario ? "Usuario activado." : "Usuario inactivado.");
        });

        if (errorMensaje is null)
        {
            usuarioCambioEstado = null;
            await CargarUsuariosAsync();
        }
    }

    // Cambio de rol DIFERIDO: solo modifica el conjunto en memoria. La asignacion
    // o revocacion real (y todas sus validaciones) ocurren en "Guardar cambios".
    private void ToggleRolEditar(CodigoRol codigoRol)
    {
        if (usuarioEditando is null) return;

        if (rolesEditando.Contains(codigoRol))
        {
            // Proteccion en UI; la validacion definitiva se hace al guardar.
            if (NoPuedeQuitarRolEditar(codigoRol))
            {
                Toasts.Error("No se puede quitar este rol administrativo.");
                return;
            }
            rolesEditando.Remove(codigoRol);
        }
        else
        {
            if (rolesEditando.Count >= 3)
            {
                Toasts.Error("No se permite mas de 3 roles por usuario.");
                return;
            }
            rolesEditando.Add(codigoRol);
        }
    }

    private async Task EjecutarOperacionAsync(Action operacion)
    {
        procesando = true;
        errorMensaje = null;

        try
        {
            await Task.Yield();
            operacion();
        }
        catch (Exception ex)
        {
            errorMensaje = $"No se pudo completar la operacion. {ex.Message}";
            Toasts.Error("No se pudo completar la operacion.");
        }
        finally
        {
            procesando = false;
        }
    }

    private static Usuario CopiarUsuario(Usuario usuario)
        => new()
        {
            Id = usuario.Id,
            Username = usuario.Username ?? "",
            ContrasenaHash = usuario.ContrasenaHash ?? "",
            Nombres = usuario.Nombres ?? "",
            Apellidos = usuario.Apellidos ?? "",
            Email = usuario.Email ?? "",
            Telefono = usuario.Telefono ?? "",
            Activo = usuario.Activo,
            Roles = usuario.Roles?.ToList() ?? new List<RolSistema>()
        };

    private static bool DatosBasicosValidos(Usuario usuario)
        => !string.IsNullOrWhiteSpace(usuario.Username)
            && !string.IsNullOrWhiteSpace(usuario.Nombres)
            && !string.IsNullOrWhiteSpace(usuario.Apellidos)
            && !string.IsNullOrWhiteSpace(usuario.Email);

    private static bool TieneRol(Usuario usuario, CodigoRol codigoRol)
        => usuario.Roles?.Any(r => r.Codigo == codigoRol) == true;

    // En el editor diferido, no se puede dejar staged la quita de ADMINISTRADOR a
    // uno mismo ni al SuperAdmin (se bloquea el toggle). El resto se valida al guardar.
    private bool NoPuedeQuitarRolEditar(CodigoRol codigoRol)
        => usuarioEditando is not null
            && codigoRol == CodigoRol.ADMINISTRADOR
            && rolesEditando.Contains(CodigoRol.ADMINISTRADOR)
            && (usuarioEditando.Id == usuarioActualId || EsSuperAdminUsuario(usuarioEditando));

    private static bool EsSuperAdminUsuario(Usuario usuario)
        => usuario.Id == 1
            || string.Equals(usuario.Username, "superadmin", StringComparison.OrdinalIgnoreCase);

    // Etiqueta canonica por codigo: la columna de roles solo muestra
    // Administrador, Veterinario o Recepcionista (no la descripcion de la BD).
    private static string NombreRol(RolSistema rol)
        => rol.Codigo switch
        {
            CodigoRol.ADMINISTRADOR => "Administrador",
            CodigoRol.VETERINARIO => "Veterinario",
            CodigoRol.RECEPCIONISTA => "Recepcionista",
            _ => rol.Codigo.ToString()
        };

    private static string CssRol(CodigoRol codigoRol)
        => codigoRol switch
        {
            CodigoRol.VETERINARIO => "role-pill-vet",
            CodigoRol.RECEPCIONISTA => "role-pill-recep",
            _ => "role-pill-admin"
        };

    private string TituloRolEditar(CodigoRol codigoRol, string label)
        => NoPuedeQuitarRolEditar(codigoRol)
            ? "No se puede quitar este rol administrativo"
            : $"{(rolesEditando.Contains(codigoRol) ? "Quitar" : "Asignar")} {label}";

    private void IrAPagina(int p) => paginaActual = p;

    public void Dispose()
    {
        debounceCts?.Cancel();
        usernameDebounceCts?.Cancel();
    }
}
