@page "/usuarios-roles"
@using VetCitasWA.Servicios.Modelo.Usuario
@inject VetCitasWA.Servicios.REST.UsuarioRS.AdministradorRestService AdminService

<PageTitle>Gestión de Usuarios y Roles - VetCitas</PageTitle>

<SectionContent SectionName="breadcrumb">
    <span class="crumb">VetCitas</span>
    <span class="crumb-sep">›</span>
    <span class="crumb current">Gestión de Usuarios y Roles</span>
</SectionContent>

<div class="page-section">

    <h1 class="page-title">Gestión de Usuarios y Roles</h1>

    <div class="filters">
        <div class="filter-field filter-buscar">
            <label class="filter-label" for="buscar">Buscar</label>
            <input id="buscar" type="text" class="search-input" placeholder="Buscar usuarios (nombre, username o DNI)" />
        </div>
        <div class="filter-field filter-rol">
            <label class="filter-label" for="filtroRol">Filtrar por Rol</label>
            <div class="select-wrap">
                <select id="filtroRol" class="select">
                    <option>Todos los roles</option>
                    <option>Administrador</option>
                    <option>Veterinario</option>
                    <option>Recepcionista</option>
                </select>
            </div>
        </div>
        <div class="filter-action">
            <label for="usuario-form-modal" class="btn-new">
                <span class="btn-plus" aria-hidden="true">+</span>
                <span>Nuevo Usuario</span>
            </label>
        </div>
    </div>

    <section class="panel">
        <h2 class="panel-title">Lista de Usuarios</h2>

        <div class="table-wrapper">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Usuario</th>
                        <th>Nombre</th>
                        <th>DNI/Teléfono</th>
                        <th>Correo</th>
                        <th>Roles</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (listaUsuarios == null || !listaUsuarios.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center" style="padding: 2rem;">
                                <em>Cargando datos desde el servidor o no se encontraron resultados...</em>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var usuario in listaUsuarios)
                        {
                            <tr class="@(!usuario.Activo ? "row-inactive" : "")">
                                <td data-label="ID">@usuario.Id</td>
                                <td data-label="Usuario">
                                    <div class="user-cell">
                                        <span class="user-avatar-small">
                                            @(string.IsNullOrWhiteSpace(usuario.Username) ? "U" : usuario.Username.Substring(0, 1).ToUpper())
                                        </span>
                                        <span class="user-username">@usuario.Username</span>
                                    </div>
                                </td>
                                <td data-label="Nombre">@usuario.Nombres @usuario.Apellidos</td>
                                <td data-label="DNI/Teléfono">@usuario.Telefono</td>
                                <td data-label="Correo">@usuario.Email</td>
                                <td data-label="Roles">
                                    @if (usuario.Roles != null && usuario.Roles.Any())
                                    {
                                        <div class="@(usuario.Roles.Count > 1 ? "role-pills-stack" : "")">
                                            @foreach (var rol in usuario.Roles)
                                            {
                                                // Asignamos el color del pill dependiendo del nombre del rol
                                                string rolClass = "role-pill-admin"; // default
                                                string nombreRol = rol.Descripcion ?? rol.Codigo.ToString();

                                                if (nombreRol.Contains("Veterinario", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    rolClass = "role-pill-vet";
                                                }
                                                else if (nombreRol.Contains("Recepcionista", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    rolClass = "role-pill-recep";
                                                }

                                                <span class="role-pill @rolClass">@nombreRol</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin roles</span>
                                    }
                                </td>
                                <td data-label="Estado">
                                    @if (usuario.Activo)
                                    {
                                        <span class="status-pill status-active">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill status-inactive">Inactivo</span>
                                    }
                                </td>
                                <td data-label="Acciones">
                                    <div class="actions-row">
                                        <label for="usuario-form-modal" class="btn-act btn-act-edit" title="Editar" aria-label="Editar">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325" />
                                            </svg>
                                        </label>

                                        @if (usuario.Activo)
                                        {
                                            <label for="confirm-delete-modal" class="btn-act btn-act-toggle" title="Inactivar" aria-label="Inactivar">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                                                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708" />
                                                </svg>
                                            </label>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn-act btn-act-toggle btn-act-on" title="Activar usuario" aria-label="Activar">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                                                </svg>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <nav class="pager" aria-label="Paginación">
            <button type="button" class="pager-btn pager-arrow" aria-label="Anterior">‹</button>
            <button type="button" class="pager-btn pager-active">1</button>
            <button type="button" class="pager-btn pager-arrow" aria-label="Siguiente">›</button>
        </nav>
    </section>

</div>

@code {
    private List<Usuario> listaUsuarios = new List<Usuario>();

    protected override void OnInitialized()
    {
        listaUsuarios = AdminService.ListarUsuariosFiltrados("", "Todos los roles", null);
    }
}