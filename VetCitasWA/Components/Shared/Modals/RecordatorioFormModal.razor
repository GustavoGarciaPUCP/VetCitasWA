@*
    Modal reutilizable para editar el mensaje y la fecha programada de un
    recordatorio. Se abre con <label for="recordatorio-form-modal">.
*@
@using VetCitasWA.Servicios.Modelo.Cita
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.CitaRS.RecordatorioRestService RecordatorioService

<input type="checkbox" id="recordatorio-form-modal" class="rec-modal-toggle" aria-hidden="true" />

<div class="rec-modal-backdrop">
    <div class="rec-modal-card" role="dialog" aria-modal="true" aria-labelledby="rec-modal-title">

        <header class="rec-modal-head">
            <div>
                <h2 id="rec-modal-title" class="rec-modal-title">Editar Recordatorio</h2>
                <p class="rec-modal-subtitle">@Subtitulo</p>
            </div>
            <label for="recordatorio-form-modal" class="rec-modal-close" aria-label="Cerrar">×</label>
        </header>

        <div class="rec-modal-body">

            <div class="rf-field">
                <label class="rf-label" for="rf-mensaje">Mensaje</label>
                <textarea id="rf-mensaje" class="rf-textarea" rows="4" maxlength="255" @bind="recordatorio.Mensaje"></textarea>
                <span class="rf-hint">Este es el texto que recibirá el cliente por WhatsApp. Máx 255 caracteres.</span>
            </div>

            <div class="rf-row">
                <div class="rf-field">
                    <label class="rf-label" for="rf-fecha">Fecha programada</label>
                    <input id="rf-fecha" type="datetime-local" class="rf-input" @bind="recordatorio.FechaProgramada" />
                    <span class="rf-hint">Día y hora de envío.</span>
                </div>
            </div>

            <div class="rf-info">
                <span class="rf-info-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2" />
                    </svg>
                </span>
                <span>Canal de envío: <strong>WhatsApp</strong> (único canal disponible).</span>
            </div>

        </div>

        <footer class="rec-modal-foot">
            <button type="button" class="btn-rec btn-rec-primary" @onclick="Guardar">Guardar Cambios</button>
        </footer>
    </div>
</div>

@code {
    // El modal es global (vive en MainLayout) y se abre mediante un toggle CSS,
    // por lo que mantiene su propio objeto editable. Si en el futuro se pasa el
    // recordatorio seleccionado, basta con asignar `recordatorio` antes de abrirlo.
    private Recordatorio recordatorio = new Recordatorio
    {
        FechaProgramada = DateTime.Now,
        Canal = CanalRecordatorio.WHATSAPP,
        EstadoSeguimiento = EstadoSeguimiento.PENDIENTE
    };

    private string Subtitulo
    {
        get
        {
            var mascota = recordatorio.Cita?.Mascota;
            var cliente = mascota?.Cliente;
            if (recordatorio.Cita == null)
            {
                return "Edición de recordatorio";
            }
            string nombreMascota = mascota?.Nombre ?? "";
            string nombreCliente = cliente != null ? $"{cliente.Nombres} {cliente.Apellidos}" : "";
            return $"Cita #{recordatorio.Cita.Id} · {nombreMascota} · {nombreCliente}";
        }
    }

    private void Guardar()
    {
        if (recordatorio.Id > 0)
        {
            RecordatorioService.Modificar(recordatorio);
        }
    }

    // Permite que un componente padre cargue el recordatorio a editar.
    public void Cargar(Recordatorio r)
    {
        recordatorio = r;
        StateHasChanged();
    }
}
