@*
    Modal reutilizable para crear/editar mascota.
    Se abre con <label for="mascota-form-modal">. Los campos están
    enlazados a un objeto Mascota local y el botón Guardar invoca
    el servicio REST (Insertar si es nueva, Modificar si tiene Id).
*@
@using VetCitasWA.Servicios.Modelo.Cliente
@using VetCitasWA.Servicios.Modelo.Common.Enums
@inject VetCitasWA.Servicios.REST.ClienteRS.MascotaRestService MascotaService
@inject VetCitasWA.Servicios.REST.ClienteRS.ClienteRestService ClienteService

<input type="checkbox" id="mascota-form-modal" class="mas-modal-toggle" aria-hidden="true" />

<div class="mas-modal-backdrop">
    <div class="mas-modal-card" role="dialog" aria-modal="true" aria-labelledby="mas-modal-title">

        <header class="mas-modal-head">
            <div>
                <h2 id="mas-modal-title" class="mas-modal-title">Editar Mascota</h2>
                <p class="mas-modal-subtitle">Permiso requerido: MASCOTA_GESTIONAR</p>
            </div>
            <label for="mascota-form-modal" class="mas-modal-close" aria-label="Cerrar">×</label>
        </header>

        <div class="mas-modal-body">

            <div class="mf-field">
                <label class="mf-label" for="mf-cliente">Cliente *</label>
                <div class="mf-select-wrap">
                    <select id="mf-cliente" class="mf-select" required @bind="idClienteSeleccionado">
                        <option value="0" disabled hidden>Selecciona un cliente...</option>
                        @foreach (var c in listaClientes)
                        {
                            <option value="@c.Id">@c.Nombres @c.Apellidos — DNI @c.Dni</option>
                        }
                    </select>
                </div>
                <span class="mf-hint">La mascota queda asociada a este cliente.</span>
            </div>

            <div class="mf-row">
                <div class="mf-field">
                    <label class="mf-label" for="mf-nombre">Nombre *</label>
                    <input id="mf-nombre" type="text" class="mf-input" @bind="modelo.Nombre" required />
                </div>
                <div class="mf-field">
                    <label class="mf-label" for="mf-especie">Especie *</label>
                    <div class="mf-select-wrap">
                        <select id="mf-especie" class="mf-select" required @bind="modelo.Especie">
                            <option value="@TipoEspecie.PERRO">Perro</option>
                            <option value="@TipoEspecie.GATO">Gato</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="mf-row">
                <div class="mf-field">
                    <label class="mf-label" for="mf-raza">Raza</label>
                    <input id="mf-raza" type="text" class="mf-input" @bind="modelo.Raza" />
                </div>
                <div class="mf-field">
                    <label class="mf-label" for="mf-fecha">Fecha de nacimiento</label>
                    <input id="mf-fecha" type="date" class="mf-input" @bind="modelo.FechaNacimiento" />
                </div>
            </div>

            <div class="mf-field">
                <label class="mf-label" for="mf-peso">Peso (kg)</label>
                <input id="mf-peso" type="number" class="mf-input" @bind="modelo.Peso" step="0.1" min="0" />
                <span class="mf-hint">Se actualizará en cada control veterinario.</span>
            </div>

            <label class="mf-check">
                <input type="checkbox" class="mf-check-input" @bind="modelo.Esterilizado" />
                <span class="mf-check-visual" aria-hidden="true"></span>
                <span class="mf-check-text">Esterilizado</span>
            </label>

            <label class="mf-check">
                <input type="checkbox" class="mf-check-input" @bind="modelo.Activo" />
                <span class="mf-check-visual" aria-hidden="true"></span>
                <span class="mf-check-text">Mascota activa</span>
            </label>

            @if (!string.IsNullOrEmpty(mensaje))
            {
                <p class="mf-hint">@mensaje</p>
            }

        </div>

        <footer class="mas-modal-foot">
            <button type="button" class="btn-mas btn-mas-primary" @onclick="Guardar">Guardar Mascota</button>
        </footer>
    </div>
</div>

@code {
    // Objeto enlazado al formulario. Por defecto una mascota nueva y activa.
    private Mascota modelo = new Mascota { Activo = true, Especie = TipoEspecie.PERRO };
    private List<Cliente> listaClientes = new();
    private int idClienteSeleccionado = 0;
    private string mensaje = "";

    protected override void OnInitialized()
    {
        listaClientes = ClienteService.ListarTodos();
    }

    private void Guardar()
    {
        if (string.IsNullOrWhiteSpace(modelo.Nombre))
        {
            mensaje = "El nombre de la mascota es obligatorio.";
            return;
        }
        if (idClienteSeleccionado <= 0)
        {
            mensaje = "Debe seleccionar un cliente.";
            return;
        }

        // Se asocia la mascota al cliente seleccionado.
        modelo.Cliente = new Cliente { Id = idClienteSeleccionado };

        if (modelo.Id > 0)
        {
            MascotaService.Modificar(modelo);
        }
        else
        {
            MascotaService.Insertar(modelo);
        }

        mensaje = "Mascota guardada correctamente.";
        // Se reinicia el modelo para una nueva captura.
        modelo = new Mascota { Activo = true, Especie = TipoEspecie.PERRO };
        idClienteSeleccionado = 0;
    }
}
