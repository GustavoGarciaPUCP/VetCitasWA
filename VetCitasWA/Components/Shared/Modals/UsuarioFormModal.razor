@*
    Modal reutilizable para crear/editar usuario.
    Se abre con <label for="usuario-form-modal">.
    Demo pre-llenado con datos de Carlos para mostrar el modo edición;
    en modo crear vendrían vacíos.
*@

<input type="checkbox" id="usuario-form-modal" class="usr-modal-toggle" aria-hidden="true" />

<div class="usr-modal-backdrop">
    <div class="usr-modal-card" role="dialog" aria-modal="true" aria-labelledby="usr-modal-title">

        <header class="usr-modal-head">
            <div>
                <h2 id="usr-modal-title" class="usr-modal-title">Editar Usuario</h2>
                <p class="usr-modal-subtitle">carlos_admin · ID 101</p>
            </div>
            <label for="usuario-form-modal" class="usr-modal-close" aria-label="Cerrar">×</label>
        </header>

        <div class="usr-modal-body">

            @* === Datos del usuario === *@
            <fieldset class="uf-section uf-section-datos">
                <legend class="uf-legend">Datos del usuario</legend>

                <div class="uf-row">
                    <div class="uf-field">
                        <label class="uf-label" for="uf-nombres">Nombres</label>
                        <input id="uf-nombres" type="text" class="uf-input" value="Carlos" />
                    </div>
                    <div class="uf-field">
                        <label class="uf-label" for="uf-apellidos">Apellidos</label>
                        <input id="uf-apellidos" type="text" class="uf-input" value="Mendoza" />
                    </div>
                </div>

                <div class="uf-field">
                    <label class="uf-label" for="uf-username">Username</label>
                    <input id="uf-username" type="text" class="uf-input" value="carlos_admin" />
                </div>

                <div class="uf-row">
                    <div class="uf-field">
                        <label class="uf-label" for="uf-dni">DNI</label>
                        <input id="uf-dni" type="text" class="uf-input" value="10234567" maxlength="8" />
                    </div>
                    <div class="uf-field">
                        <label class="uf-label" for="uf-telefono">Teléfono</label>
                        <input id="uf-telefono" type="tel" class="uf-input" value="987654100" />
                    </div>
                </div>

                <div class="uf-field">
                    <label class="uf-label" for="uf-email">Correo</label>
                    <input id="uf-email" type="email" class="uf-input" value="carlos@vetcitas.pe" />
                </div>

                <div class="uf-field">
                    <label class="uf-label" for="uf-password">Contraseña</label>
                    <div class="uf-pwd-wrap">
                        <input id="uf-password" type="password" class="uf-input uf-pwd-input" placeholder="Deja vacío para mantener la actual" minlength="6" />
                        <button type="button" class="uf-pwd-toggle" tabindex="-1"
                                onclick="vetTogglePwd('uf-password', this)"
                                aria-label="Mostrar contraseña" title="Mostrar contraseña">
                            <svg class="pwd-eye-show" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                            </svg>
                            <svg class="pwd-eye-hide" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="display:none">
                                <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755q-.247.248-.517.486z" />
                                <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829" />
                                <path d="M3.35 5.47q-.27.24-.518.487A13 13 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7 7 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238zm10.296 8.884-12-12 .708-.708 12 12z" />
                            </svg>
                        </button>
                    </div>
                    <span class="uf-hint">Mínimo 6 caracteres. En edición es opcional; al crear es obligatoria.</span>
                </div>

                <label class="uf-check">
                    <input type="checkbox" class="uf-check-input" checked />
                    <span class="uf-check-visual" aria-hidden="true"></span>
                    <span class="uf-check-text">Usuario activo</span>
                </label>
            </fieldset>

            @* === Roles asignados === *@
            <fieldset class="uf-section">
                <legend class="uf-legend">Roles asignados</legend>
                <p class="uf-hint">Marca los roles que tendrá este usuario. Puede tener más de uno.</p>

                <label class="uf-check">
                    <input type="checkbox" class="uf-check-input" id="uf-rol-admin" checked />
                    <span class="uf-check-visual" aria-hidden="true"></span>
                    <span class="uf-check-text">Administrador</span>
                </label>
                <label class="uf-check">
                    <input type="checkbox" class="uf-check-input" id="uf-rol-vet" />
                    <span class="uf-check-visual" aria-hidden="true"></span>
                    <span class="uf-check-text">Veterinario</span>
                </label>
                <label class="uf-check">
                    <input type="checkbox" class="uf-check-input" id="uf-rol-recep" />
                    <span class="uf-check-visual" aria-hidden="true"></span>
                    <span class="uf-check-text">Recepcionista</span>
                </label>
            </fieldset>

            @* === Datos específicos del rol Administrador === *@
            <fieldset class="uf-section uf-section-admin">
                <legend class="uf-legend">Datos de Administrador</legend>
                <div class="uf-field">
                    <label class="uf-label" for="uf-area">Área</label>
                    <input id="uf-area" type="text" class="uf-input" value="Sistemas" />
                </div>
            </fieldset>

            @* === Datos específicos del rol Veterinario === *@
            <fieldset class="uf-section uf-section-vet">
                <legend class="uf-legend">Datos de Veterinario</legend>
                <div class="uf-row">
                    <div class="uf-field">
                        <label class="uf-label" for="uf-cmpv">CMPV</label>
                        <input id="uf-cmpv" type="text" class="uf-input" placeholder="Código colegiatura" />
                    </div>
                    <div class="uf-field">
                        <label class="uf-label" for="uf-esp">Especialidad</label>
                        <input id="uf-esp" type="text" class="uf-input" placeholder="Ej. Medicina general" />
                    </div>
                </div>
            </fieldset>

            @* === Datos específicos del rol Recepcionista === *@
            <fieldset class="uf-section uf-section-recep">
                <legend class="uf-legend">Datos de Recepcionista</legend>
                <div class="uf-field">
                    <label class="uf-label" for="uf-area-recep">Área</label>
                    <input id="uf-area-recep" type="text" class="uf-input" placeholder="Ej. Recepción principal" />
                </div>
            </fieldset>

        </div>

        <footer class="usr-modal-foot">
            <button type="button" class="btn-usr btn-usr-primary">Guardar Usuario</button>
        </footer>
    </div>
</div>
