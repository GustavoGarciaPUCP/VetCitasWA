@rendermode InteractiveServer
@implements IDisposable
@inject VetCitasWA.Servicios.UI.ToastService Toasts

<div class="vc-toast-container">
    @foreach (var t in mensajes)
    {
        <div class="vc-toast vc-toast-@t.Tipo.ToString().ToLower()" @key="t.Id" role="status">
            <span class="vc-toast-icon" aria-hidden="true">
                @if (t.Tipo == VetCitasWA.Servicios.UI.ToastTipo.Exito)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05" /></svg>
                }
                else if (t.Tipo == VetCitasWA.Servicios.UI.ToastTipo.Error)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" /><path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z" /></svg>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2" /></svg>
                }
            </span>
            <span class="vc-toast-text">@t.Texto</span>
            <button type="button" class="vc-toast-close" aria-label="Cerrar" @onclick="() => Quitar(t)">×</button>
        </div>
    }
</div>

@code {
    private readonly List<VetCitasWA.Servicios.UI.ToastMensaje> mensajes = new();

    protected override void OnInitialized()
    {
        Toasts.OnMostrar += Mostrar;
    }

    private void Mostrar(VetCitasWA.Servicios.UI.ToastMensaje m)
    {
        _ = InvokeAsync(async () =>
        {
            mensajes.Add(m);
            StateHasChanged();

            await Task.Delay(3500);

            if (mensajes.Remove(m))
            {
                StateHasChanged();
            }
        });
    }

    private void Quitar(VetCitasWA.Servicios.UI.ToastMensaje m)
    {
        mensajes.Remove(m);
    }

    public void Dispose()
    {
        Toasts.OnMostrar -= Mostrar;
    }
}
