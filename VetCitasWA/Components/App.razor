<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["VetCitasWA.styles.css"]" />
    @* intl-tel-input: campo de teléfono con banderas *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@18.2.1/build/css/intlTelInput.css" />
    <ImportMap />
    <link rel="icon" type="image/png" href="@Assets["favicon.png"]" />
    <HeadOutlet />
    @* Aplica el tema antes de pintar para evitar flash en oscuro *@
    <script>
        function vetApplyTheme() {
            try {
                var saved = localStorage.getItem('theme');
                var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                var shouldBeDark = saved === 'dark' || (!saved && prefersDark);
                if (shouldBeDark) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }
            } catch (e) { }
        }

        function vetToggleTheme() {
            var html = document.documentElement;
            var isDark = html.classList.toggle('dark');
            try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch (e) { }
        }

        // Alterna mostrar/ocultar contraseña en un input password.
        // Uso: <button onclick="vetTogglePwd('id-del-input', this)">
        function vetTogglePwd(inputId, btn) {
            var input = document.getElementById(inputId);
            if (!input) return;
            var willShow = input.type === 'password';
            input.type = willShow ? 'text' : 'password';

            // Cambia el icono y la etiqueta accesible
            if (btn) {
                var iconShow = btn.querySelector('.pwd-eye-show');
                var iconHide = btn.querySelector('.pwd-eye-hide');
                if (iconShow) iconShow.style.display = willShow ? 'none' : '';
                if (iconHide) iconHide.style.display = willShow ? '' : 'none';
                btn.setAttribute('aria-label', willShow ? 'Ocultar contraseña' : 'Mostrar contraseña');
                btn.setAttribute('title', willShow ? 'Ocultar contraseña' : 'Mostrar contraseña');
            }
        }

        // 1) Aplica el tema inmediatamente (evita el flash en el primer render)
        vetApplyTheme();

        // 2) Re-aplica tras cada navegación mejorada de Blazor
        //    (el diff del enhanced nav puede quitar la clase del <html>)
        document.addEventListener('enhancedload', vetApplyTheme);

        // 3) Fallback: si el atributo class del <html> cambia y borra .dark,
        //    lo volvemos a poner según la preferencia guardada
        (function () {
            var observer = new MutationObserver(function () {
                try {
                    var saved = localStorage.getItem('theme');
                    var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                    var shouldBeDark = saved === 'dark' || (!saved && prefersDark);
                    var isDark = document.documentElement.classList.contains('dark');
                    if (shouldBeDark && !isDark) {
                        document.documentElement.classList.add('dark');
                    } else if (!shouldBeDark && isDark) {
                        document.documentElement.classList.remove('dark');
                    }
                } catch (e) { }
            });
            observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
        })();

    </script>
</head>

<body>
    <Routes />
    <ReconnectModal />
    @* intl-tel-input + helper de interop *@
    <script defer src="https://cdn.jsdelivr.net/npm/intl-tel-input@18.2.1/build/js/intlTelInput.min.js"></script>
    <script>
        window.vetIntlTel = {
            _map: new Map(),
            init: function (el, initial) {
                if (!el || typeof window.intlTelInput !== 'function') return;
                if (this._map.has(el)) { try { this._map.get(el).destroy(); } catch (e) { } this._map.delete(el); }
                var iti = window.intlTelInput(el, {
                    initialCountry: 'pe',
                    preferredCountries: ['pe'],
                    separateDialCode: true,
                    utilsScript: 'https://cdn.jsdelivr.net/npm/intl-tel-input@18.2.1/build/js/utils.js'
                });
                if (initial) { try { iti.setNumber(initial.charAt(0) === '+' ? initial : '+' + initial); } catch (e) { } }
                this._map.set(el, iti);
            },
            getNumber: function (el) {
                var iti = this._map.get(el);
                if (iti && typeof iti.getNumber === 'function') {
                    var n = iti.getNumber();
                    return n || (el ? el.value : '');
                }
                return el ? el.value : '';
            },
            destroy: function (el) {
                var iti = this._map.get(el);
                if (iti) { try { iti.destroy(); } catch (e) { } this._map.delete(el); }
            }
        };

        // Descarga un archivo desde una URL del mismo origen (usa la cookie de sesion)
        // y dispara la descarga en el navegador con el nombre indicado.
        window.descargarArchivo = async function (url, filename) {
            const resp = await fetch(url, { credentials: 'same-origin' });
            if (!resp.ok) {
                let detalle = '';
                try { detalle = await resp.text(); } catch (e) { }
                throw new Error('HTTP ' + resp.status + (detalle ? (': ' + detalle) : ''));
            }
            const blob = await resp.blob();
            const href = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = href;
            a.download = filename || 'archivo';
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(href);
        };
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
