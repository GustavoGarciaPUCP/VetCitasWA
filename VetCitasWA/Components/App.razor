<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["VetCitasWA.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
    @* Aplica el tema antes de pintar para evitar flash en oscuro *@
    <script>
        function vetApplyTheme() {
            try {
                var saved = localStorage.getItem('theme');
                var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                var shouldBeDark = saved === 'dark' || (!saved && prefersDark);
                if (shouldBeDark) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }
            } catch (e) { }
        }

        function vetToggleTheme() {
            var html = document.documentElement;
            var isDark = html.classList.toggle('dark');
            try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch (e) { }
        }

        // Alterna mostrar/ocultar contraseña en un input password.
        // Uso: <button onclick="vetTogglePwd('id-del-input', this)">
        function vetTogglePwd(inputId, btn) {
            var input = document.getElementById(inputId);
            if (!input) return;
            var willShow = input.type === 'password';
            input.type = willShow ? 'text' : 'password';

            // Cambia el icono y la etiqueta accesible
            if (btn) {
                var iconShow = btn.querySelector('.pwd-eye-show');
                var iconHide = btn.querySelector('.pwd-eye-hide');
                if (iconShow) iconShow.style.display = willShow ? 'none' : '';
                if (iconHide) iconHide.style.display = willShow ? '' : 'none';
                btn.setAttribute('aria-label', willShow ? 'Ocultar contraseña' : 'Mostrar contraseña');
                btn.setAttribute('title', willShow ? 'Ocultar contraseña' : 'Mostrar contraseña');
            }
        }

        // 1) Aplica el tema inmediatamente (evita el flash en el primer render)
        vetApplyTheme();

        // 2) Re-aplica tras cada navegación mejorada de Blazor
        //    (el diff del enhanced nav puede quitar la clase del <html>)
        document.addEventListener('enhancedload', vetApplyTheme);

        // 3) Fallback: si el atributo class del <html> cambia y borra .dark,
        //    lo volvemos a poner según la preferencia guardada
        (function () {
            var observer = new MutationObserver(function () {
                try {
                    var saved = localStorage.getItem('theme');
                    var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                    var shouldBeDark = saved === 'dark' || (!saved && prefersDark);
                    var isDark = document.documentElement.classList.contains('dark');
                    if (shouldBeDark && !isDark) {
                        document.documentElement.classList.add('dark');
                    } else if (!shouldBeDark && isDark) {
                        document.documentElement.classList.remove('dark');
                    }
                } catch (e) { }
            });
            observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
        })();

        // ============================================================
        // ============ Persistencia del role picker ==================
        // El estado vive en clases del <html> (que Blazor no repinta).
        // El CSS lee esas clases, NO los checkboxes. Los checkboxes
        // son solo visuales y se sincronizan al estado de la clase.
        // ============================================================
        var VET_ROLE_IDS = ['role-vet', 'role-recep', 'role-admin'];
        var VET_ROLE_CLASS = {
            'role-vet': 'role-vet-active',
            'role-recep': 'role-recep-active',
            'role-admin': 'role-admin-active'
        };
        var VET_ROLE_DEFAULT = 'role-vet';
        var vetSyncingCheckboxes = false;

        function vetGetSavedRoles() {
            try {
                var saved = localStorage.getItem('vetRoles');
                if (saved === null) return [VET_ROLE_DEFAULT];
                if (saved === '') return [];
                return saved.split(',').filter(Boolean);
            } catch (e) { return [VET_ROLE_DEFAULT]; }
        }

        function vetApplyClassesToHtml() {
            var roles = vetGetSavedRoles();
            var html = document.documentElement;
            VET_ROLE_IDS.forEach(function (id) {
                html.classList.toggle(VET_ROLE_CLASS[id], roles.indexOf(id) !== -1);
            });
        }

        function vetSyncCheckboxes() {
            vetSyncingCheckboxes = true;
            try {
                var roles = vetGetSavedRoles();
                VET_ROLE_IDS.forEach(function (id) {
                    var cb = document.getElementById(id);
                    if (cb) {
                        var shouldBe = roles.indexOf(id) !== -1;
                        if (cb.checked !== shouldBe) cb.checked = shouldBe;
                    }
                });
            } catch (e) { }
            setTimeout(function () { vetSyncingCheckboxes = false; }, 0);
        }

        function vetSaveFromCheckboxes() {
            if (vetSyncingCheckboxes) return;
            try {
                var roles = [];
                VET_ROLE_IDS.forEach(function (id) {
                    var cb = document.getElementById(id);
                    if (cb && cb.checked) roles.push(id);
                });
                localStorage.setItem('vetRoles', roles.join(','));
                vetApplyClassesToHtml();
            } catch (e) { }
        }

        function vetWireCheckboxes() {
            VET_ROLE_IDS.forEach(function (id) {
                var cb = document.getElementById(id);
                if (cb && !cb.dataset.vetWired) {
                    cb.dataset.vetWired = '1';
                    cb.addEventListener('change', vetSaveFromCheckboxes);
                }
            });
        }

        function vetInitRoles() {
            vetApplyClassesToHtml();
            vetSyncCheckboxes();
            vetWireCheckboxes();
        }

        // 1) Aplica las clases del <html> INMEDIATAMENTE (antes del paint)
        //    así no hay flash del menú filtrado mal.
        vetApplyClassesToHtml();

        // 2) Sincroniza los checkboxes y los engancha cuando el DOM ya
        //    tenga los elementos del sidebar.
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function () {
                vetSyncCheckboxes();
                vetWireCheckboxes();
            });
        } else {
            vetSyncCheckboxes();
            vetWireCheckboxes();
        }

        // 3) Tras cada navegación mejorada Blazor repinta el NavMenu;
        //    re-aplicamos las clases (idempotente) y re-sincronizamos
        //    los checkboxes nuevos.
        document.addEventListener('enhancedload', vetInitRoles);

        // 4) Red de seguridad: si por cualquier motivo las clases del
        //    <html> son borradas o difieren del estado guardado, las
        //    restauramos al instante.
        (function () {
            var observer = new MutationObserver(function () {
                var saved = vetGetSavedRoles();
                var html = document.documentElement;
                var needsFix = VET_ROLE_IDS.some(function (id) {
                    var want = saved.indexOf(id) !== -1;
                    return html.classList.contains(VET_ROLE_CLASS[id]) !== want;
                });
                if (needsFix) vetApplyClassesToHtml();
            });
            observer.observe(document.documentElement, {
                attributes: true,
                attributeFilter: ['class']
            });
        })();

        // 5) Observer del body: re-sincroniza los checkboxes visuales
        //    cuando Blazor repinta el sidebar. Sin esto, los inputs
        //    vienen del servidor con sus defaults y se ven reseteados
        //    aunque la lógica de menú filtrada por las clases del <html>
        //    siga funcionando.
        (function () {
            var debounce = null;

            function checkboxesNeedSync() {
                var saved = vetGetSavedRoles();
                return VET_ROLE_IDS.some(function (id) {
                    var cb = document.getElementById(id);
                    if (!cb) return false;
                    var shouldBe = saved.indexOf(id) !== -1;
                    return cb.checked !== shouldBe;
                });
            }

            var observer = new MutationObserver(function () {
                if (vetSyncingCheckboxes) return; // ignoramos nuestros propios cambios
                if (debounce) clearTimeout(debounce);
                debounce = setTimeout(function () {
                    if (checkboxesNeedSync()) {
                        vetSyncCheckboxes();
                    }
                    vetWireCheckboxes();
                }, 16); // ~1 frame
            });

            function attach() {
                if (document.body) {
                    observer.observe(document.body, {
                        childList: true,
                        subtree: true,
                        attributes: true,
                        attributeFilter: ['checked']
                    });
                    return true;
                }
                return false;
            }

            if (!attach()) {
                document.addEventListener('DOMContentLoaded', attach);
            }
        })();
    </script>
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
